<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="NamoaMaterialButtonFilled" parent="Widget.Material3.Button.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
        <item name="iconSize">18dp</item>
        <item name="android:paddingHorizontal">15dp</item>
    </style>

    <style name="NamoaTheme3.TextInputLayout.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:textColorHint">@drawable/edittext_theme</item>
        <item name="hintTextColor">@drawable/edittext_theme</item>
        <item name="boxStrokeColor">@drawable/edittext_theme_outlined</item>
        <item name="android:textColor">@drawable/edittext_theme_text</item>
        <item name="android:paddingVertical">8dp</item>
    </style>


    <style name="NamoaTheme3.TextInputLayout.Outlined.Transparent">
        <item name="android:textColorHint">@drawable/edittext_theme_text_transparent_hint</item>
        <item name="hintTextAppearance">@style/TextAppearance.Material3.LabelMedium</item>
        <item name="boxStrokeColor">@android:color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="android:textColor">@drawable/edittext_theme_text_transparent_text</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyLarge</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="NamoaTheme3.Button.Icon.Tonal" parent="NamoaTheme3.Button.Outlined">
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_width">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="iconPadding">8dp</item>
        <item name="iconSize">24dp</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="startIconTint">@color/m3_namoa_onSecondaryContainer</item>
        <item name="iconTint">@color/m3_namoa_onSecondaryContainer</item>
        <item name="backgroundTint">@drawable/icon_button_theme_tonal</item>
        <item name="backgroundColor">@drawable/icon_button_theme_tonal</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="boxBackgroundMode">none</item>
        <item name="android:insetTop">4dp</item>
        <item name="android:insetBottom">4dp</item>
        <item name="android:insetLeft">4dp</item>
        <item name="android:insetRight">4dp</item>
    </style>

    <style name="NamoaTheme3.Button.Icon.Filled" parent="NamoaTheme3.Button.Outlined">
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_width">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="iconPadding">8dp</item>
        <item name="iconSize">24dp</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="startIconTint">@color/m3_namoa_onPrimary</item>
        <item name="iconTint">@color/m3_namoa_onPrimary</item>
        <item name="backgroundTint">@drawable/icon_button_theme_filled</item>
        <item name="backgroundColor">@drawable/icon_button_theme_filled</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="boxBackgroundMode">none</item>
        <item name="android:insetTop">4dp</item>
        <item name="android:insetBottom">4dp</item>
        <item name="android:insetLeft">4dp</item>
        <item name="android:insetRight">4dp</item>
    </style>
</resources>