<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="NamoaMaterialButtonFilled" parent="Widget.Material3.Button.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
        <item name="iconSize">18dp</item>
        <item name="android:paddingHorizontal">15dp</item>
    </style>

    <style name="NamoaTheme3.TextInputLayout.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="hintTextColor">@drawable/edittext_theme</item>
        <item name="boxStrokeColor">@drawable/edittext_theme_outlined</item>
        <item name="android:textColor">@drawable/edittext_theme_text</item>
        <item name="android:paddingVertical">8dp</item>
    </style>


    <style name="NamoaTheme3.TextInputLayout.Outlined.Transparent">
        <item name="android:textColorHint">@drawable/edittext_theme_text_transparent_hint</item>
        <item name="hintTextAppearance">@style/TextAppearance.Material3.LabelMedium</item>
        <item name="boxStrokeColor">@android:color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="android:textColor">@drawable/edittext_theme_text_transparent_text</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyLarge</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="ButtonCircleWithIcon">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@color/m3_namoa_secondaryContainer</item>
        <item name="android:padding">1dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="shapeAppearanceOverlay">@style/RoundedImageView</item>
        <item name="android:scaleType">center</item>
        <item name="android:tint">@color/m3_namoa_onSurfaceVariant</item>
    </style>
</resources>