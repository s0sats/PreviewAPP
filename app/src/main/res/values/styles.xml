<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here.
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item> -->

        <item name="colorPrimary">@color/namoa_color_light_blue</item>
        <item name="colorPrimaryDark">@color/namoa_color_dark_blue</item>
        <item name="colorAccent">@color/namoa_lime_green</item>
        <item name="android:textColor">@color/namoa_color_dark_blue</item>
        <item name="android:textColorPrimary">@color/namoa_color_dark_blue</item>
     <!--   <item name="android:textColorPrimary">@color/namoa_color_light_blue</item>-->
