<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar.Bridge">
        <!-- Customize your theme here.
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item> -->

        <item name="colorPrimary">@color/namoa_color_light_blue</item>
        <item name="colorPrimaryDark">@color/namoa_color_dark_blue</item>
        <item name="colorAccent">@color/namoa_color_light_green3</item>
        <item name="android:textColor">@color/namoa_color_dark_blue</item>
        <item name="android:textColorPrimary">@color/namoa_color_dark_blue</item>
        <item name="android:statusBarColor">@color/namoa_color_dark_blue</item>
        <!--   <item name="android:textColorPrimary">@color/namoa_color_light_blue</item>-->

        <!-- Material3 attributes (needed if parent="Theme.MaterialComponents"). -->
        <item name="colorPrimaryInverse">@color/namoa_color_light_blue</item>
        <item name="colorPrimaryContainer">@color/namoa_color_light_blue</item>
        <item name="colorOnPrimaryContainer">@color/namoa_color_light_blue</item>
        <item name="colorSecondaryContainer">@color/namoa_color_dark_blue</item>
        <item name="colorOnSecondaryContainer">@color/namoa_color_dark_blue</item>
        <item name="colorTertiary">@color/namoa_color_light_green3</item>
        <item name="colorOnTertiary">@color/namoa_color_light_green3</item>
        <item name="colorTertiaryContainer">@color/namoa_color_light_green3</item>
        <item name="colorOnTertiaryContainer">@color/namoa_color_light_green3</item>
        <item name="colorSurfaceVariant">@color/namoa_color_light_blue</item>
        <item name="colorOnSurfaceVariant">@color/namoa_color_light_blue</item>
        <item name="colorSurfaceInverse">@color/namoa_color_light_blue</item>
        <item name="colorOnSurfaceInverse">@color/namoa_color_light_blue</item>
        <item name="colorOutline">@color/namoa_color_dark_blue</item>
        <item name="colorErrorContainer">@color/namoa_color_danger_red</item>
        <item name="colorOnErrorContainer">@color/namoa_color_danger_red_alpha</item>
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Material3.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.Material3.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.Material3.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Material3.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Material3.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Material3.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Material3.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Material3.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Material3.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Material3.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Material3.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Material3.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Material3.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Material3.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Material3.LabelSmall</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Material3.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Material3.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Material3.LargeComponent</item>

        <item name="bottomSheetDialogTheme">@style/BottomSheetDialog_Rounded</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.AppBarFlat" parent="ThemeOverlay.AppCompat.Dark.ActionBar" >
        <item name="elevation">0dp</item>
        <item name="android:translationZ">0dp</item>
    </style>

    <style name="MyFormOSDrawerImageButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/namoa_icon_bg_states</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="MyAlertDialogTheme" parent="Base.Theme.AppCompat.Light.Dialog.Alert">
        <item name="windowFixedWidthMajor">90%</item>
        <item name="windowFixedWidthMinor">90%</item>
    </style>

    <style name="TextViewForm" parent="AppTheme">
        <item name="android:textColor">@color/namoa_color_light_blue</item>
        <item name="android:textSize">@dimen/font_size_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NamoaSaveButton" parent="@android:style/Widget.Button">
        <item name="android:background">@color/namoa_pipeline_product_lbl</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
    </style>

    <style name="MyTicketRadioButtton" parent="@android:style/Widget.Button">
        <item name="android:background">@color/padrao_TRANSPARENT</item>
        <item name="android:textColor">@color/namoa_amount_pipeline_background_btn</item>
    </style>

    <style name="MyHomeFilterDialogRadioButtton" parent="@android:style/Widget.Button">
        <item name="android:background">@color/padrao_TRANSPARENT</item>
        <item name="android:textColor">@color/namoa_color_green_2</item>
    </style>

    <style name="TextViewChips" parent="Widget.AppCompat.TextView">
        <item name="android:background">@drawable/textview_chip_bg</item>
        <item name="android:textSize">13sp</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:padding">8dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TextViewGray9Padding" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/namoa_color_gray_9</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="ImageViewButtonStd">
        <item name="android:padding">15dp</item>
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="tint">@color/namoa_dark_blue</item>
        <item name="android:background">@drawable/namoa_icon_bg_states</item>
    </style>

    <style name="TextInputLayoutHelperTextColorRequired" parent="Widget.Design.TextInputLayout">
        <item name="android:textColor">@color/font_required</item>
    </style>

    <style name="NamoaSaveButtonDarkBlue" parent="@android:style/Widget.Button">
        <item name="android:textColor">@color/padrao_WHITE</item>
        <item name="android:background">@drawable/btn_namoa_main_4_states</item>
        <item name="textAllCaps">true</item>
    </style>

    <style name="NamoaFormOsRadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:buttonTint">@color/os_form_verify_item_label_text_color_states</item>
        <item name="android:background">@drawable/os_form_verify_background_states</item>
        <item name="android:textColor">@color/os_form_verify_text_color_states</item>
        <item name="android:textSize">@dimen/font_size_font_16</item>
    </style>

    <style name="TextInputLayoutHelperTextColorMainBlue" parent="Widget.Design.TextInputLayout">
        <item name="android:textColor">@color/namoa_dark_blue</item>
    </style>

    <style name="NamoaMaterialButtonOutlined" parent="Widget.Material3.Button.OutlinedButton.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/namoa_color_dark_blue</item>
        <item name="android:textColor">@color/namoa_color_dark_blue</item>
        <item name="iconSize">18dp</item>
    </style>

    <style name="NamoaMaterialButtonElevated" parent="Widget.Material3.Button.ElevatedButton.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/namoa_color_dark_blue</item>
        <item name="android:textColor">@color/namoa_color_dark_blue</item>
        <item name="iconSize">18dp</item>
    </style>

    <style name="NamoaMaterialButtonElevatedFilled" parent="Widget.Material3.Button.ElevatedButton.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="backgroundTint">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
        <item name="iconSize">18dp</item>
    </style>

    <style name="NamoaMaterialButtonFilled" parent="Widget.Material3.Button.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
        <item name="iconSize">18dp</item>
    </style>

    <style name="NamoaMaterialButtonFilledGreen" parent="Widget.Material3.Button">
        <item name="strokeColor">@color/namoa_color_light_green5</item>
<!--        <item name="backgroundTint">@color/namoa_green_bg_color_states</item>-->
        <item name="backgroundTint">@color/namoa_color_light_green5</item>
        <item name="iconSize">18dp</item>
    </style>

    <style name="NamoaMaterialButtonFilledDarkBlue" parent="Widget.Material3.Button.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="backgroundTint">@color/namoa_color_dark_blue</item>
        <item name="iconSize">18dp</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
    </style>

    <style name="NamoaNoIconMaterialButtonFilledDarkBlue" parent="Widget.Material3.Button.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="backgroundTint">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="NamoaNMaterialButtonFilledDarkBlue" parent="Widget.Material3.Button.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="background">@color/namoa_color_dark_blue</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="NamoaMaterialButtonFilledOrange" parent="Widget.Material3.Button.Icon">
        <item name="strokeColor">@color/namoa_color_highlight_required_item</item>
        <item name="backgroundTint">@color/namoa_color_highlight_required_item</item>
        <item name="iconSize">18dp</item>
        <item name="iconTint">@color/padrao_WHITE</item>
        <item name="android:textColor">@color/padrao_WHITE</item>
    </style>

    <style name="NamoaMaterialButtonText" parent="Widget.Material3.Button.TextButton.Icon">
        <item name="strokeColor">@color/namoa_color_dark_blue</item>
        <item name="iconTint">@color/namoa_color_dark_blue</item>
        <item name="android:textColor">@color/namoa_color_dark_blue</item>
        <item name="iconSize">18dp</item>
    </style>

    <style name="BottomSheetDialog_Rounded" parent="@style/ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheet_Rounded</item>
    </style>

    <style name="BottomSheet_Rounded" parent="Widget.MaterialComponents.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceBottomSheetDialog_Rounded</item>
    </style>

    <style name="ShapeAppearanceBottomSheetDialog_Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>


    <style name="ShapeAppearanceCard_Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeBottomRight">16dp</item>
        <item name="cornerSizeBottomLeft">16dp</item>
    </style>


</resources>
