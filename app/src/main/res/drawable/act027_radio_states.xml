<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:state_enabled="false"
        android:drawable="@color/namoa_color_gray"
        />

    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid
                android:color="@color/padrao_TRANSPARENT" />
            <stroke
                android:color="@color/namoa_color_gray"
                android:width="1dp"
                />
        </shape>
    </item>

    <item
        android:state_checked="true"
        android:drawable="@color/namoa_color_light_green4"
        />

</selector>