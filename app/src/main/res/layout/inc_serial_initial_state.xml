<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Estado da Máquina antes do início da OS"
        style="@style/TextAppearance.Material3.TitleLarge"
        android:textColor="@color/namoa_color_black"
        android:textStyle="bold"
        android:textSize="@dimen/font_size_font_20"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_question_lbl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Estado da Máquina antes do início da OS"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:textColor="@color/namoa_color_black"
        style="@style/TextAppearance.Material3.BodyMedium"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/sw_initial_state_machine"
        />


    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/sw_initial_state_machine"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:textSize="@dimen/font_size_font_16"
        android:thumb="@drawable/namoa_switch_states"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/tv_question_lbl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_question_lbl"
        app:thumbTint="@color/namoa_form_onboard_switch_color_states"
        app:trackTint="@color/namoa_form_onboard_switch_track_color_states" />

    <RadioGroup
        android:id="@+id/rg_stop_machine"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_question_lbl">

        <RadioButton
            android:id="@+id/rb_machine_running"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Não estava parada" />

        <RadioButton
            android:id="@+id/rb_machine_stopped"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parada desde:" />

    </RadioGroup>

    <View
        android:id="@+id/view_separator"
        android:layout_width="24dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/rg_responsable_stop_machine"
        app:layout_constraintStart_toStartOf="@+id/tv_question_lbl"
        app:layout_constraintTop_toBottomOf="@+id/rg_stop_machine" />

    <TextView
        android:id="@+id/tv_serial_stopped_date_lbl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:text="Parada desde:"
        android:textColor="@color/namoa_color_black"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/view_separator"
        app:layout_constraintTop_toBottomOf="@+id/rg_stop_machine" />


    <com.namoa_digital.namoa_library.ctls.MkDateTime
        android:id="@+id/mk_date_val"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/view_separator"
        app:layout_constraintTop_toBottomOf="@+id/tv_serial_stopped_date_lbl"
        app:mConfigType="DATE_HOUR"
        app:mTextSizeLabel="16sp" />

    <TextView
        android:id="@+id/tv_responsable_stop_machine_lbl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:text="Responsável pela parada:"
        android:textColor="@color/namoa_color_black"
        android:textSize="@dimen/font_size_font_16"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/view_separator"
        app:layout_constraintTop_toBottomOf="@+id/mk_date_val" />

    
    <RadioGroup
        android:id="@+id/rg_responsable_stop_machine"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/view_separator"
        app:layout_constraintTop_toBottomOf="@+id/tv_responsable_stop_machine_lbl">

        <RadioButton
            android:id="@+id/rb_maintenance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manutenção" />

        <RadioButton
            android:id="@+id/rb_third_party_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Erro do operador" />

    </RadioGroup>


</androidx.constraintlayout.widget.ConstraintLayout>