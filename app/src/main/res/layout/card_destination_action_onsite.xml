<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#E4EEF0"
    >

    <TextView
        android:id="@+id/tv_action_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_margin="16dp"
        style="@style/TextAppearance.Material3.TitleSmall"
        android:textColor="@color/m3_namoa_onSurfaceVariant"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="02/08/23 10:38 - 10:56"
        />

    <TextView
        android:id="@+id/tv_action_desc"
        style="@style/TextAppearance.Material3.BodyLarge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/m3_namoa_onSurfaceVariant"
        app:layout_constraintEnd_toEndOf="@+id/tv_action_date"
        app:layout_constraintStart_toStartOf="@+id/tv_action_date"
        app:layout_constraintTop_toBottomOf="@id/tv_action_date"
        tools:text="Corretiva de manutenção não planejada" />

    <TextView
        android:id="@+id/tv_action_serial"
        style="@style/TextAppearance.Material3.TitleLarge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/m3_namoa_onSurface"
        app:layout_constraintEnd_toEndOf="@+id/tv_action_desc"
        app:layout_constraintStart_toStartOf="@+id/tv_action_desc"
        app:layout_constraintTop_toBottomOf="@id/tv_action_desc"
        tools:text="2587" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_ticket"
        style="@style/NamoaTheme3.Button.Text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginRight="12dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@+id/v_line"
        app:layout_constraintEnd_toStartOf="@+id/btn_open_form_os"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_action_serial"
        app:layout_constraintWidth_default="wrap"
        tools:text="Abrir Ticket" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_form_os"
        style="@style/NamoaTheme3.Button.Text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@+id/v_line"
        app:layout_constraintEnd_toEndOf="@+id/tv_action_serial"
        app:layout_constraintTop_toBottomOf="@+id/tv_action_serial"
        app:layout_constraintWidth_default="wrap"
        tools:text="Abrir OS" />


    <View
        android:id="@+id/v_line"
        android:layout_width="match_parent"
        android:layout_height="1sp"
        android:layout_marginTop="12dp"
        android:background="@color/m3_namoa_outlineVariant"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>