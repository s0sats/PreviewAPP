            <View
                android:id="@+id/act086_v_divider_answer"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/namoa_color_gray_6"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/act086_rg_answers" />

            <TextView
                android:id="@+id/act086_tv_other_data_ttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Dados complementares"
                android:textAllCaps="true"
                android:textSize="16sp"
                app:layout_constraintEnd_toStartOf="@+id/act086_gd_end"
                app:layout_constraintStart_toStartOf="@+id/act086_gd_start"
                app:layout_constraintTop_toBottomOf="@+id/act086_v_divider_answer" />

            <ImageView
                android:id="@+id/act086_iv_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/act086_mket_comment"
                app:layout_constraintStart_toStartOf="@+id/act086_gd_start"
                app:layout_constraintTop_toTopOf="@+id/act086_mket_comment"
                app:srcCompat="@drawable/ic_baseline_notes_24" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act086_mket_comment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                app:layout_constraintEnd_toEndOf="@id/act086_gd_end"
                app:layout_constraintStart_toEndOf="@id/act086_iv_comment"
                app:layout_constraintTop_toBottomOf="@id/act086_tv_other_data_ttl"
                app:mBARCODE="false"
                tools:hint="Inserir comentario" />

            <ImageView
                android:id="@+id/act086_iv_spare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/act086_tv_spare_ttl"
                app:layout_constraintStart_toStartOf="@+id/act086_gd_start"
                app:layout_constraintTop_toTopOf="@+id/act086_tv_spare_ttl"
                app:srcCompat="@drawable/ic_archive_material_black_24dp"
                app:tint="@color/namoa_pipeline_header_icon" />

            <TextView
                android:id="@+id/act086_tv_spare_ttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="10dp"
                android:hint="Insumos aplicados: 0"
                app:layout_constraintStart_toEndOf="@+id/act086_iv_spare"
                app:layout_constraintTop_toBottomOf="@+id/act086_mket_comment" />

            <ImageView
                android:id="@+id/act086_iv_add_spare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/act086_tv_spare_ttl"
                app:layout_constraintEnd_toStartOf="@+id/act086_gd_end"
                app:layout_constraintTop_toTopOf="@+id/act086_tv_spare_ttl"
                app:layout_constraintVertical_bias="0.0"
                app:srcCompat="@drawable/ic_add_black_24px" />

            <TextView
                android:id="@+id/act086_tv_photo_ttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="8dp"
                android:hint="Photo"
                app:layout_constraintEnd_toStartOf="@+id/act086_iv_add_photo"
                app:layout_constraintStart_toEndOf="@+id/act086_iv_photo"
                app:layout_constraintTop_toBottomOf="@+id/act086_tv_spare_ttl" />

            <ImageView
                android:id="@+id/act086_iv_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:tint="@color/namoa_pipeline_header_icon"
                app:layout_constraintBottom_toBottomOf="@+id/act086_tv_photo_ttl"
                app:layout_constraintStart_toStartOf="@+id/act086_gd_start"
                app:layout_constraintTop_toTopOf="@+id/act086_tv_photo_ttl"
                app:srcCompat="@drawable/ic_baseline_photo_camera_24" />

            <ImageView
                android:id="@+id/act086_iv_add_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/act086_tv_photo_ttl"
                app:layout_constraintEnd_toStartOf="@+id/act086_gd_end"
                app:layout_constraintTop_toTopOf="@+id/act086_tv_photo_ttl"
                app:srcCompat="@drawable/ic_add_black_24px"
                android:clickable="true"
                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/act086_rv_photos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:layout_constraintEnd_toEndOf="@id/act086_gd_end"
                app:layout_constraintStart_toStartOf="@id/act086_gd_start"
                app:layout_constraintTop_toBottomOf="@id/act086_tv_photo_ttl"
                app:spanCount="2"
                tools:itemCount="4"
                tools:listitem="@layout/act086_photo_item" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/act086_cl_delete_infos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@id/act086_gd_end"
                app:layout_constraintStart_toStartOf="@id/act086_gd_start"
                app:layout_constraintTop_toBottomOf="@id/act086_rv_photos"
                android:padding="8dp"
                >

                <ImageView
                    android:id="@+id/act086_iv_delete_infos"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_trash"
                    android:tint="@color/namoa_color_danger_red"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/act086_iv_delete_infos"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:text="Descartar resposta e anexos"
                    android:gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/namoa_color_danger_red"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <Button
                android:id="@+id/act086_btn_ok"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@id/act086_gd_start"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/act086_cl_delete_infos"
                app:layout_constraintWidth_percent="0.5"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/namoa_cell_12_states"
                android:textColor="@color/padrao_WHITE"
                android:text="Ok"
                />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>