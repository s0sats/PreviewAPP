<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act086.Act086Main"
    tools:showIn="@layout/act086_main">

    <include
        android:id="@+id/include"
        layout="@layout/footer_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"

            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <androidx.cardview.widget.CardView
                android:id="@+id/act086_cv_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/act086_tv_description"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="8dp"
                        android:text="Verificar articulações  e cabos do freio de estacionamento"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <RadioGroup
                        android:id="@+id/act086_tabs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/act086_tv_description">

                        <RadioButton
                            android:id="@+id/act086_tab_answer"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:background="@drawable/act074_radio_states"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:textAllCaps="true"
                            android:textColor="@color/my_tickets_radio"
                            android:textStyle="bold"
                            android:text="resposta" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="match_parent" />

                        <RadioButton
                            android:id="@+id/act086_tab_info"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:background="@drawable/act074_radio_states"
                            android:button="@null"
                            android:gravity="center"
                            android:textAllCaps="true"
                            android:textColor="@color/my_tickets_radio"
                            android:textStyle="bold"
                            android:text="informações" />

                    </RadioGroup>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/act086_tv_alert_ttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Alerta Atual"
                android:textAllCaps="true"
                android:textSize="16sp"
                app:layout_constraintEnd_toStartOf="@+id/act086_gd_end"
                app:layout_constraintStart_toStartOf="@+id/act086_gd_start"
                app:layout_constraintTop_toBottomOf="@id/act086_cv_header" />

            <TextView
                android:id="@+id/act086_tv_subttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Alerta Manual (5 dias)"
                android:textColor="@color/namoa_color_danger_red"
                app:layout_constraintEnd_toStartOf="@+id/act086_gd_end"
                app:layout_constraintStart_toStartOf="@+id/act086_gd_start"
                app:layout_constraintTop_toBottomOf="@+id/act086_tv_alert_ttl" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/act086_gd_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="16dp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/act086_gd_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="16dp" />

            <View
                android:id="@+id/act086_v_divider_alert"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/namoa_color_gray_6"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/act086_tv_subttl" />

            <TextView
                android:id="@+id/act086_tv_answer_ttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Resposta"
                android:textAllCaps="true"
                android:textSize="16sp"
                app:layout_constraintEnd_toStartOf="@+id/act086_gd_end"
                app:layout_constraintStart_toStartOf="@+id/act086_gd_start"
                app:layout_constraintTop_toBottomOf="@+id/act086_v_divider_alert" />

            <RadioGroup
                android:id="@+id/act086_rg_answers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toStartOf="@+id/act086_gd_end"
                app:layout_constraintStart_toStartOf="@id/act086_gd_start"
                app:layout_constraintTop_toBottomOf="@+id/act086_tv_answer_ttl">

                <RadioButton
                    android:id="@+id/act086_rdo_answer_done"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_build_black_24dp"
                    android:drawableTint="@color/os_form_answer_done_action_color_states"
                    android:buttonTint="@color/os_form_answer_done_action_color_states"
                    android:checked="true"
                    android:paddingStart="8dp"
                    android:drawablePadding="8dp"
                    android:textColor="@color/os_form_verify_text_color_states"
                    android:textStyle="bold"
                    android:text="Ação realizada" />

                <RadioButton
                    android:id="@+id/act086_rdo_answer_problem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@drawable/ic_outline_report_problem_24_black"
                    android:drawableTint="@color/os_form_answer_problem_color_states"
                    android:buttonTint="@color/os_form_answer_problem_color_states"
                    android:checked="false"
                    android:paddingStart="8dp"
                    android:drawablePadding="8dp"
                    android:textColor="@color/os_form_verify_text_color_states"
                    android:textStyle="bold"
                    android:text="Continua com problema" />

                <RadioButton
                    android:id="@+id/act086_rdo_answer_verified"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@drawable/ic_done_black_24dp"
                    android:drawableTint="@color/os_form_answer_verified_color_states"
                    android:buttonTint="@color/os_form_answer_verified_color_states"
                    android:checked="false"
                    android:paddingStart="8dp"
                    android:drawablePadding="8dp"
                    android:textColor="@color/os_form_verify_text_color_states"
                    android:textStyle="bold"
                    android:text="Já estava ok" />

                <RadioButton
                    android:id="@+id/act086_rdo_answer_not_verified"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@drawable/ic_baseline_redo_24_black"
                    android:drawableTint="@color/os_form_answer_not_verified_color_states"
                    android:buttonTint="@color/os_form_answer_not_verified_color_states"
                    android:checked="false"
                    android:paddingStart="8dp"
                    android:drawablePadding="8dp"
                    android:textColor="@color/os_form_verify_text_color_states"
                    android:textStyle="bold"
                    android:text="Não verificado" />
            </RadioGroup>

