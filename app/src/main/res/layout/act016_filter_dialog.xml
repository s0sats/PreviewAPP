<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/act016_filter_dialog_tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/font_size_title"
        android:text="Filtros - trad"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"
        />

    <CheckBox
        android:id="@+id/act016_filter_dialog_chk_n_form"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/namoa_dark_blue"
        android:layout_marginBottom="20dp"
        android:text="Edit - trad"
        android:checked="true"
        />

    <CheckBox
        android:id="@+id/act016_filter_dialog_chk_n_form_ap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/namoa_dark_blue"
        android:layout_marginBottom="20dp"
        android:checked="true"
        android:text="Process - trad"
        />

</LinearLayout>