<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    >

    <View
        android:id="@+id/act086_product_edit_dialog_v_top"
        android:layout_width="50dp"
        android:layout_height="3dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:background="@color/namoa_dark_blue" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/act086_product_edit_dialog_tv_product_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:text="Oleo Super Freio"
            android:textColor="@color/namoa_font_color_black222"
            android:textSize="18sp"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.501"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act086_product_edit_dialog_tv_product_id" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_act086_product_edit_dialog_et_qty"
            style="@style/NamoaTheme3.TextInputLayout.Outlined"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:minWidth="100dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toStartOf="@+id/act086_product_edit_dialog_tv_unit"
            app:layout_constraintHorizontal_bias="0.57"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act086_product_edit_dialog_tv_product_desc"
            app:layout_constraintWidth_percent="0.4">

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act086_product_edit_dialog_et_qty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:ems="2"
                android:imeOptions="actionDone"
                android:inputType="numberDecimal"
                android:selectAllOnFocus="true"
                tools:text="2,100000000000"
                android:textSize="@dimen/font_size_font_16"
                android:textColor="@color/m3_namoa_onSurface"
                app:mBARCODE="false"
                app:mDecimal="4"
                app:mInputType="NUMBER"
                app:mNFC="false"
                app:mOCR="false"
                app:mOCRVin="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/act086_product_edit_dialog_tv_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="L"
            android:textColor="@color/namoa_font_color_black222"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/til_act086_product_edit_dialog_et_qty"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/til_act086_product_edit_dialog_et_qty"
            app:layout_constraintTop_toTopOf="@+id/til_act086_product_edit_dialog_et_qty" />


        <Button
            android:id="@+id/act086_product_edit_dialog_btn_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="Cancelar"
            android:textColor="@color/namoa_dark_blue"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/act086_product_edit_dialog_btn_apply"
            app:layout_constraintTop_toTopOf="@+id/act086_product_edit_dialog_btn_apply" />

        <Button
            android:id="@+id/act086_product_edit_dialog_btn_apply"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Adicionar"
            android:textColor="@color/namoa_dark_blue"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/til_act086_product_edit_dialog_et_qty" />

        <TextView
            android:id="@+id/act086_product_edit_dialog_tv_product_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="18758"
            android:textColor="@color/namoa_font_color_black222"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>