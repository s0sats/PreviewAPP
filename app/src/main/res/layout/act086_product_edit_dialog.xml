<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:animateLayoutChanges="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_marginTop="4dp"
        android:layout_width="50dp"
        android:layout_height="3dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/cardview_dark_background"
        android:layout_marginBottom="4dp"
        />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:padding="10dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/act086_product_edit_dialog_tv_product_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="18758 - Oleo Super Freio"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.501"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/act086_product_edit_dialog_tv_title" />

            <EditText
                android:id="@+id/act086_product_edit_dialog_et_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ems="2"
                android:inputType="numberDecimal"
                android:text="2,1"
                app:layout_constraintEnd_toEndOf="@+id/act086_product_edit_dialog_tv_product_desc"
                app:layout_constraintStart_toStartOf="@+id/act086_product_edit_dialog_tv_product_desc"
                app:layout_constraintTop_toBottomOf="@+id/act086_product_edit_dialog_tv_product_desc" />

            <TextView
                android:id="@+id/act086_product_edit_dialog_tv_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="L"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/act086_product_edit_dialog_et_qty"
                app:layout_constraintStart_toEndOf="@+id/act086_product_edit_dialog_et_qty"
                app:layout_constraintTop_toTopOf="@+id/act086_product_edit_dialog_et_qty" />

            <TextView
                android:id="@+id/act086_product_edit_dialog_tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Aplicação de Insumo"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/act086_product_edit_dialog_btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:text="Cancelar"
                app:layout_constraintEnd_toStartOf="@+id/act086_product_edit_dialog_gd_middle"
                app:layout_constraintTop_toBottomOf="@+id/act086_product_edit_dialog_et_qty"
                style="@style/Widget.AppCompat.Button.Borderless.Colored"
                />

            <Button
                android:id="@+id/act086_product_edit_dialog_btn_apply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="Adicionar"
                app:layout_constraintStart_toEndOf="@+id/act086_product_edit_dialog_btn_cancel"
                app:layout_constraintTop_toBottomOf="@+id/act086_product_edit_dialog_et_qty"
                style="@style/Widget.AppCompat.Button.Borderless.Colored"
                />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/act086_product_edit_dialog_gd_middle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>