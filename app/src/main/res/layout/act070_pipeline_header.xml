<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardElevation="8dp"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <android.support.constraint.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <android.support.constraint.Guideline
            android:id="@+id/act070_ticket_cell_guide_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_begin="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.Guideline
            android:id="@+id/act070_ticket_cell_guide_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="8dp"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.ConstraintLayout
            android:id="@+id/act070_ticket_cell_cl_ticket_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/act070_ticket_cell_tv_status"
            app:layout_constraintStart_toStartOf="@id/act070_ticket_cell_guide_start"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/act070_ticket_cell_tv_ticket_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="2019.999" />
        </android.support.constraint.ConstraintLayout>

        <TextView
            android:id="@+id/act070_ticket_cell_tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:textColor="@color/namoa_color_light_blue"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_ticket_cell_guide_end"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Pending" />

        <TextView
            android:id="@+id/act070_ticket_cell_tv_prod_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act070_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act070_ticket_cell_tv_site_desc"
            tools:text="Desc Prod" />

        <TextView
            android:id="@+id/act070_ticket_cell_tv_site_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/namoa_color_danger_red"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/act070_ticket_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/act070_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_ticket_cell_cl_ticket_id"
            tools:text="Site - trad" />

        <TextView
            android:id="@+id/act070_ticket_cell_tv_serial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act070_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act070_ticket_cell_tv_prod_desc"
            tools:text="Serial ID" />

        <android.support.v7.widget.CardView
            android:id="@+id/cv_btn_sync"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:elevation="15dp"
            app:layout_constraintEnd_toStartOf="@+id/act070_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@+id/act070_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_ticket_cell_tv_serial"
            app:layout_constraintWidth_percent=".60">

            <LinearLayout
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@color/namoa_sync_pipeline_background_btn"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:src="@drawable/ic_baseline_sync_24" />

                <TextView
                    android:id="@+id/btn_sync_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="FAVOR SINCRONIZAR" />

            </LinearLayout>
        </android.support.v7.widget.CardView>

        <android.support.constraint.ConstraintLayout
            android:id="@+id/act070_pipeline_header_ticket"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/act070_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@+id/act070_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/cv_btn_sync">

            <ImageView
                android:id="@+id/iv_ticket_header_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:src="@drawable/ic_baseline_report_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/act070_ticket_cell_tv_desc_origin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="4dp"
                android:ellipsize="start"
                android:singleLine="true"
                app:layout_constraintEnd_toStartOf="@+id/act070_ticket_cell_tv_action_shortcut"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@+id/iv_ticket_header_icon"
                app:layout_constraintTop_toTopOf="parent"
                tools:text=".../lalalla/alallal" />

            <ImageView
                android:id="@+id/act070_ticket_cell_tv_ticket_status_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:tint="@color/namoa_color_green_2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@+id/act070_ticket_cell_tv_desc_origin"
                app:layout_constraintTop_toBottomOf="@+id/act070_ticket_cell_tv_desc_origin"
                app:srcCompat="@drawable/ic_check_white_24dp" />

            <TextView
                android:id="@+id/act070_ticket_cell_tv_ticket_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:singleLine="true"
                tools:text="TextView"
                app:layout_constraintBottom_toBottomOf="@+id/act070_ticket_cell_tv_ticket_status_icon"
                app:layout_constraintEnd_toStartOf="@+id/act070_ticket_cell_tv_action_shortcut"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@+id/act070_ticket_cell_tv_ticket_status_icon"
                app:layout_constraintTop_toTopOf="@+id/act070_ticket_cell_tv_ticket_status_icon" />

            <ImageView
                android:id="@+id/act070_ticket_cell_tv_action_shortcut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_outline_open_in_new_24"
                android:tint="@color/namoa_pipeline_background_icon"
                app:layout_constraintBottom_toBottomOf="@+id/act070_ticket_cell_tv_ticket_status_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/act070_ticket_cell_tv_desc_origin" />

        </android.support.constraint.ConstraintLayout>
    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>