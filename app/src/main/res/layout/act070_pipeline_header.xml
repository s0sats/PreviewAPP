<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardElevation="8dp"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginBottom="5dp"
    >

    <android.support.constraint.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <android.support.constraint.Guideline
            android:id="@+id/frg_ticket_guide_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_begin="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.Guideline
            android:id="@+id/frg_ticket_guide_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="8dp"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.ConstraintLayout
            android:id="@+id/frg_ticket_cl_ticket_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="@id/frg_ticket_guide_start"
            app:layout_constraintTop_toTopOf="parent">

<!--O layout comentado se refere a como ficará quando o botoa sync for habilitado             -->
<!--            <TextView-->
<!--                android:id="@+id/frg_ticket_tv_ticket_id"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:textSize="13sp"-->
<!--                android:textStyle="bold"-->
<!--                app:layout_constraintBottom_toBottomOf="parent"-->
<!--                app:layout_constraintStart_toStartOf="parent"-->
<!--                app:layout_constraintTop_toTopOf="parent"-->
<!--                tools:text="2019.999"-->
<!--                android:drawableEnd="@drawable/ic_sync_black_24dp"-->
<!--                android:gravity="center"-->
<!--                android:paddingTop="3dp"-->
<!--                android:paddingStart="8dp"-->
<!--                android:paddingEnd="8dp"-->
<!--                android:paddingBottom="3dp"-->
<!--                android:background="@drawable/border_blue"-->
<!--                android:drawablePadding="3dp"-->
<!--                />-->

            <TextView
                android:id="@+id/frg_ticket_tv_ticket_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="2019.999"
                android:gravity="center"
                />

            <TextView
                android:id="@+id/frg_ticket_tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/namoa_color_light_blue"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Pending"
                />
        </android.support.constraint.ConstraintLayout>

        <TextView
            android:id="@+id/frg_ticket_tv_client_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="@id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@id/frg_ticket_tv_site_desc"
            tools:text="Desc Client" />

        <TextView
            android:id="@+id/frg_ticket_tv_contract_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="@dimen/pipeline_smallest_font_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="@id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@id/frg_ticket_tv_client_name"
            tools:text="Desc Contract" />

        <TextView
            android:id="@+id/frg_ticket_tv_prod_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="@dimen/pipeline_smallest_font_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="@id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@id/frg_ticket_tv_contract_desc"
            tools:text="Desc Prod" />

        <TextView
            android:id="@+id/frg_ticket_tv_ticket_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:singleLine="true"
            android:textSize="@dimen/pipeline_smallest_font_size"
            app:layout_constraintEnd_toStartOf="@+id/frg_ticket_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/frg_ticket_cl_ticket_id"
            tools:text="31/02/2999 25:69:59"
            android:textColor="@color/namoa_color_gray_4"
            />

        <TextView
            android:id="@+id/frg_ticket_tv_site_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/namoa_color_danger_red"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/frg_ticket_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/frg_ticket_tv_ticket_date"
            tools:text="Site - trad" />

        <TextView
            android:id="@+id/frg_ticket_tv_serial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="@id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@id/frg_ticket_tv_prod_desc"
            tools:text="Serial ID" />

        <android.support.v7.widget.CardView
            android:id="@+id/cv_btn_sync"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:elevation="15dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@+id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="@+id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/frg_ticket_tv_serial"
            app:layout_constraintWidth_percent=".60">

            <LinearLayout
                android:id="@+id/frg_ticket_ll_btn_sync"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@color/namoa_sync_pipeline_background_btn"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:src="@drawable/ic_baseline_sync_24" />

                <TextView
                    android:id="@+id/frg_ticket_btn_sync_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    tools:text="FAVOR SINCRONIZAR" />

            </LinearLayout>
        </android.support.v7.widget.CardView>

        <android.support.constraint.ConstraintLayout
            android:id="@+id/frg_pipeline_header_ticket"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="@id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cv_btn_sync">

            <android.support.constraint.Guideline
                android:id="@+id/frg_pipeline_header_gd_origin_icon_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.15"  />

            <ImageView
                android:id="@+id/iv_ticket_header_icon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:src="@drawable/ic_baseline_error_outline_24dp_black"
                android:tint="@color/namoa_color_pipeline_origin_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="@id/frg_pipeline_header_gd_origin_icon_end"
                />

            <TextView
                android:id="@+id/frg_ticket_tv_desc_origin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:ellipsize="start"
                android:singleLine="true"
                app:layout_constraintBottom_toBottomOf="@+id/iv_ticket_header_icon"
                app:layout_constraintEnd_toStartOf="@+id/frg_ticket_iv_action_shortcut"
                app:layout_constraintStart_toStartOf="@+id/frg_pipeline_header_gd_origin_icon_end"
                app:layout_constraintTop_toTopOf="@+id/iv_ticket_header_icon"
                tools:text=".../lalalla/alallal" />

            <ImageView
                android:id="@+id/frg_ticket_iv_action_shortcut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_outline_open_in_new_24"
                android:tint="@color/namoa_pipeline_background_icon"
                app:layout_constraintBottom_toBottomOf="@+id/frg_ticket_tv_desc_origin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/frg_ticket_tv_desc_origin" />


        </android.support.constraint.ConstraintLayout>
<!--        Step-->
        <android.support.constraint.ConstraintLayout
            android:id="@+id/frg_pipeline_cl_step_ticket"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="@+id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/frg_pipeline_header_ticket"
            app:layout_constraintHorizontal_bias="0.0"
            android:layout_marginBottom="@dimen/pipeline_step_info_margin_top"
            >

            <android.support.constraint.Guideline
                android:id="@+id/frg_pipeline_header_gd_step_icon_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.15" />

            <TextView
                android:id="@+id/frg_pipeline_tv_step_main_step_num"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/step_status"
                android:gravity="center"
                android:textColor="@android:color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/frg_pipeline_header_gd_step_icon_end"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                tools:text="1" />

            <TextView
                android:id="@+id/frg_pipeline_tv_step_main_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/frg_pipeline_tv_step_main_step_num"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/frg_pipeline_header_gd_step_icon_end"
                app:layout_constraintTop_toTopOf="@+id/frg_pipeline_tv_step_main_step_num"
                tools:text="1 -Planejamento" />
        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.ConstraintLayout
            android:id="@+id/frg_ticket_cl_schedule"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@id/frg_pipeline_cl_step_ticket">

            <TextView
                android:id="@+id/frg_ticket_tv_schedule_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="DEscrição do agendamento" />

            <TextView
                android:id="@+id/frg_ticket_tv_schedule_comment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
                android:layout_marginEnd="8dp"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/frg_ticket_tv_schedule_desc"
                tools:text="Comentario do agendamento" />

            <ImageView
                android:id="@+id/frg_ticket_iv_schedule_date"
                android:layout_width="@dimen/pipeline_step_icon_width"
                android:layout_height="@dimen/pipeline_step_icon_height"
                android:tint="@color/namoa_color_gray_4"
                app:layout_constraintBottom_toBottomOf="@+id/frg_ticket_tv_schedule_date"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/frg_ticket_tv_schedule_date"
                app:srcCompat="@drawable/ic_baseline_date_range_24" />


            <TextView
                android:id="@+id/frg_ticket_tv_schedule_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="@dimen/pipeline_step_info_margin_top"
                android:textColor="@color/namoa_color_gray_4"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/frg_ticket_iv_schedule_date"
                app:layout_constraintTop_toBottomOf="@id/frg_ticket_tv_schedule_comment"
                tools:text="13/08/2020 14:58:05" />
        </android.support.constraint.ConstraintLayout>

        <include
            android:id="@+id/frg_pipeline_origin_header"
            layout="@layout/pipeline_origin_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/frg_ticket_guide_end"
            app:layout_constraintStart_toStartOf="@+id/frg_ticket_guide_start"
            app:layout_constraintTop_toBottomOf="@id/frg_ticket_cl_schedule" />

        <android.support.constraint.Group
            android:id="@+id/frg_ticket_gp_ticket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="frg_pipeline_header_ticket"
            android:visibility="visible"
            />
        <android.support.constraint.Group
            android:id="@+id/frg_ticket_gp_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="frg_pipeline_cl_step_ticket"
            android:visibility="visible"
            />
        <android.support.constraint.Group
            android:id="@+id/frg_ticket_gp_schedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="frg_ticket_cl_schedule"
            android:visibility="visible"
            />

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>