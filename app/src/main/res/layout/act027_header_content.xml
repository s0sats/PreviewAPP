<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="10dp"
                android:paddingRight="10dp"
                android:paddingTop="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="10dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:padding="5dp"

                        android:src="@drawable/ic_produto" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:orientation="vertical"
                    android:paddingBottom="10dp"
                    android:paddingLeft="0dp"
                    android:paddingRight="10dp"
                    android:paddingTop="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="5dp">

                        <TextView
                            android:id="@+id/act027_header_content_tv_product_code_lbl"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="left"
                            android:padding="2dp"
                            android:text="Code"
                            android:textSize="@dimen/font_size_item_md"

                            />

                        <View
                            android:layout_width="5dp"
                            android:layout_height="match_parent" />

                        <TextView
                            android:id="@+id/act027_header_content_tv_product_id_lbl"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="right"
                            android:padding="2dp"
                            android:text="Id"
                            android:textSize="@dimen/font_size_item_md" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/act027_header_content_tv_product_desc_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="2dp"
                        android:paddingLeft="5dp"
                        android:paddingRight="2dp"
                        android:paddingTop="2dp"
                        android:text="Product Description"
                        android:textSize="@dimen/font_size_title_md" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/act027_header_content_tv_prefix_code_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="10dp"
                android:text="Prefix / Code"
                android:textSize="@dimen/font_size_title_lib" />

            <TextView
                android:id="@+id/act027_header_content_tv_prefix_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/namoa_bg_1"
                android:padding="10dp"
                android:text="2017 / 30"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act027_header_content_tv_serial_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingLeft="10dp"
                android:text="Serial Data"
                android:textSize="@dimen/font_size_title_lib" />

            <TextView
                android:id="@+id/act027_header_content_tv_serial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/namoa_bg_1"
                android:padding="10dp"
                android:text="2530"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act027_header_content_tv_deadline_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingLeft="10dp"
                android:text="DeadLine"
                android:textSize="@dimen/font_size_title_lib" />

            <TextView
                android:id="@+id/act027_header_content_tv_deadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/namoa_bg_1"
                android:padding="10dp"
                android:text="01/01/2017"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act027_header_content_tv_status_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingLeft="10dp"
                android:text="Status"
                android:textSize="@dimen/font_size_title_lib" />

            <TextView
                android:id="@+id/act027_header_content_tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/namoa_bg_1"
                android:padding="10dp"
                android:text="PENDING"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act027_header_content_tv_priority_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingLeft="10dp"
                android:text="Priority"
                android:textSize="@dimen/font_size_title_lib" />

            <TextView
                android:id="@+id/act027_header_content_tv_priority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/namoa_bg_1"
                android:padding="10dp"
                android:text="P001"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act027_header_content_tv_operation_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingLeft="10dp"
                android:text="Operation"
                android:textSize="@dimen/font_size_title_lib" />

            <TextView
                android:id="@+id/act027_header_content_tv_operation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/namoa_bg_1"
                android:padding="10dp"
                android:text="CHERY"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act027_header_content_tv_site_contract_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingLeft="10dp"
                android:text="Contract"
                android:textSize="@dimen/font_size_title_lib" />

            <TextView
                android:id="@+id/act027_header_content_tv_contract"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/namoa_bg_1"
                android:padding="10dp"
                android:text=" ?????? "
                android:textSize="@dimen/font_size_title_md" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>