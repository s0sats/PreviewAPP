<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act042.Act042_Main"
    tools:showIn="@layout/act042_main">

    <include
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        layout="@layout/top_search_os_layout" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="5dp">


        <ViewFlipper
            android:id="@+id/act042_vf_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ProgressBar
                android:id="@+id/act042_pb_list"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_margin="16dp"
                />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/act042_rv_sos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="10dp"
                android:layout_weight="1"
                android:divider="@color/padrao_TRANSPARENT"
                android:dividerHeight="4dp"
                android:padding="5dp" />

            <TextView
                android:id="@+id/act042_tv_emptylist"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:visibility="gone"
                android:textColor="@color/m3_namoa_onSurface" />

        </ViewFlipper>



    </LinearLayout>

    <include layout="@layout/footer_base" />

</LinearLayout>
