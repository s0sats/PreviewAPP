<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/act027_approval_content_ll_so_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/act027_product_list_content_tv_so_id_lbl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="left"
                        android:text="SO ID"
                        android:textStyle="bold" />

                </LinearLayout>

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/act027_product_list_content_tv_so_id_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:text="2017.1" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/act027_approval_content_tv_so_approval_type_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_weight="1"
                android:gravity="left"
                android:text="Aprovação Final"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act027_approval_content_tv_name_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Approval Name"
                android:textStyle="bold" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act027_approval_content_mk_name_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N.Hugo Android"
                android:textSize="@dimen/font_size_item_md"
                app:mBARCODE="false" />

            <TextView
                android:id="@+id/act027_approval_content_tv_name_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:enabled="false"
                android:padding="2dp"
                android:text="N.Hugo Android"
                android:textColor="@color/lib_custom_cell_font_color" />

            <LinearLayout
                android:id="@+id/act027_approval_content_ll_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_approval_content_tv_client_approval_user_nick_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="2dp"
                    android:text="Client Approval User Nick"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/act027_approval_content_tv_client_approval_user_nick_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:enabled="false"
                    android:padding="2dp"
                    android:text="Nick"
                    android:textColor="@color/lib_custom_cell_font_color" />

                <TextView
                    android:id="@+id/act027_approval_content_tv_client_approval_date_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="2dp"
                    android:text="Client Approval Date"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/act027_approval_content_tv_client_approval_date_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:enabled="false"
                    android:padding="2dp"
                    android:text="Date"
                    android:textColor="@color/lib_custom_cell_font_color" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>