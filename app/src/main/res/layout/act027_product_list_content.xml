<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:gravity="center"
        android:layout_marginBottom="5dp"
        android:clickable="false"
        android:focusable="false"
        >

        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
            android:id="@+id/act027_product_list_content_mket_product"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="text"
            app:mOCR="false"
            app:mNFC="false"
            app:mBARCODE="false"
            android:hint="Search Product"
            />

        <ImageView
            android:padding="0dp"
            android:id="@+id/act027_product_list_content_iv_new_event"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_adicionar_filled_states"
            android:layout_marginLeft="5dp"
            />

    </LinearLayout>

    <ListView
        android:id="@+id/act027_product_list_content_lv_events"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        />


</LinearLayout>