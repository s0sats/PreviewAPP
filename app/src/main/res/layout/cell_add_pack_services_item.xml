<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/cl_pack_services_cell"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <TextView
        android:id="@+id/tv_pack_services"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:textSize="16sp"
        android:textColor="@color/namoa_font_color_black222"
        app:layout_constraintBottom_toTopOf="@+id/tv_pack_services_comment"
        app:layout_constraintEnd_toStartOf="@+id/iv_pack_services_edit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="TextView(1x 200)" />

    <ImageView
        android:id="@+id/iv_pack_services_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_pack_services_comment"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_pack_services"
        app:srcCompat="@drawable/ic_edit_black_24dp"
        app:tint="@color/namoa_color_dark_blue" />

    <TextView
        android:id="@+id/tv_pack_services_comment"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:textSize="14sp"
        android:textColor="@color/namoa_color_gray_9"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/iv_pack_services_edit"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Tampa do motor" />


</androidx.constraintlayout.widget.ConstraintLayout>