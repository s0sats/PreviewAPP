<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/footer_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/m3_namoa_primary_light"
    android:padding="8dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_left_action"
        style="@style/NamoaTheme3.Button.Text"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_right_action"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        tools:text="Cancelar Viagem" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_right_action"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        style="@style/NamoaTheme3.Button.Text"
        tools:text="Começar Viagem"
        android:visibility="visible"
        android:enabled="false"
        app:iconTint="@drawable/button_theme_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/btn_left_action"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_filled_right_action"
        style="@style/NamoaTheme3.Button"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@+id/btn_left_action"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        tools:text="Chegada ao destino" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_outlined_right_action"
        style="@style/NamoaTheme3.Button.Outlined"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@+id/btn_left_action"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        tools:text="Chegada ao destino" />

</androidx.constraintlayout.widget.ConstraintLayout>