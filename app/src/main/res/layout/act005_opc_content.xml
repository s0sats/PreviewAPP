<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:background="@color/padrao_WHITE"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <ImageView
        android:id="@+id/act005_opc_iv_logo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        android:layout_weight="1"
        android:background="@color/padrao_WHITE"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/logo_namoa_oficial" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/namoa_color_light_blue3"/>

    <ListView
        android:id="@+id/act005_opc_lv_opt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:divider="@color/namoa_color_light_blue3"
        android:dividerHeight="1dp">

    </ListView>

    <LinearLayout
        android:id="@+id/act005_opc_ll_footer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="bottom"
        android:clickable="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="15dp"
            android:background="@drawable/btn_namoa_main_states"
            android:orientation="horizontal"
            android:clickable="true"
            android:id="@+id/act005_opc_ll_sync"
            >

            <ImageView
                android:id="@+id/act005_opc_iv_sync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_sync_black_24dp"
                android:tint="@color/padrao_WHITE" />

            <TextView
                android:id="@+id/act005_opc_tv_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="15dp"
                android:text="Sync"
                android:textColor="@color/padrao_WHITE"
                android:textSize="@dimen/font_size_title_md" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="15dp"
            android:background="@drawable/btn_namoa_main_states"
            android:orientation="horizontal"
            android:clickable="true"
            android:id="@+id/act005_opc_ll_logout"
            >

            <ImageView
                android:id="@+id/act005_opc_iv_logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE" />

            <TextView
                android:id="@+id/act005_opc_tv_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="15dp"
                android:text="Log me out"
                android:textColor="@color/padrao_WHITE"
                android:textSize="@dimen/font_size_title_md" />

        </LinearLayout>

    </LinearLayout>
</LinearLayout>

