<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:gravity="center_vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act071.Act071_Main"
    tools:showIn="@layout/act071_main">

    <FrameLayout
        android:id="@+id/act071_frg_pipeline_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_default="wrap"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <ScrollView
        android:id="@+id/act071_sv_main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/act071_frg_pipeline_header">

        <android.support.constraint.ConstraintLayout
            android:id="@+id/act071_cl_main"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent">

            <android.support.constraint.Guideline
                android:id="@+id/act071_guide_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintGuide_begin="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <android.support.constraint.Guideline
                android:id="@+id/act071_guide_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintGuide_end="8dp"
                app:layout_constraintTop_toTopOf="parent" />

            <android.support.constraint.ConstraintLayout
                android:id="@+id/act071_cl_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:padding="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/act071_guide_end"
                app:layout_constraintHeight_percent="0.6"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="@id/act071_guide_start"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0">

                <TextView
                    android:id="@+id/act071_tv_photo_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    tools:text="Photo"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- A cor do icone é definida via code-->
                <ImageView
                    android:id="@+id/act071_iv_action_photo"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintWidth_percent="0.8"
                    app:layout_constraintHeight_percent="0.4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act071_tv_photo_lbl"
                    app:srcCompat="@drawable/ic_foto_ns_black"
                    />

                <TextView
                    android:id="@+id/act071_tv_done_info_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act071_cl_finalize"
                    tools:text="Done"
                    android:layout_marginTop="8dp"
                    />


                <TextView
                    android:id="@+id/act071_tv_done_info_val"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    tools:text="22/01/2019 19:36 (Luche)"
                    app:layout_constraintBottom_toBottomOf="@id/act071_tv_done_info_lbl"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toEndOf="@id/act071_tv_done_info_lbl"
                    app:layout_constraintTop_toTopOf="@id/act071_tv_done_info_lbl" />

                <android.support.constraint.Group
                    android:id="@+id/act071_gr_done"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="act071_tv_done_info_lbl,act071_tv_done_info_val"
                    tools:layout_editor_absoluteX="8dp"
                    tools:layout_editor_absoluteY="8dp"
                    tools:visibility="visible" />

                <android.support.constraint.ConstraintLayout
                    android:id="@+id/act071_cl_finalize"
                    android:layout_width="276dp"
                    android:layout_height="0dp"
                    android:minHeight="36dp"
                    android:background="@drawable/btn_namoa_main_states"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act071_til_comment"
                    app:layout_constraintHeight_default="spread"
                    android:layout_marginTop="8dp"
                    >

                    <ImageView
                        android:id="@+id/act071_iv_finalize_icon"
                        android:layout_width="@dimen/pipeline_step_icon_width"
                        android:layout_height="@dimen/pipeline_step_icon_height"
                        android:src="@drawable/ic_finalizar_white"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/act071_tv_finalize_lbl"
                        app:layout_constraintHorizontal_chainStyle="packed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_marginStart="8dp"
                        />

                    <TextView
                        android:id="@+id/act071_tv_finalize_lbl"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:text="FINALIZAR"
                        android:textColor="@color/padrao_WHITE"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toEndOf="@id/act071_iv_finalize_icon"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        app:layout_constraintWidth_default="wrap"
                        app:layout_constraintHeight_default="wrap"
                        />

                </android.support.constraint.ConstraintLayout>

                <TextView
                    android:id="@+id/act071_tv_comment_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Comment"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act071_iv_action_photo" />

                <android.support.design.widget.TextInputLayout
                    android:id="@+id/act071_til_comment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:counterEnabled="true"
                    app:counterMaxLength="500"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act071_tv_comment_lbl">

                    <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                        android:id="@+id/act071_mket_comment_val"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:inputType="textMultiLine"
                        android:maxLength="500"
                        app:mBARCODE="false"
                        app:mNFC="false"
                        app:mOCR="false"
                        app:mOCRVin="false"
                        tools:text="Comentario aqui" />
                </android.support.design.widget.TextInputLayout>


            </android.support.constraint.ConstraintLayout>

        </android.support.constraint.ConstraintLayout>

    </ScrollView>

    <include
        android:id="@+id/include"
        layout="@layout/footer_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/act071_sv_main" />
</android.support.constraint.ConstraintLayout>