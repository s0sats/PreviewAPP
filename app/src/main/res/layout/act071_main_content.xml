<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:gravity="center_vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act071.Act071_Main"
    tools:showIn="@layout/act071_main">

    <ScrollView
        android:id="@+id/act071_sv_main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <android.support.constraint.ConstraintLayout
            android:id="@+id/act071_cl_main"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent">

            <android.support.constraint.Guideline
                android:id="@+id/act071_guide_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintGuide_begin="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <android.support.constraint.Guideline
                android:id="@+id/act071_guide_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintGuide_end="8dp"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/act071_tv_ticket_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:textSize="@dimen/font_size_item_md"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/act071_tv_status"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@id/act071_guide_start"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="2019.999" />

            <TextView
                android:id="@+id/act071_tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textSize="@dimen/font_size_title"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/act071_guide_end"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Pending" />

            <TextView
                android:id="@+id/act071_tv_type_path"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="@dimen/font_size_item"
                app:layout_constraintEnd_toStartOf="@id/act071_guide_end"
                app:layout_constraintStart_toStartOf="@id/act071_guide_start"
                app:layout_constraintTop_toBottomOf="@id/act071_tv_ticket_id"
                tools:text="LIMPEZA\Banheiro Feminino" />

            <TextView
                android:id="@+id/act071_tv_type_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/font_size_item_md"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/act071_guide_end"
                app:layout_constraintStart_toStartOf="@id/act071_guide_start"
                app:layout_constraintTop_toBottomOf="@id/act071_tv_type_path"
                tools:text="Vaso" />

            <android.support.constraint.ConstraintLayout
                android:id="@+id/act071_cl_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/namoa_color_gray"
                android:padding="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/act071_guide_end"
                app:layout_constraintHeight_percent="0.6"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="@id/act071_guide_start"
                app:layout_constraintTop_toBottomOf="@id/act071_tv_type_desc"
                app:layout_constraintVertical_bias="0.0">

                <TextView
                    android:id="@+id/act071_tv_photo_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Photo"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/act071_mket_partner" />

                <TextView
                    android:id="@+id/act071_tv_seq"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    tools:text="1"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/act071_iv_exec"
                    app:layout_constraintEnd_toStartOf="@+id/act071_iv_exec"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/act071_iv_exec" />


                <ImageView
                    android:id="@+id/act071_iv_action_photo"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintWidth_percent="0.8"
                    app:layout_constraintHeight_percent="0.4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/act071_tv_photo_lbl"
                    app:srcCompat="@android:drawable/ic_menu_camera" />

                <TextView
                    android:id="@+id/act071_tv_done_info_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Done"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act071_mket_comment_val" />


                <TextView
                    android:id="@+id/act071_tv_done_info_val"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    tools:text="22/01/2019 19:36 (Luche)"
                    app:layout_constraintBottom_toBottomOf="@+id/act071_tv_done_info_lbl"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toEndOf="@id/act071_tv_done_info_lbl"
                    app:layout_constraintTop_toTopOf="@id/act071_tv_done_info_lbl" />

                <android.support.constraint.Group
                    android:id="@+id/act071_gr_done"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="act071_tv_done_info_lbl,act071_tv_done_info_val"
                    tools:layout_editor_absoluteX="8dp"
                    tools:layout_editor_absoluteY="8dp"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/act071_iv_exec"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_ok_ns_states" />

                <TextView
                    android:id="@+id/act071_tv_partner_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    tools:text="Partner"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/act071_iv_exec" />

                <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                    android:id="@+id/act071_mket_partner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Parceiro não é companheiro"
                    android:inputType="text"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/act071_tv_partner_lbl"
                    app:mBARCODE="false"
                    app:mNFC="false"
                    app:mOCR="false"
                    app:mOCRVin="false" />

                <TextView
                    android:id="@+id/act071_tv_comment_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Comment"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/act071_iv_action_photo" />

                <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                    android:id="@+id/act071_mket_comment_val"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Comentario aqui"
                    android:inputType="text"
                    app:mBARCODE="false"
                    app:mNFC="false"
                    app:mOCR="false"
                    app:mOCRVin="false"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/act071_tv_comment_lbl" />
            </android.support.constraint.ConstraintLayout>

        </android.support.constraint.ConstraintLayout>

    </ScrollView>

    <include
        android:id="@+id/include"
        layout="@layout/footer_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/act071_sv_main" />
</android.support.constraint.ConstraintLayout>