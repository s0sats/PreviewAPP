<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.act085.Act085WorkgroupRemoveListFrg">

   <androidx.constraintlayout.widget.ConstraintLayout
       android:layout_width="match_parent"
       android:layout_height="match_parent">

       <TextView
           android:id="@+id/act085_workgroup_remove_list_frg_tv_usr_name"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_marginTop="8dp"
           android:text="Daniel Luche"
           android:textSize="@dimen/font_size_title_md"
           android:textStyle="bold"
           app:layout_constraintEnd_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_end"
           app:layout_constraintStart_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_start"
           app:layout_constraintTop_toTopOf="parent" />

       <TextView
           android:id="@+id/act085_workgroup_remove_list_frg_tv_usr_nick"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_marginTop="4dp"
           android:text="luche(52)"
           android:textSize="@dimen/font_size_font_12"
           app:layout_constraintEnd_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_end"
           app:layout_constraintStart_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_start"
           app:layout_constraintTop_toBottomOf="@+id/act085_workgroup_remove_list_frg_tv_usr_name" />

       <TextView
           android:id="@+id/act085_workgroup_remove_list_frg_tv_list_ttl"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_marginTop="8dp"
           android:text="Vinculado aos Grupos de Trbalho:"
           android:textStyle="bold"
           app:layout_constraintEnd_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_end"
           app:layout_constraintHorizontal_bias="0.0"
           app:layout_constraintStart_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_start"
           app:layout_constraintTop_toBottomOf="@+id/act085_workgroup_remove_list_frg_tv_usr_nick"
           android:visibility="gone"
           />

       <androidx.constraintlayout.widget.Guideline
           android:id="@+id/act085_workgroup_remove_list_frg_gd_start"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:orientation="vertical"
           app:layout_constraintGuide_begin="8dp" />

       <androidx.constraintlayout.widget.Guideline
           android:id="@+id/act085_workgroup_remove_list_frg_gd_end"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:orientation="vertical"
           app:layout_constraintEnd_toEndOf="parent"
           app:layout_constraintGuide_end="8dp" />

       <Button
           android:id="@+id/act085_workgroup_remove_list_frg_btn_add_in_wg"
           android:layout_width="0dp"
           android:layout_height="wrap_content"
           android:layout_marginBottom="8dp"
           android:text="Incluir usr em wg"
           app:layout_constraintBottom_toBottomOf="parent"
           app:layout_constraintEnd_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_end"
           app:layout_constraintStart_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_start"
           android:background="@drawable/namoa_cell_11_states"
           android:textColor="@color/padrao_WHITE"
           />

       <androidx.recyclerview.widget.RecyclerView
           android:id="@+id/act085_workgroup_remove_list_frg_rv_wg"
           android:layout_width="0dp"
           android:layout_height="0dp"
           app:layout_constraintWidth_default="spread"
           app:layout_constraintHeight_default="wrap"
           app:layout_constraintVertical_bias="0"
           android:layout_marginBottom="4dp"
           android:layout_marginTop="8dp"
           app:layout_constraintBottom_toTopOf="@+id/act085_workgroup_remove_list_frg_btn_add_in_wg"
           app:layout_constraintEnd_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_end"
           app:layout_constraintStart_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_start"
           app:layout_constraintTop_toBottomOf="@+id/act085_workgroup_remove_list_frg_tv_list_ttl"
           tools:itemCount="6"
           tools:listitem="@layout/act085_workgroup_remove_list_frg_cell"
           android:scrollbars="vertical"
           android:scrollbarAlwaysDrawVerticalTrack="true"
           android:fadeScrollbars="false"
           />

       <TextView
           android:id="@+id/act085_workgroup_remove_list_tv_empty_list"
           android:layout_width="0dp"
           android:layout_height="wrap_content"
           app:layout_constraintEnd_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_end"
           app:layout_constraintStart_toStartOf="@+id/act085_workgroup_remove_list_frg_gd_start"
           app:layout_constraintTop_toBottomOf="@+id/act085_workgroup_remove_list_frg_tv_list_ttl"
           android:gravity="center"
           android:layout_marginTop="32dp"
           tools:text="Lista Vazia"
           android:visibility="gone"
           android:textStyle="bold"
           android:textSize="@dimen/font_size_font_16"
           />
   </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>