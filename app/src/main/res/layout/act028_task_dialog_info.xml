<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act028_dialog_info_tv_so_lbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:padding="2dp"
                    android:text="O.S"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/act028_dialog_info_tv_so_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:padding="2dp"
                    android:text="2017-xxx"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/act028_dialog_info_tv_service_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="left"
                android:padding="2dp"
                android:text="Service"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act028_dialog_info_tv_service_val"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:padding="2dp"
                android:textColor="@color/lib_custom_cell_font_color"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act028_dialog_info_tv_product_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="2dp"
                android:text="Product"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act028_dialog_info_tv_product_val"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:padding="2dp"
                android:textColor="@color/lib_custom_cell_font_color"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act028_dialog_info_tv_serial_id_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="2dp"
                android:text="Serial"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act028_dialog_info_tv_serial_id_val"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:padding="2dp"
                android:text="uhauh"
                android:textColor="@color/lib_custom_cell_font_color"
                android:textSize="@dimen/font_size_title_md" />

            <TextView
                android:id="@+id/act028_dialog_info_tv_tracking_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="2dp"
                android:text="Tracking"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act028_dialog_info_tv_tracking_val"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:padding="2dp"
                android:textColor="@color/lib_custom_cell_font_color"
                android:textSize="@dimen/font_size_title_md" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>