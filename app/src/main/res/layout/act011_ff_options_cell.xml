<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/act011_ff_options_cell_ll_a_b"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/act011_ff_options_cell_ll_a"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="15dp">


        <TextView
            android:id="@+id/act011_ff_options_cell_tv_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1." />

        <TextView
            android:id="@+id/act011_ff_options_cell_tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingLeft="16dp"
            android:text="About"
            android:textSize="14sp"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/act011_ff_options_cell_tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0" />

    </LinearLayout>

</LinearLayout>