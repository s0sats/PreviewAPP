<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp">

        <View
            android:id="@+id/act035_main_content_cell_ticket_v_space_left"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/act035_main_content_cell_ticket_iv_other_img"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginRight="-6dp"
            android:background="@drawable/ic_play"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="18"
            android:background="@drawable/bg_msg_me"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/act035_main_content_cell_ticket_tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#f1194f"
                android:textSize="14sp"
                android:textStyle="bold"
                android:typeface="normal"
                tools:text="N.Hugo" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_ttl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="2dp"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Ticket - trad" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_id_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:textStyle="bold"
                    tools:text="2019.666" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_id_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    tools:text="Ticket.ID:"
                    android:textStyle="bold" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_path_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    android:textStyle="bold"
                    tools:text="Hieraquia:" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_path_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:textStyle="bold"
                    tools:text="LIMPEZA/Copa/" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    android:textStyle="bold"
                    tools:text="Tipo:"

                    android:visibility="gone"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_type_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    tools:text="Falta Copo Plástico"
                    android:textStyle="bold"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_comment_lbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:textStyle="bold"
                    tools:text="Open Comments:"
                    android:visibility="gone"/>

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_user_msg_on"
                    android:tint="@color/namoa_dark_blue"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="2dp"
                    />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_comment_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:maxLines="3"
                    android:paddingStart="5dp"
                    tools:text="Comnetario usado na abertura para que  ajudar  a identificar o problemas " />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_serial_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    android:textStyle="bold"
                    tools:text="Serial:"  android:visibility="gone"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    />

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_serial_24x24"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="2dp"
                    />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_serial_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:layout_gravity="center_vertical"
                    android:paddingStart="5dp"
                    tools:text="btt123" />

                <ImageButton
                    android:id="@+id/act035_main_content_cell_namoa_ticket_iv_download"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/btn_namoa_main_states"
                    android:padding="5dp"
                    android:src="@drawable/ic_file_download_black_24dp"
                    android:tint="@color/padrao_WHITE" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/act035_main_content_cell_namoa_ticket_ll_action_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="end"
                android:visibility="gone"
                >

                <Button
                    android:id="@+id/act035_main_content_cell_namoa_ticket_btn_download"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/btn_namoa_main_states"
                    android:focusable="false"
                    android:padding="10dp"
                    android:textColor="@color/padrao_WHITE"
                    android:visibility="gone"
                    tools:text="Download Ticket" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_msg_code_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    android:textColor="#9c9b9b"
                    android:textSize="12sp"
                    android:textStyle="normal"
                    android:typeface="normal"
                    android:visibility="gone"
                    tools:text="2048.666" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_hour_ttl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:textColor="#9c9b9b"
                    android:textSize="12sp"
                    android:textStyle="normal"
                    android:typeface="normal"
                    tools:text="11:30" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/act035_main_content_cell_ticket_iv_me_img"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginLeft="-6dp"
            android:background="@drawable/ic_play_2" />

        <View
            android:id="@+id/act035_main_content_cell_ticket_v_space_right"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
    </LinearLayout>

</LinearLayout>
