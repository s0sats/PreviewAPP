<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fab_with_badge_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/jump_mandatory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@null"
        android:src="@drawable/round_warning_24"
        android:backgroundTint="@color/m3_namoa_surface"
        app:backgroundTint="@color/m3_namoa_error_form_fields"
        app:tint="@color/m3_namoa_error_form_fields"
        app:borderWidth="2dp"
        app:maxImageSize="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/fab_badge_textview"
        style="@style/TextAppearance.Material3.BodySmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/badge_background"
        android:elevation="6dp"
        android:gravity="center"
        android:minWidth="22dp"
        android:minHeight="22dp"
        android:padding="3dp"
        android:text="0"
        android:textColor="@color/m3_namoa_surface"
        android:textStyle="bold"
        android:translationX="-10dp"
        android:translationY="10dp"
        app:layout_constraintBottom_toTopOf="@id/jump_mandatory"
        app:layout_constraintStart_toEndOf="@id/jump_mandatory" />

</androidx.constraintlayout.widget.ConstraintLayout>