                    <TextView
                        android:id="@+id/act047_cell_tv_brand_val"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/act047_cell_tv_model_val"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintHorizontal_chainStyle="packed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:maxEms="5"
                        tools:text="Marca" />

                    <TextView
                        android:id="@+id/act047_cell_tv_model_val"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/act047_cell_tv_color_val"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toEndOf="@+id/act047_cell_tv_brand_val"
                        app:layout_constraintTop_toTopOf="parent"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:maxEms="5"
                        tools:text="Modelo" />

                    <TextView
                        android:id="@+id/act047_cell_tv_color_val"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="213dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:maxLines="1"
                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toEndOf="@+id/act047_cell_tv_model_val"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Cor" />

                    <!--                <TextView
                                        android:id="@+id/my_actions_item_tv_action_process"
                                        style="@style/TextAppearance.Material3.BodySmall"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Modelo"
                                        android:textColor="@color/m3_namoa_onSurface" />

                                    <TextView
                                        android:id="@+id/my_actions_item_tv_action_processs"
                                        style="@style/TextAppearance.Material3.BodySmall"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Cor"
                                        android:textColor="@color/m3_namoa_onSurface" />-->

                </androidx.constraintlayout.widget.ConstraintLayout>


                <TextView
                    android:id="@+id/act047_cell_tv_tracking_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    android:visibility="gone"
                    tools:text="LISTA | TRACKINGS " />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />

                <TextView
                    android:id="@+id/act047_cell_tv_so_id_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    android:visibility="gone"
                    tools:text="MY-OS.XXX" />


                <TextView
                    android:id="@+id/act047_cell_tv_client_so_id_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    android:visibility="gone"
                    tools:text="CLIENT S.O ID XX.XX" />

                <TextView
                    android:id="@+id/act047_cell_tv_segment_category_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    android:visibility="gone"
                    tools:text="Usados | Carro pequeno" />

                <TextView
                    android:id="@+id/act047_cell_tv_pipeline_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    android:visibility="gone"
                    tools:text="JGA" />

                <!--                <TextView
                                    android:id="@+id/act047_cell_tv_pipeline_val"
                                    style="@style/TextAppearance.Material3.BodySmall"
