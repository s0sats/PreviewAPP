                                    android:layout_height="wrap_content"
                                    android:text="Criada em 14/06/23"
                                    android:layout_gravity="end"
                                    android:textAlignment="textEnd"
                                    android:visibility="visible"
                                    android:textColor="@color/m3_namoa_onSurfaceVariant" />-->

            </LinearLayout>

            <View
