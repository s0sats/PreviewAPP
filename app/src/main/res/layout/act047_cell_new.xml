    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/act047_cell_tv_prefix_code"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:paddingVertical="2dp"
            android:paddingEnd="5dp"
            tools:text="2022.1234"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/act047_cell_tv_status_val"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/act047_cell_tv_status_val"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="end"
            android:paddingVertical="2dp"
            android:paddingEnd="10dp"
            tools:text="In Editing"
            android:textAlignment="textEnd"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/namoa_cell_8_states"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="16dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/schedule_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="null"
                    android:src="@drawable/baseline_schedule_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/m3_namoa_onSurfaceVariant" />


                <LinearLayout
                    android:id="@+id/deadline_layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/schedule_icon"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/act047_cell_tv_deadline_val"
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:paddingStart="8dp"
                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                        tools:text="01/11/2022 22:00" />

                    <!--
                    <TextView
                        android:id="@+id/my_actions_item_tv_done_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:paddingBottom="2dp"
                        android:text="01/11/2022 22:00 - 02/11/2022 06:00"
                        style="@style/TextAppearance.Material3.TitleSmall"
                        android:textColor="@color/m3_namoa_extended_verdeDone_seed" />
-->

                    <!--                    <TextView
                        android:id="@+id/my_actions_item_tv_site"
                        style="@style/TextAppearance.Material3.BodyMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                        tools:text="Site | Zona" />-->

                </LinearLayout>

                <!--<ImageView
                    android:id="@+id/my_actions_item_iv_icon_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="null"
                    android:src="@drawable/ic_baseline_cloud_done_24"
                    app:layout_constraintEnd_toStartOf="@+id/my_actions_item_iv_icon_mid"
                    app:layout_constraintTop_toTopOf="parent" />-->


                <TextView
                    android:id="@+id/act047_cell_tv_priority_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Aguardando peça" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/serial_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="12dp">

                <LinearLayout
                    android:id="@+id/ll_serial_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="6dp">

                    <TextView
                        android:id="@+id/act047_cell_tv_serial_id"
                        style="@style/TextAppearance.Material3.TitleLarge"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_gravity="left|center"
                        android:text="SERIAL NAME"
                        android:textColor="@color/m3_namoa_onSurface" />

                    <!--                <TextView
                                        android:id="@+id/act047_cell_tv_product_val"
                                        style="@style/TextAppearance.Material3.BodySmall"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Produto desc"
                                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                                        android:paddingVertical="2dp" />

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:background="@color/m3_namoa_outlineVariant" />-->
                    <ImageView
                        android:id="@+id/act047_cell_iv_block"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="right|center"
                        android:src="@drawable/ic_block_helper_black_18dp"
                        />
                </LinearLayout>
            </LinearLayout>



            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_tag_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/my_actions_item_tv_tag_desc"
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:textAllCaps="true"
                    android:textColor="@color/m3_namoa_onSurface"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/my_actions_item_tv_class_status"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0"
                    tools:text="TAG NAME" />

                <TextView
                    android:id="@+id/my_actions_item_tv_class_status"
                    style="@style/TextAppearance.Material3.LabelLarge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textAlignment="textEnd"
                    android:textColor="@color/m3_namoa_error"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/my_actions_item_tv_tag_desc"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="CLASSE TICKET" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
