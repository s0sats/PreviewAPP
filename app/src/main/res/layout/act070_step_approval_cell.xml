<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/step_approval_v_line"
        android:layout_width="@dimen/pipeline_step_vertical_line_width"
        android:layout_height="0dp"
        android:background="@color/namoa_color_dark_blue"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/step_approval_gd_start"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <!--Image com dashed-->
    <ImageView
        android:id="@+id/step_approval_iv_line"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/step_dashed_vertical_line"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/step_approval_gd_start"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <android.support.constraint.Guideline
        android:id="@+id/step_approval_gd_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.15" />

    <android.support.constraint.ConstraintLayout
        android:id="@+id/step_approval_cl_background"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="@id/step_approval_gd_start"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <android.support.constraint.Guideline
            android:id="@+id/step_approval_gd_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="8dp" />

        <TextView
            android:id="@+id/step_approval_tv_question"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/step_approval_gd_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Trabalhos realizado conforme Norma X ?" />


        <ImageView
            android:id="@+id/step_approval_iv_end_date"
            android:layout_width="@dimen/pipeline_step_icon_width"
            android:layout_height="@dimen/pipeline_step_icon_width"
            android:src="@drawable/ic_check_white_24dp"
            android:tint="@color/namoa_color_gray_4"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@id/step_approval_tv_end_date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/step_approval_tv_end_date" />

        <TextView
            android:id="@+id/step_approval_tv_end_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            app:layout_constraintEnd_toStartOf="@id/step_approval_gd_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/step_approval_iv_end_date"
            app:layout_constraintTop_toBottomOf="@+id/step_approval_tv_user"
            app:layout_constraintWidth_default="spread"
            tools:text="21/06/2020 18:00" />

        <ImageView
            android:id="@+id/step_approval_iv_user"
            android:layout_width="@dimen/pipeline_step_icon_width"
            android:layout_height="@dimen/pipeline_step_icon_width"
            android:src="@drawable/ic_person_black_24dp"
            android:tint="@color/namoa_color_gray_4"
            app:layout_constraintBottom_toBottomOf="@id/step_approval_tv_user"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/step_approval_tv_user"
            android:layout_marginStart="8dp"
            />

        <TextView
            android:id="@+id/step_approval_tv_user"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            app:layout_constraintEnd_toStartOf="@id/step_approval_gd_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/step_approval_iv_user"
            app:layout_constraintTop_toBottomOf="@+id/step_approval_tv_partner"
            app:layout_constraintWidth_default="spread"
            tools:text="luche" />

        <View
            android:id="@+id/step_approval_v_divider"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            android:background="@color/namoa_color_gray3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/step_approval_tv_process_action" />

        <TextView
            android:id="@+id/step_approval_tv_partner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            app:layout_constraintEnd_toStartOf="@id/step_approval_gd_end"
            app:layout_constraintStart_toEndOf="@+id/step_approval_iv_partner"
            app:layout_constraintTop_toBottomOf="@+id/step_approval_tv_comments"
            tools:text="Partner" />

        <TextView
            android:id="@+id/step_approval_tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            android:textAllCaps="true"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/step_approval_gd_end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/step_approval_tv_question"
            tools:text="REJEITADO"
            android:textColor="@color/namoa_color_success_green"
            />

        <TextView
            android:id="@+id/step_approval_tv_comments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            app:layout_constraintEnd_toStartOf="@id/step_approval_gd_end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/step_approval_tv_status"
            tools:text="Rejeitado pois a norma não foi seguida no item 2 nem no item 3, també não foi seguida a norma no item 4 " />

        <ImageView
            android:id="@+id/step_approval_iv_partner"
            android:layout_width="@dimen/pipeline_step_icon_width"
            android:layout_height="@dimen/pipeline_step_icon_width"
            app:layout_constraintBottom_toBottomOf="@+id/step_approval_tv_partner"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@+id/step_approval_tv_partner"
            app:srcCompat="@drawable/ic_baseline_business_24_black"
            android:tint="@color/namoa_color_gray_4"
            />

        <TextView
            android:id="@+id/step_approval_tv_process_action"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            android:textAllCaps="true"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/step_approval_gd_end"
            app:layout_constraintStart_toEndOf="@+id/step_approval_iv_process_action"
            app:layout_constraintTop_toBottomOf="@+id/step_approval_tv_end_date"
            android:text="iniciar processo" />

        <ImageView
            android:id="@+id/step_approval_iv_process_action"
            android:layout_width="@dimen/pipeline_step_icon_width"
            android:layout_height="@dimen/pipeline_step_icon_height"
            android:layout_marginStart="8dp"
            android:layout_marginTop="3dp"
            android:tint="@color/namoa_color_gray_4"
            app:layout_constraintBottom_toBottomOf="@+id/step_approval_tv_process_action"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/step_approval_tv_process_action"
            android:src="@drawable/ic_skip_next_white_24px" />

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout
        android:id="@+id/step_approval_cl_rejection_background"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/step_approval_gd_start"
        app:layout_constraintTop_toBottomOf="@id/step_approval_cl_background"

        android:background="@drawable/pipeline_step_states">

        <TextView
            android:id="@+id/step_approval_tv_rejection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            android:text="REJEITADOS"
            android:textAllCaps="true"
            android:textColor="@color/namoa_color_danger_red"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@+id/step_approval_iv_rejection"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/step_approval_iv_rejection"
            android:layout_width="@dimen/pipeline_step_icon_width"
            android:layout_height="@dimen/pipeline_step_icon_width"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_exclamation"
            android:tint="@color/namoa_color_danger_red"
            app:layout_constraintBottom_toBottomOf="@+id/step_approval_tv_rejection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/step_approval_tv_rejection"
            />

        <View
            android:id="@+id/step_approval_v_rejection_divider"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            android:background="@color/namoa_color_gray3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/step_approval_tv_rejection" />

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>