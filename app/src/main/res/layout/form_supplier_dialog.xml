<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/popup_window_default"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginHorizontal="8dp"
        >

        <TextView
            android:id="@+id/tv_horimeter_label"
            style="@style/TelemetryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:visibility="gone"
            android:text="Label:"/>

        <TextView
            android:id="@+id/tv_horimeter_value"
            style="@style/TelemetryBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:text="Value" />

        <TextView
            android:id="@+id/tv_horimeter_supplier_desc_label"
            style="@style/TelemetrySupplierTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="Label:"/>

        <TextView
            android:id="@+id/tv_horimeter_supplier_desc_value"
            style="@style/TelemetrySupplierBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:layout_marginBottom="8dp"
            android:text="Value"/>
    </LinearLayout>

</FrameLayout>