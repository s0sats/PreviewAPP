<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/act011_ff_sv_main"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

            <include
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                layout="@layout/cv_product_serial_with_icon"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:orientation="vertical">


                <TextView
                        android:id="@+id/act011_ff_tv_schedule_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Titulo do Comentário"
                        android:textColor="@color/namoa_color_blue_dark_chat"
                        android:textSize="@dimen/font_size_title"
                        android:textStyle="bold"/>

                <TextView
                        android:id="@+id/act011_ff_tv_comments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sem Valor"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/act011_ff_ll_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <LinearLayout
                        android:id="@+id/act011_ff_ll_pre"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_margin="10dp"
                        android:background="@drawable/namoa_cell_2_states"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                    <ImageView
                            android:id="@+id/act011_ff_iv_pre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:src="@drawable/ic_skip_previous_white_24px"/>

                </LinearLayout>

                <LinearLayout
                        android:id="@+id/act011_ff_ll_drawer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/namoa_cell_2_states"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                    <ImageView
                            android:id="@+id/act011_ff_iv_drawer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:src="@drawable/ic_menu_hamburger"/>

                    <TextView
                            android:id="@+id/act011_ff_tv_drawer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:focusable="false"
                            android:text="Open Drawer - Trad"
                            android:textColor="#FFFFFFFF"/>

                </LinearLayout>

                <LinearLayout
                        android:id="@+id/act011_ff_ll_nex"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_margin="10dp"
                        android:background="@drawable/namoa_cell_2_states"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                    <ImageView
                            android:id="@+id/act011_ff_iv_nex"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:src="@drawable/ic_skip_next_white_24px"/>

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                    android:id="@+id/act011_ff_ll_footer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                <!--<LinearLayout-->
                <!--android:id="@+id/act011_ff_ll_drawer"-->
                <!--android:layout_width="match_parent"-->
                <!--android:layout_height="match_parent"-->
                <!--android:layout_margin="10dp"-->
                <!--android:background="@drawable/namoa_cell_2_states"-->
                <!--android:gravity="center_vertical"-->
                <!--android:orientation="horizontal"-->
                <!--android:padding="20dp">-->

                <!--<ImageView-->
                <!--android:id="@+id/act011_ff_iv_drawer"-->
                <!--android:layout_width="wrap_content"-->
                <!--android:layout_height="wrap_content"-->
                <!--android:focusable="false"-->
                <!--android:src="@drawable/ic_menu_hamburger" />-->

                <!--<TextView-->
                <!--android:id="@+id/act011_ff_tv_drawer"-->
                <!--android:layout_width="wrap_content"-->
                <!--android:layout_height="wrap_content"-->
                <!--android:layout_marginLeft="10dp"-->
                <!--android:focusable="false"-->
                <!--android:text="Open Drawer - Trad"-->
                <!--android:textColor="#FFFFFFFF" />-->

                <!--</LinearLayout>-->


                <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    <LinearLayout
                            android:id="@+id/act011_ff_ll_check"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/namoa_cell_2_states"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            app:layout_constraintHorizontal_bias="0.5"
                            app:layout_constraintBottom_toBottomOf="@+id/act011_ff_tv_check_new"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/act011_ff_tv_check_new"
                            app:layout_constraintTop_toTopOf="@+id/act011_ff_tv_check_new"
                    >


                        <ImageView
                                android:id="@+id/act011_ff_iv_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:src="@drawable/ic_finalizar_white"/>

                        <TextView
                                android:id="@+id/act011_ff_tv_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:focusable="false"
                                android:text="Check- Trad"
                                android:textColor="#FFFFFFFF"/>

                    </LinearLayout>

                    <TextView
                            android:id="@+id/act011_ff_tv_check_new"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/namoa_cell_3_states"
                            android:drawableStart="@drawable/ic_loop_white_24dp"
                            android:drawablePadding="10dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="5dp"
                            android:text="Finaliza + Novo - trad"
                            android:textColor="@color/namoa_color_white_alpha"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/act011_ff_ll_check"
                            app:layout_constraintHorizontal_bias="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"

                    />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!--<Button-->
                <!--android:id="@+id/act011_ff_btn_drawer"-->
                <!--android:layout_width="match_parent"-->
                <!--android:layout_height="wrap_content"-->
                <!--android:text="Drawer - Trad" />-->

                <!--<Button-->
                <!--android:id="@+id/act011_ff_btn_check"-->
                <!--android:layout_width="match_parent"-->
                <!--android:layout_height="wrap_content"-->
                <!--android:text="Check - Trad" />-->

            </LinearLayout>


        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/act011_go_to_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_namoa_main_states"
            tools:text="Cancel - Trad"
            android:textColor="@color/padrao_WHITE"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/gl_bottom_buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/act011_go_to_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_namoa_main_states"
            tools:text="Cancel - Trad"
            android:textColor="@color/padrao_WHITE"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/gl_bottom_buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </LinearLayout>
</LinearLayout>