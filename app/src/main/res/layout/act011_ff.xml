<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/act011_ff_ll_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/act011_ff_ll_pre"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_margin="10dp"
                    android:background="@drawable/namoa_cell_2_states"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/act011_ff_iv_pre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:src="@drawable/ic_skip_previous_white_24px" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/act011_ff_ll_drawer"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:layout_margin="10dp"
                    android:background="@drawable/namoa_cell_2_states"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/act011_ff_iv_drawer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:src="@drawable/ic_menu_hamburger" />

                    <TextView
                        android:id="@+id/act011_ff_tv_drawer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:focusable="false"
                        android:text="Open Drawer - Trad"
                        android:textColor="#FFFFFFFF" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/act011_ff_ll_nex"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_margin="10dp"
                    android:background="@drawable/namoa_cell_2_states"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/act011_ff_iv_nex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:src="@drawable/ic_skip_next_white_24px" />

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/act011_ff_ll_footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!--<LinearLayout-->
                    <!--android:id="@+id/act011_ff_ll_drawer"-->
                    <!--android:layout_width="match_parent"-->
                    <!--android:layout_height="match_parent"-->
                    <!--android:layout_margin="10dp"-->
                    <!--android:background="@drawable/namoa_cell_2_states"-->
                    <!--android:gravity="center_vertical"-->
                    <!--android:orientation="horizontal"-->
                    <!--android:padding="20dp">-->

                    <!--<ImageView-->
                        <!--android:id="@+id/act011_ff_iv_drawer"-->
                        <!--android:layout_width="wrap_content"-->
                        <!--android:layout_height="wrap_content"-->
                        <!--android:focusable="false"-->
                        <!--android:src="@drawable/ic_menu_hamburger" />-->

                    <!--<TextView-->
                        <!--android:id="@+id/act011_ff_tv_drawer"-->
                        <!--android:layout_width="wrap_content"-->
                        <!--android:layout_height="wrap_content"-->
                        <!--android:layout_marginLeft="10dp"-->
                        <!--android:focusable="false"-->
                        <!--android:text="Open Drawer - Trad"-->
                        <!--android:textColor="#FFFFFFFF" />-->

                <!--</LinearLayout>-->


                <LinearLayout
                    android:id="@+id/act011_ff_ll_check"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="10dp"
                    android:background="@drawable/namoa_cell_2_states"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/act011_ff_iv_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:src="@drawable/ic_finalizar_white" />

                    <TextView
                        android:id="@+id/act011_ff_tv_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:focusable="false"
                        android:text="Check - Trad"
                        android:textColor="#FFFFFFFF" />

                </LinearLayout>


                <!--<Button-->
                <!--android:id="@+id/act011_ff_btn_drawer"-->
                <!--android:layout_width="match_parent"-->
                <!--android:layout_height="wrap_content"-->
                <!--android:text="Drawer - Trad" />-->

                <!--<Button-->
                <!--android:id="@+id/act011_ff_btn_check"-->
                <!--android:layout_width="match_parent"-->
                <!--android:layout_height="wrap_content"-->
                <!--android:text="Check - Trad" />-->

            </LinearLayout>


        </LinearLayout>

    </ScrollView>

</LinearLayout>