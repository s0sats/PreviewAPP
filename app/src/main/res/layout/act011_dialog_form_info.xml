<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="15dp">

    <TextView
        android:id="@+id/act_011_dialog_tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Form Information"
        android:textSize="@dimen/font_size_title_md"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingRight="10dp"
        android:layout_weight="3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/act_011_dialog_tv_product_title_lbl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Product"
                android:textSize="@dimen/font_size_title"
                android:textStyle="bold"
                android:gravity="center_vertical"/>

            <TextView
                android:id="@+id/act_011_dialog_tv_product_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:layout_marginBottom="5dp"
                android:text="Product desc"
                android:textStyle="bold"
                android:textSize="@dimen/font_size_title"
                android:gravity="center_vertical"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/act_011_dialog_tv_product_code_lbl"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:text="Code:"
                    android:textColor="@color/namoa_color_light_blue"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold"

                    />

                <TextView
                    android:id="@+id/act_011_dialog_tv_product_code_val"
                    android:text="2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:gravity="start|center_vertical"
                    android:textColor="@color/namoa_color_light_blue"
                    android:textStyle="bold"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/act_011_dialog_tv_product_id_lbl"
                    android:text="ID--"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold"
                    android:textColor="@color/namoa_color_light_blue"/>

                <TextView
                    android:id="@+id/act_011_dialog_tv_product_id_val"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:gravity="start|center_vertical"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:text="2"
                    android:textColor="@color/namoa_color_light_blue"
                    android:textStyle="bold"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/act_011_dialog_tv_serial_code_lbl"
                    android:text="Serial:"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold"
                    android:textColor="@color/namoa_color_light_blue"/>

                <TextView
                    android:id="@+id/act_011_dialog_tv_serial_code_val"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:gravity="start|center_vertical"
                    android:text="2"
                    android:textColor="@color/namoa_color_light_blue"
                    android:textStyle="bold"/>

            </LinearLayout>

            <TextView
                android:id="@+id/act_011_dialog_tv_serial_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:padding="5dp"
                android:text=""
                android:textSize="@dimen/font_size_item"
                android:visibility="gone"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Form"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_code_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="4"
                    android:layout_marginBottom="5dp"
                    android:text="Form desc"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_code_lbl"
                    android:text="Form Code:"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold"
                    android:textColor="@color/namoa_color_light_blue"
                    />

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_code_val"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:gravity="start|center_vertical"
                    android:text="2"
                    android:textColor="@color/namoa_color_light_blue"
                    android:textStyle="bold"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_version_lbl"
                    android:text="Form Version:"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold"
                    android:textColor="@color/namoa_color_light_blue"/>

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_version_val"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:gravity="start|center_vertical"
                    android:text="2"
                    android:textColor="@color/namoa_color_light_blue"
                    android:textStyle="bold"
                    />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                >

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_type_lbl"
                    android:text="Form Type:"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="start|center_vertical"
                    android:textSize="@dimen/font_size_title"
                    android:textStyle="bold"
                    android:textColor="@color/namoa_color_light_blue"
                    />

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_type_val"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="2"
                    android:textColor="@color/namoa_color_light_blue"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/act_011_dialog_tv_form_type_desc"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:gravity="start|center_vertical"
                    android:text="2"
                    android:textColor="@color/namoa_color_light_blue"
                    android:textStyle="bold"
                    />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/act_011_dialog_ll_scheduel_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="10dp">

                    <TextView
                        android:id="@+id/act_011_dialog_tv_data_serv_lbl"
                        android:text="Seq.Exec::"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:textSize="@dimen/font_size_title"
                        android:textStyle="bold"
                        android:textColor="@color/namoa_color_light_blue"/>

                    <TextView
                        android:id="@+id/act_011_dialog_tv_data_serv_val"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="3"
                        android:paddingStart="15dp"
                        android:paddingEnd="15dp"
                        android:gravity="start|center_vertical"
                        android:text="2"
                        android:textColor="@color/namoa_color_light_blue"
                        android:textStyle="bold"
                        />

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="10dp">

                    <TextView
                        android:id="@+id/act_011_dialog_tv_schedule_dt_start_lbl"
                        android:text="Agendamento Ini:"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:textSize="@dimen/font_size_title"
                        android:textStyle="bold"
                        android:textColor="@color/namoa_color_light_blue"/>

                    <TextView
                        android:id="@+id/act_011_dialog_tv_schedule_dt_start_val"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="3"
                        android:paddingStart="15dp"
                        android:paddingEnd="15dp"
                        android:gravity="start|center_vertical"
                        android:text="2"
                        android:textColor="@color/namoa_color_light_blue"
                        android:textStyle="bold"
                        />

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="10dp">

                    <TextView
                        android:id="@+id/act_011_dialog_tv_schedule_dt_end_lbl"
                        android:text="Agendamento Ini:"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:textSize="@dimen/font_size_title"
                        android:textStyle="bold"
                        android:textColor="@color/namoa_color_light_blue"/>

                    <TextView
                        android:id="@+id/act_011_dialog_tv_schedule_dt_end_val"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="3"
                        android:paddingStart="15dp"
                        android:paddingEnd="15dp"
                        android:gravity="start|center_vertical"
                        android:text="2"
                        android:textColor="@color/namoa_color_light_blue"
                        android:textStyle="bold"
                        />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <TextView
        android:id="@+id/act_011_dialog_tv_title_pdf"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="PDFs"
        android:textSize="@dimen/font_size_title"
        android:textStyle="bold"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/act_011_dialog_lv_pdfs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingEnd="10dp"
        android:layout_weight="1.5"/>

</LinearLayout>