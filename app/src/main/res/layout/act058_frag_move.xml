<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.namoadigital.prj001.ui.act058.Frag_Move_Create">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <include
        android:id="@+id/act058_serial_layout"
        layout="@layout/act058_product_serial_info"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@color/fieldset_background">

            <android.support.constraint.Guideline
                android:id="@+id/gl_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="8dp" />

            <android.support.constraint.Guideline
                android:id="@+id/gl_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="8dp" />

            <TextView
                android:id="@+id/act058_tv_zone_position"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="Zone | Position"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/act058_tv_inbound_lbl"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/act058_chk_change_zone"
                app:layout_constraintVertical_chainStyle="spread" />

            <TextView
                android:id="@+id/act058_tv_inbound_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="Inbound:"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_tv_zone_position" />

            <TextView
                android:id="@+id/act058_tv_inbound_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="2019.111"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/act058_tv_inbound_lbl"
                app:layout_constraintStart_toEndOf="@+id/act058_tv_inbound_lbl"
                app:layout_constraintTop_toTopOf="@+id/act058_tv_inbound_lbl" />

            <TextView
                android:id="@+id/act058_tv_move_order_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="MO:"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_tv_inbound_lbl" />

            <TextView
                android:id="@+id/act058_tv_move_order_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="2019.111"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/act058_tv_move_order_lbl"
                app:layout_constraintStart_toEndOf="@+id/act058_tv_move_order_lbl"
                app:layout_constraintTop_toTopOf="@+id/act058_tv_move_order_lbl" />


            <TextView
                android:id="@+id/act058_tv_move_to_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="Move to:"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_tv_move_order_lbl" />

            <TextView
                android:id="@+id/act058_tv_move_to_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Zone | Position"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/act058_tv_move_to_lbl"
                app:layout_constraintStart_toEndOf="@+id/act058_tv_move_to_lbl"
                app:layout_constraintTop_toTopOf="@+id/act058_tv_move_to_lbl" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act058_mkedit_zone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:hint="Zone"
                app:layout_constraintBottom_toTopOf="@+id/act058_mkedit_position"
                app:layout_constraintEnd_toStartOf="@+id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_tv_move_to_lbl" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act058_mkedit_position"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:hint="Position"
                app:layout_constraintBottom_toTopOf="@+id/act058_ss_reason"
                app:layout_constraintEnd_toStartOf="@+id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_mkedit_zone" />

            <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                android:id="@+id/act058_ss_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toTopOf="@+id/act058_ll_serial_tracking"
                app:layout_constraintEnd_toStartOf="@+id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_mkedit_position" />

            <LinearLayout
                android:id="@+id/act058_ll_serial_tracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toTopOf="@+id/act058_ll_tracking_container"
                app:layout_constraintEnd_toStartOf="@+id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_ss_reason">

                <TextView
                    android:id="@+id/act058_tv_serial_tracking_ttl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="5dp"
                    android:text="Tracking"
                    android:textSize="@dimen/font_size_item_md" />

                <ImageView
                    android:id="@+id/act058_iv_add_tracking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:paddingLeft="15dp"
                    android:paddingTop="4dp"
                    android:paddingRight="15dp"
                    android:paddingBottom="4dp"
                    android:src="@drawable/ic_adicionar_tracking_number_states" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/act058_ll_tracking_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toTopOf="@+id/act058_ll_class"
                app:layout_constraintEnd_toStartOf="@+id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_ll_serial_tracking"></LinearLayout>

            <LinearLayout
                android:id="@+id/act058_ll_class"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="@color/namoa_color_gray"
                android:orientation="vertical"
                android:padding="5dp"
                app:layout_constraintBottom_toTopOf="@+id/act058_mkedit_coments"
                app:layout_constraintEnd_toStartOf="@+id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_ll_tracking_container">

                <TextView
                    android:id="@+id/act058_tv_class_ttl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="5dp"
                    android:text="Class - Trad"
                    android:textSize="@dimen/font_size_item_md"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/act058_iv_class_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="5dp"
                        android:src="@drawable/ic_archive_black_24dp" />

                    <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                        android:id="@+id/act058_ss_class"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:gravity="center_vertical"
                        android:text="Class -Trad" />

                </LinearLayout>

            </LinearLayout>

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act058_mkedit_coments"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:hint="Coments - trad"
                app:layout_constraintBottom_toTopOf="@+id/act058_mkdate_confirm"
                app:layout_constraintEnd_toStartOf="@+id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@+id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_ll_class" />

            <com.namoa_digital.namoa_library.ctls.MkDateTime
                android:id="@+id/act058_mkdate_confirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/gl_right"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="@id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_mkedit_coments" />

            <CheckBox
                android:id="@+id/act058_chk_change_zone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Change to zone target - trad"
                app:layout_constraintEnd_toEndOf="@id/gl_right"
                app:layout_constraintStart_toStartOf="@id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_mkdate_confirm" />

            <Button
                android:id="@+id/act058_btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:background="@drawable/btn_namoa_main_states"
                android:focusable="true"
                android:text="NEW"
                android:textColor="@color/padrao_WHITE"
                app:layout_constraintEnd_toEndOf="@id/gl_right"
                app:layout_constraintStart_toStartOf="@id/gl_left"
                app:layout_constraintTop_toBottomOf="@+id/act058_chk_change_zone" />


        </android.support.constraint.ConstraintLayout>


    </LinearLayout>


</ScrollView>
