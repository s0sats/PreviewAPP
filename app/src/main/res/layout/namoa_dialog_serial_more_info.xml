<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/dialog_serial_info_tv_ttl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="Serial More Info"
        android:textSize="@dimen/font_size_title_dialog"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/dialog_serial_info_ll_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp"
                android:layout_marginBottom="5dp">
                <!--Category-->
                <TextView
                    android:id="@+id/dialog_serial_info_tv_category_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Categoria"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialog_serial_info_tv_category_val"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Categoria 001"
                    android:textSize="@dimen/font_size_item_md"
                    android:textColor="@color/namoa_light_blue"
                    android:layout_marginStart="5dp"
                    />
            </LinearLayout>

            <!--Segment-->
            <LinearLayout
                android:id="@+id/dialog_serial_info_ll_segment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/dialog_serial_info_tv_segment_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Segment"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialog_serial_info_tv_segment_val"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Segment 001"
                    android:textSize="@dimen/font_size_item_md"
                    android:textColor="@color/namoa_light_blue"
                    android:layout_marginStart="5dp"
                    />
            </LinearLayout>
            <!--Add Info-->
            <LinearLayout
                android:id="@+id/dialog_serial_info_ll_add_info1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/dialog_serial_info_tv_add_info1_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Info 1"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialog_serial_info_tv_add_info1_val"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Segment 001"
                    android:textSize="@dimen/font_size_item_md"
                    android:textColor="@color/namoa_light_blue"
                    android:layout_marginStart="5dp"
                    />
            </LinearLayout>

            <!--Add Info2-->
            <LinearLayout
                android:id="@+id/dialog_serial_info_ll_add_info2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/dialog_serial_info_tv_add_info2_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Info 2"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialog_serial_info_tv_add_info2_val"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="add info 2"
                    android:textSize="@dimen/font_size_item_md"
                    android:textColor="@color/namoa_light_blue"
                    android:layout_marginStart="5dp"
                    />
            </LinearLayout>

            <!--Add Info3-->
            <LinearLayout
                android:id="@+id/dialog_serial_info_ll_add_info3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/dialog_serial_info_tv_add_info3_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Info 3"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialog_serial_info_tv_add_info3_val"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="add info 3"
                    android:textSize="@dimen/font_size_item_md"
                    android:textColor="@color/namoa_light_blue"
                    android:layout_marginStart="5dp"
                    />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>