<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp">

        <View
            android:id="@+id/act035_main_content_cell_ticket_v_space_left"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/act035_main_content_cell_ticket_iv_other_img"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginRight="-6dp"
            android:background="@drawable/ic_play"
            />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="18"
            android:background="@drawable/bg_msg_from"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/act035_main_content_cell_ticket_tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="N.Hugo"
                android:textColor="#f1194f"
                android:textSize="14sp"
                android:textStyle="bold"
                android:typeface="normal" />

            <TextView
                android:id="@+id/act035_main_content_cell_namoa_ticket_tv_module_ttl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                tools:text="Formulario - trad"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_ttl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    tools:text="Ticket - trad"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_iv_sync_upload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="2dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_arrow_up_thick_black_24dp"
                    android:tint="@color/namoa_dark_blue"
                    android:visibility="gone" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_id_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    tools:text="Ticket.ID:"
                    android:textStyle="bold" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_id_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    tools:text="2019.666" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginLeft="15dp"
                >

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_path_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    android:textStyle="bold"
                    tools:text="Hieraquia:" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_path_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:textStyle="bold"
                    tools:text="LIMPEZA/Copa/" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    tools:text="Tipo:"
                    android:textStyle="bold" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_type_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:textStyle="bold"
                    tools:text="Teste" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_serial_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    tools:text="Serial:"
                    android:textStyle="bold" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_serial_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    tools:text="btt123" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_comment_lbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    tools:text="Open Comments:"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_comment_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="5dp"
                    android:gravity="start"
                    tools:text="Comnetario usado na abertura para que  ajudar  a identificar o problemas "
                    android:maxLines="3"
                    android:ellipsize="end"
                    />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/act035_main_content_cell_namoa_ticket_ll_action_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/act035_main_content_cell_namoa_ticket_btn_download"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/btn_namoa_main_states"
                        android:focusable="false"
                        android:padding="10dp"
                        tools:text="Download Ticket"
                        android:textColor="@color/padrao_WHITE"
                        android:layout_gravity="center"
                        />

                    <ImageButton
                        android:id="@+id/act035_main_content_cell_namoa_ticket_iv_download"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/btn_namoa_main_states"
                        android:padding="5dp"
                        android:src="@drawable/ic_file_download_black_24dp"
                        android:tint="@color/padrao_WHITE"
                        android:visibility="gone"
                        />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_msg_code_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    tools:text="2048.666"
                    android:textColor="#9c9b9b"
                    android:textSize="12sp"
                    android:textStyle="normal"
                    android:typeface="normal"
                    android:visibility="gone"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/act035_main_content_cell_namoa_ticket_tv_hour_ttl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    tools:text="11:30"
                    android:textColor="#9c9b9b"
                    android:textSize="12sp"
                    android:textStyle="normal"
                    android:typeface="normal" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/act035_main_content_cell_ticket_iv_me_img"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginLeft="-6dp"
            android:background="@drawable/ic_play_2"
            android:visibility="gone"/>

        <View
            android:id="@+id/act035_main_content_cell_ticket_v_space_right"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:visibility="gone"
            />
    </LinearLayout>

</LinearLayout>
