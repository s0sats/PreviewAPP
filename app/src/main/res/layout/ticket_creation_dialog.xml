<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fitsSystemWindows="false"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/act010_create_ticket_dialog_ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/act010_create_ticket_dialog_ttl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="asdsdasdasdasdasdaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
            android:textColor="@color/text_black"
            android:textAlignment="center"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act010_create_ticket_dialog_tv_site"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            tools:text="asdsdasdasdasdasdaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
            android:textColor="@color/text_red"
            android:textAlignment="center"
            app:layout_constraintEnd_toEndOf="@+id/act010_create_ticket_dialog_ttl"
            app:layout_constraintStart_toStartOf="@+id/act010_create_ticket_dialog_ttl"
            app:layout_constraintTop_toBottomOf="@+id/act010_create_ticket_dialog_ttl" />

       <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/act010_create_ticket_dialog_internal_comments_til"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:hint="Texto"
            app:endIconMode="none"
            app:counterEnabled="true"
            app:counterMaxLength="500"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act010_create_ticket_dialog_tv_site">

            <AutoCompleteTextView
                android:id="@+id/act010_create_ticket_dialog_internal_comments_actv"
                android:maxLength="500"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act010_create_ticket_dialog_internal_comments_til">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/act010_create_ticket_dialog_btn_cancel"
                style="@style/NamoaMaterialButtonText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                tools:text="Cancelar"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/act010_create_ticket_dialog_btn_save"
                style="@style/NamoaNoIconMaterialButtonFilledDarkBlue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:textAllCaps="true"
                android:padding="2dp"
                tools:text="Salvar"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>