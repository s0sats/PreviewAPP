<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/act034_opc_cell_ll_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/act034_cell_bg_states"
        android:orientation="horizontal"
        android:padding="15dp"
        android:gravity="center_vertical"
        >

        <TextView
            android:id="@+id/act034_opc_cell_tv_customer_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nome"
            android:textColor="@color/namoa_color_light_blue"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/act034_opc_cell_tv_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_chat"
            android:gravity="center"
            android:paddingBottom="3dp"
            android:paddingLeft="5dp"
            android:paddingRight="6dp"
            android:paddingTop="3dp"
            android:layout_margin="2dp"
            android:text=" 2 "
            android:textColor="@color/padrao_WHITE"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>