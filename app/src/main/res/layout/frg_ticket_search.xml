<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:background="@color/padrao_WHITE"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp">

            <!--<View-->
            <!--android:layout_width="match_parent"-->
            <!--android:layout_height="5dp" />-->

            <TextView
                android:id="@+id/frg_ticket_search_tv_product_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Prod Id"
                android:textSize="@dimen/font_size_title_md"
                android:visibility="gone" />

            <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                android:id="@+id/frg_serial_search_ss_site"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/frg_ticket_search_tv_serial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Serial id"
                android:textSize="@dimen/font_size_title_md"
                android:visibility="gone" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/frg_ticket_search_ll_client"
                style="@style/NamoaTheme3.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:hint="Client"
                app:helperTextTextColor="@color/m3_namoa_secondary">

                <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                    android:id="@+id/frg_ticket_search_mket_client"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@drawable/edittext_theme_text"
                    android:inputType="textMultiLine"
                    app:mBARCODE="true"
                    app:mNFC="false"
                    app:mOCR="false" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/frg_serial_search_ll_contract"
                style="@style/NamoaTheme3.TextInputLayoutNoMargin.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:hint="Contract"
                app:helperTextTextColor="@color/m3_namoa_secondary">

                <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                    android:id="@+id/frg_serial_search_mket_contract"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@drawable/edittext_theme_text"
                    android:inputType="textMultiLine"
                    app:mBARCODE="true"
                    app:mNFC="false"
                    app:mOCR="false" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/frg_ticket_search_ll_ticket"
                style="@style/NamoaTheme3.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:hint="Ticket"
                app:helperTextTextColor="@color/m3_namoa_secondary">

                <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                    android:id="@+id/frg_ticket_search_mket_ticket"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@drawable/edittext_theme_text"
                    android:inputType="textMultiLine"
                    app:mBARCODE="true"
                    app:mNFC="false"
                    app:mOCR="false" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/frg_ticket_search_btn_option_02"
                style="@style/Widget.Material3.Button"
                app:shapeAppearance="@style/ShapeAppearance.Material3.SmallComponent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="Option 02" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/frg_ticket_search_btn_option_03"
                style="@style/Widget.Material3.Button"
                app:shapeAppearance="@style/ShapeAppearance.Material3.SmallComponent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="Option 02" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <LinearLayout
                android:id="@+id/frg_ticket_search_ll_btn_option_04"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/frg_ticket_search_btn_option_04"
                    style="@style/Widget.Material3.Button"
                    app:shapeAppearance="@style/ShapeAppearance.Material3.SmallComponent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:text="Option 02" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="5dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/frg_ticket_search_ll_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/frg_ticket_search_btn_option_05"
                style="@style/Widget.Material3.Button"
                app:shapeAppearance="@style/ShapeAppearance.Material3.SmallComponent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="Option 02" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

        </LinearLayout>

    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/m3_namoa_surface2"
        android:orientation="horizontal"
        android:gravity="start"
        android:layout_gravity="bottom"
        android:paddingHorizontal="10dp"
        android:paddingVertical="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/frg_ticket_search_btn_option_01"
            style="@style/Widget.Material3.Button.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            tools:text="Search"
            android:textAlignment="center"
            android:textColor="@color/m3_namoa_surface2"
            android:visibility="visible"
            android:backgroundTint="@drawable/button_theme_primary"
            app:icon="@drawable/ic_search_black_24dp"
            app:iconGravity="textStart"
            app:iconTint="@color/m3_namoa_surface2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/m3_namoa_primary"
            app:strokeWidth="0dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>


</LinearLayout>

