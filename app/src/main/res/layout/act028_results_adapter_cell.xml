<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/act027_services_content_cell_ll_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/namoa_cell_8_states"
    android:orientation="vertical"
    android:paddingBottom="15dp"
    android:paddingLeft="15dp"
    android:paddingRight="15dp"
    android:paddingTop="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act028_results_adapter_cell_tv_ttl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="10dp"
            android:layout_weight="4"
            android:text="S.O."
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/act028_results_adapter_cell_iv_flag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_flag_black_24dp"
            android:tint="@color/namoa_dark_blue"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/act028_results_adapter_cell_tv_prod_ttl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:gravity="left"
        android:text="Product ID"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/act028_results_adapter_cell_tv_prod_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:gravity="left"
        android:text="Product ID Value"
        android:textStyle="normal" />

    <TextView
        android:id="@+id/act028_results_adapter_cell_tv_serial_ttl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="5dp"
        android:gravity="left"
        android:text="Serial"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/act028_results_adapter_cell_tv_serial_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:gravity="left"
        android:text="Serial Value"
        android:textStyle="normal" />


    <TextView
        android:id="@+id/act028_results_adapter_cell_tv_msg_ttl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="5dp"
        android:gravity="left"
        android:text="Mensagem"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/act028_results_adapter_cell_tv_msg_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:gravity="left"
        android:text="Descricao da Mensagem"
        android:textStyle="normal" />


</LinearLayout>