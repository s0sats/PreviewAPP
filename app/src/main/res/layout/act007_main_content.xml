<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act007.Act007_Main"
    tools:showIn="@layout/act007_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product"
            android:textColor="@color/bootstrap_brand_secondary_text"
            android:textSize="20sp"
            android:visibility="gone" />

        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
            android:id="@+id/act007_mket_product_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:mNFC="false"
            app:mOCR="false"
            android:background="@drawable/namoa_bg_1"
            android:inputType="text"
            android:textSize="@dimen/font_size_title"
            />

        <ListView
            android:id="@+id/act007_lv_groups_products"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:padding="5dp"
            android:dividerHeight="1dp"
            android:divider="@color/namoa_color_light_blue7"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/act007_btn_back"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:background="@drawable/btn_namoa_main_states"
                android:textColor="@color/padrao_WHITE"
                />

            <Button
                android:id="@+id/act007_btn_home"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:background="@drawable/btn_namoa_main_states"
                android:textColor="@color/padrao_WHITE"
             />

        </LinearLayout>


    </LinearLayout>

    <include layout="@layout/footer_base" />

</LinearLayout>
