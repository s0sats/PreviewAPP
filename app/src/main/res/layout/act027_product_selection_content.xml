<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="10dp">

        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
            android:id="@+id/act027_product_selection_mket_product_search"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/namoa_bg_1"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:padding="10dp"
            app:mNFC="false"
            app:mOCR="false"
            android:textSize="@dimen/font_size_title"
        />

        <ListView
            android:id="@+id/act027_product_selection_lv_groups_products"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:divider="@color/namoa_color_light_blue7"
            android:dividerHeight="1dp"
            android:padding="5dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/act027_product_selection_btn_back"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:layout_weight="1"
                android:background="@drawable/btn_namoa_main_states"
                android:textColor="@color/padrao_WHITE" />

            <Button
                android:id="@+id/act027_product_selection_btn_home"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:layout_weight="1"
                android:background="@drawable/btn_namoa_main_states"
                android:textColor="@color/padrao_WHITE" />

        </LinearLayout>


    </LinearLayout>
</LinearLayout>
