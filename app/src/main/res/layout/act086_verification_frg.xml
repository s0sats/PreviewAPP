<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.act086.frg_verification.Act086VerificationFrg"
    android:id="@+id/act086_verification_frg_fl_main"
    >
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/act086_verification_frg_cl_manual_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="gone"
            >
            <ImageView
                android:id="@+id/act086_verification_frg_iv_manual_handler"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/act086_verification_frg_mket_manual_desc"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/act086_verification_frg_mket_manual_desc"
                app:srcCompat="@drawable/ic_done_black_24dp"
                app:tint="@drawable/os_form_verify_item_ic_color_states"
                android:background="@drawable/namoa_icon_bg_states"
                />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act086_verification_frg_mket_manual_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:hint="Informar nome do novo item de verificação para a posteridade"
                app:layout_constraintEnd_toStartOf="@+id/act086_verification_frg_iv_manual_handler"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textColorHint="@color/namoa_color_gray_9"
                app:mBARCODE="false"
                app:mNFC="false"
                app:mOCR="false"
                app:mOCRVin="false"
                android:layout_marginBottom="32dp"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <RadioGroup
            android:id="@+id/act086_verification_frg_rg_answers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act086_verification_frg_cl_manual_desc">

            <RadioButton
                android:id="@+id/act086_verification_frg_rdo_answer_fixed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="false"
                android:drawableStart="@drawable/ic_build_black_24dp"
                android:drawablePadding="8dp"
                android:minHeight="48dp"
                android:paddingStart="8dp"
                android:text="Ação realizada"
                style="@style/NamoaFormOsRadioButton"
                app:drawableTint="@color/namoa_os_form_done_action_blue"
                />

            <RadioButton
                android:id="@+id/act086_verification_frg_rdo_answer_already_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/NamoaFormOsRadioButton"
                android:checked="false"
                android:drawableStart="@drawable/ic_done_black_24dp"
                android:drawablePadding="8dp"
                android:minHeight="48dp"
                android:paddingStart="8dp"
                android:text="Já estava ok"
                app:drawableTint="@color/namoa_os_form_verified_green" />

            <RadioButton
                android:id="@+id/act086_verification_frg_rdo_answer_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/NamoaFormOsRadioButton"
                android:checked="false"
                android:drawableStart="@drawable/ic_outline_report_problem_24_black"
                android:drawablePadding="8dp"
                android:minHeight="48dp"
                android:paddingStart="8dp"
                android:text="Continua com problema"
                app:drawableTint="@color/namoa_os_form_problem_red" />

            <RadioButton
                android:id="@+id/act086_verification_frg_rdo_answer_not_verified"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/NamoaFormOsRadioButton"
                android:checked="false"
                android:drawableStart="@drawable/ic_baseline_redo_24_black"
                android:drawablePadding="8dp"
                android:minHeight="48dp"
                android:paddingStart="8dp"
                android:text="Não verificado"
                app:drawableTint="@color/namoa_status_not_executed" />
        </RadioGroup>

        <TextView
            android:id="@+id/act086_verification_frg_tv_supplementary_data_ttl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Dados complementares"
            android:textAllCaps="true"
            android:textColor="@color/namoa_color_gray_9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act086_verification_frg_tv_require_fields" />

        <ImageView
            android:id="@+id/act086_verification_frg_iv_comment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/act086_verification_frg_mket_comment"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/act086_verification_frg_mket_comment"
            app:srcCompat="@drawable/ic_baseline_notes_24"
            app:tint="@color/namoa_pipeline_header_icon"
            android:enabled="false"
            />

        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
            android:id="@+id/act086_verification_frg_mket_comment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/act086_verification_frg_iv_comment"
            app:layout_constraintTop_toBottomOf="@id/act086_verification_frg_tv_supplementary_data_ttl"
            app:mBARCODE="false"
            tools:hint="Inserir comentario"
            android:textColor="@color/os_form_verify_item_label_text_color_states"
            android:textSize="@dimen/font_size_font_16"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/act086_verification_frg_cl_material"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act086_verification_frg_mket_comment"
            android:background="@drawable/namoa_icon_bg_states"
            android:clickable="false"
            android:enabled="false"
            >

            <ImageView
                android:id="@+id/act086_verification_frg_iv_spare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:srcCompat="@drawable/ic_baseline_inventory_2_black_24"
                app:tint="@color/namoa_pipeline_header_icon"
                android:enabled="false"/>

            <TextView
                android:id="@+id/act086_verification_frg_tv_material_ttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:text="Insumos aplicados: 0"
                app:layout_constraintEnd_toStartOf="@+id/act086_verification_frg_iv_add_material"
                app:layout_constraintStart_toEndOf="@+id/act086_verification_frg_iv_spare"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textColor="@color/os_form_verify_item_label_text_color_states"
                android:enabled="false"
                android:textSize="@dimen/font_size_font_16"
                />

            <ImageView
                android:id="@+id/act086_verification_frg_iv_add_material"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/ic_add_black_24px"
                app:tint="@color/namoa_pipeline_header_icon"
                android:enabled="false"
                android:clickable="false"
                />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/act086_verification_frg_rv_material"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act086_verification_frg_cl_material"
            tools:itemCount="2"
            tools:listitem="@layout/act086_material_item" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/act086_verification_frg_cl_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act086_verification_frg_rv_material"
            android:background="@drawable/namoa_icon_bg_states"
            android:clickable="false"
            android:enabled="false"
            >

            <TextView
                android:id="@+id/act086_verification_frg_tv_photo_ttl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:text="Photo"
                android:textColor="@color/os_form_verify_item_label_text_color_states"
                app:layout_constraintEnd_toStartOf="@+id/act086_verification_frg_iv_add_photo"
                app:layout_constraintStart_toEndOf="@+id/act086_verification_frg_iv_photo"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:enabled="false"
                android:textSize="@dimen/font_size_font_16"
                />


            <ImageView
                android:id="@+id/act086_verification_frg_iv_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:tint="@color/namoa_pipeline_header_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:srcCompat="@drawable/ic_baseline_photo_camera_24"
                android:enabled="false"
                />

            <ImageView
                android:id="@+id/act086_verification_frg_iv_add_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/ic_add_black_24px"
                app:tint="@color/namoa_pipeline_header_icon"
                android:enabled="false"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/act086_verification_frg_rv_photos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act086_verification_frg_cl_photo"
            app:spanCount="2"
            tools:itemCount="4"
            tools:listitem="@layout/act086_photo_item"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/act086_verification_frg_cl_delete_infos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act086_verification_frg_rv_photos"
            android:background="@drawable/namoa_icon_bg_states"
            >

            <ImageView
                android:id="@+id/act086_verification_frg_iv_delete_infos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_trash"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:srcCompat="@drawable/ic_eraser_24dp"
                app:tint="@color/namoa_os_form_problem_red" />

            <TextView
                android:id="@+id/act086_verification_frg_tv_delete_lbl"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="24dp"
                android:gravity="center_vertical"
                android:text="Descartar resposta e anexos"
                android:textColor="@color/namoa_os_form_problem_red"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/act086_verification_frg_iv_delete_infos"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <Button
            android:id="@+id/act086_verification_frg_btn_ok"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="46dp"
            android:layout_marginEnd="46dp"
            android:background="@drawable/namoa_cell_12_states"
            android:text="Ok"
            android:textColor="@color/padrao_WHITE"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act086_verification_frg_cl_delete_infos"
            app:layout_constraintWidth_percent="0.5"
            style="@style/NamoaSaveButtonDarkBlue"/>

        <TextView
            android:id="@+id/act086_verification_frg_tv_require_fields"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:text="Preencha abaixo os campos obrigatorios!"
            android:textColor="@color/namoa_color_highlight_required_item"
            app:layout_constraintBottom_toTopOf="@+id/act086_verification_frg_tv_supplementary_data_ttl"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act086_verification_frg_rg_answers"
            android:visibility="gone"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>