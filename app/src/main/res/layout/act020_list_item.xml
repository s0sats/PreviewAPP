<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    app:cardCornerRadius="12dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="@color/m3_namoa_surfaceVariant"
    android:id="@+id/cardSerial"
    android:minHeight="80dp"
    android:elevation="0dp"
    style="@style/Widget.Material3.CardView.Filled">
    
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            tools:ignore="UseCompoundDrawables">

            <ImageView
                android:id="@+id/iconClassColor"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="0dp"
                android:visibility="visible"
                android:src="@drawable/ic_baseline_arrow_right_24"
                app:tint="#000000" />

            <TextView
                android:id="@+id/card_serial_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/TextAppearance.Material3.TitleLarge"
                android:textColor="@color/m3_namoa_onSurface" />

            <ImageView
                android:id="@+id/iconOffline"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="0dp"
                android:src="@drawable/baseline_wifi_off_24"
                app:tint="@color/m3_namoa_onSurfaceVariant" />
        </LinearLayout>

        <TextView
            android:id="@+id/productDescription"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/serialDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="normal"
            android:visibility="gone"
            style="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/m3_namoa_onSurfaceVariant"/>

        <View
            android:id="@+id/space_site"
            android:layout_width="match_parent"
            android:layout_height="16dp"/>

        <TextView
            android:id="@+id/list_trackings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="normal"
            android:visibility="gone"
            style="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/m3_namoa_onSurfaceVariant"/>

        <View
            android:id="@+id/space_site2"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/site_and_zone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            style="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="@color/m3_namoa_onSurfaceVariant"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>