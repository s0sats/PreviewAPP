            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp">

            <ImageView
                android:id="@+id/act011_ff_options_ll_iv_ii"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:src="@drawable/ic_info" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/act011_ff_options_ll_nserv"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/namoa_icon_bg_states"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp">

            <ImageView
                android:id="@+id/act011_ff_options_ll_iv_nserv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:src="@drawable/ic_n_service2_24x24" />

        </LinearLayout>


    </LinearLayout>

