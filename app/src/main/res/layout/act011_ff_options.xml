<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_form_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:focusable="false"
        android:text="Header"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/rv_form_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_form_tabs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_form_auto_answer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_form_desc"
        tools:itemCount="50"
        tools:listitem="@layout/act011_ff_options_cell" />

    <TextView
        android:id="@+id/tv_form_auto_answer"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:background="@drawable/namoa_cell_5_states"
        android:clickable="true"
        android:drawableLeft="@drawable/ic_resposta_padrao_states"
        android:drawablePadding="16dp"
        android:focusable="false"
        android:gravity="center_vertical"
        android:padding="5dp"
        android:paddingStart="5dp"
        android:text="Automatic Answers Farhzeug"
        android:textColor="@color/namoa_cell_5_font_color"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/v_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_form_tabs"
        tools:visibility="visible" />

    <View
        android:id="@+id/v_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginBottom="64dp"
        android:background="@color/namoa_color_black"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/ib_delete"
        style="@style/MyFormOSDrawerImageButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginBottom="4dp"
        android:focusable="false"
        android:paddingHorizontal="13dp"
        android:src="@drawable/ic_apagar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ib_save"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/ib_save"
        style="@style/MyFormOSDrawerImageButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginBottom="4dp"
        android:focusable="false"
        android:paddingHorizontal="13dp"
        android:src="@drawable/ic_salvar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ib_finalize"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/ib_delete" />

    <ImageButton
        android:id="@+id/ib_finalize"
        style="@style/MyFormOSDrawerImageButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginBottom="4dp"
        android:focusable="false"
        android:paddingHorizontal="13dp"
        android:src="@drawable/ic_finalizar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ib_signature"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/ib_save" />

    <ImageButton
        android:id="@+id/ib_signature"
        style="@style/MyFormOSDrawerImageButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginBottom="4dp"
        android:focusable="false"
        android:paddingHorizontal="13dp"
        android:src="@drawable/ic_assinatura2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ib_info"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/ib_finalize" />


    <ImageButton
        android:id="@+id/ib_info"
        style="@style/MyFormOSDrawerImageButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginBottom="4dp"
        android:focusable="false"
        android:paddingHorizontal="13dp"
        android:src="@drawable/ic_info"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ib_nserv"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/ib_signature" />


    <ImageButton
        android:id="@+id/ib_nserv"
        style="@style/MyFormOSDrawerImageButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginBottom="4dp"
        android:focusable="false"
        android:paddingHorizontal="13dp"
        android:src="@drawable/ic_n_service2_24x24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/ib_info" />

</androidx.constraintlayout.widget.ConstraintLayout>