                android:layout_height="wrap_content"
                android:focusable="false"
                android:src="@drawable/ic_assinatura2" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/act011_ff_options_ll_ii"
            android:layout_width="0dp"
            android:layout_height="match_parent"
