<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/act011_ff_options_ll_h"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="5dp">

        <TextView
            android:id="@+id/act011_ff_options_ll_ih"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:focusable="false"
            android:paddingLeft="16dp"
            android:text="Header"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ListView
        android:id="@+id/act011_ff_options_lv_tabs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4D000000"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/act011_ff_options_ll_auto"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/namoa_cell_5_states"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="5dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="5dp"
            android:layout_weight="1"
            android:src="@drawable/ic_resposta_padrao_states" />

        <TextView
            android:id="@+id/act011_ff_options_ll_autot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:focusable="false"
            android:paddingLeft="16dp"
            android:text="Automatic"
            android:textColor="@color/namoa_cell_5_font_color"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:id="@+id/act011_ff_options_view_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4D000000"
        android:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/act011_ff_options_ll_e"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
