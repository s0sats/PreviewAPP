<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/frg_serial_edit_sv_serial"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:background="@color/namoa_color_gray"
                    android:orientation="vertical"
                    android:paddingBottom="5dp">


                    <!--Product Info LL -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="0dp"

                        android:paddingRight="10dp"
                        android:paddingTop="0dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginRight="10dp"
                            android:layout_weight="1"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/imageView"
                                android:layout_width="40dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:layout_marginStart="5dp"
                                android:padding="5dp"
                                android:src="@drawable/ic_produto" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="5"
                            android:orientation="vertical"
                            android:paddingBottom="5dp"
                            android:paddingLeft="0dp"
                            android:paddingRight="10dp"
                            android:paddingTop="5dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/frg_serial_edit_tv_product_code_lbl"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="left"
                                    android:padding="2dp"
                                    android:text="Code"
                                    android:textSize="@dimen/font_size_item_md"
                                    android:visibility="gone" />

                                <View
                                    android:layout_width="5dp"
                                    android:layout_height="match_parent"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/frg_serial_edit_tv_product_id_lbl"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="left|center_vertical"
                                    android:padding="2dp"
                                    android:text="Id"
                                    android:textSize="@dimen/font_size_item_md" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/frg_serial_edit_tv_product_desc_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingBottom="2dp"
                                android:paddingLeft="5dp"
                                android:paddingRight="2dp"
                                android:paddingTop="2dp"
                                android:text="Product Description"
                                android:textSize="@dimen/font_size_title_md" />
                        </LinearLayout>

                    </LinearLayout>
                    <!-- Fim Product Info LL -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_brand_model_color"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="2dp"
                            android:text=""
                            android:textSize="@dimen/font_size_item_md"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        >
                        <TextView
                            android:id="@+id/frg_serial_edit_tv_serial_ttl"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingBottom="2dp"
                            android:paddingLeft="10dp"
                            android:paddingRight="2dp"
                            android:paddingTop="2dp"
                            android:text="Serial Data"
                            android:textSize="@dimen/font_size_title_md" />

                        <ImageView
                            android:id="@+id/frg_serial_edit_iv_serial_dialog_log"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="13dp"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/ic_clock_chat"
                            android:tint="@color/light_to_dark_blue_color"
                            android:visibility="visible" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingEnd="5dp"
                        android:paddingStart="5dp">

                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_mket_serial"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:background="@drawable/namoa_bg_1"
                            android:inputType="text"
                            android:padding="10dp"
                            android:textSize="@dimen/font_size_title"
                            android:textStyle="bold"
                            app:mBARCODE="true"
                            app:mNFC="false"
                            app:mOCR="false" />

                        <ImageView
                            android:id="@+id/frg_serial_edit_iv_serial_dialog_info"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginEnd="8dp"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/icon_info_states"
                            android:visibility="visible" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="5dp">

                        <Button
                            android:id="@+id/frg_serial_edit_btn_action"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_namoa_main_states"
                            android:text="NEW"
                            android:textColor="@color/padrao_WHITE"
                            android:focusable="true"
                            />


                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/frg_serial_edit_ll_serial_full_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/frg_serial_edit_ll_class"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:background="@color/namoa_color_gray"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_class_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="5dp"
                            android:text="Class - Trad"
                            android:textSize="@dimen/font_size_item_md"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/frg_serial_edit_iv_class_icon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:padding="5dp"
                                android:src="@drawable/ic_archive_black_24dp" />

                            <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                                android:id="@+id/frg_serial_edit_ss_class"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:gravity="center_vertical"
                                android:text="Class -Trad" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/frg_serial_edit_ll_serial_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/namoa_color_gray"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_serial_location_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Location"
                            android:textSize="@dimen/font_size_item_md"
                            android:textStyle="bold"
                            />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_site"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:gravity="center_vertical"
                            android:text="Site" />

                        <LinearLayout
                                android:id="@+id/frg_serial_edit_ll_suggested_location"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="15dp"
                                android:background="@color/namoa_color_gray"
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:visibility="gone"
                        >

                            <TextView
                                    android:id="@+id/frg_serial_edit_tv_suggested_location_ttl"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:padding="5dp"
                                    android:text="Suggested"
                                    android:textSize="@dimen/font_size_item_md"
                                    android:textStyle="bold"
                                    android:visibility="gone"

                            />

                            <TextView
                                    android:id="@+id/frg_serial_edit_tv_suggested_location"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="2"
                                    android:gravity="center"
                                    android:padding="5dp"
                                    android:text="Zona | Local"
                                    android:textSize="@dimen/font_size_item_md"
                                    android:textStyle="bold"
                            />


                        </LinearLayout>

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_site_zone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:text="Zone" />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_site_zone_local"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:text="Local" />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_site_reason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:visibility="gone"
                            android:text="Motivo - trad" />

                    </LinearLayout>

                    <LinearLayout
                            android:id="@+id/frg_serial_edit_ll_serial_tracking"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@color/namoa_color_gray"
                            android:paddingBottom="8dp">
                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                            <TextView
                                    android:id="@+id/frg_serial_edit_tv_serial_tracking_ttl"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:padding="5dp"
                                    android:text="Tracking"
                                    android:textSize="@dimen/font_size_item_md" />

                            <ImageView
                                    android:id="@+id/frg_serial_edit_iv_add_tracking"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:paddingBottom="4dp"
                                    android:paddingLeft="15dp"
                                    android:paddingRight="15dp"
                                    android:paddingTop="4dp"
                                    android:src="@drawable/ic_adicionar_tracking_number_states" />

                        </LinearLayout>

                        <LinearLayout
                                android:id="@+id/frg_serial_edit_ll_tracking_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/frg_serial_edit_ll_serial_properties"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:layout_marginBottom="15dp"
                        android:background="@color/namoa_color_gray"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_serial_properties_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Properties"
                            android:textSize="@dimen/font_size_item_md"
                            android:textStyle="bold"
                            />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_brand"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint="Brand" />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_brand_model"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint="Model" />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_brand_color"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:hint="Color" />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_segment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint="Segment" />

                        <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                            android:id="@+id/frg_serial_edit_ss_category_price"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:hint="Category Price" />

                        <LinearLayout
                            android:id="@+id/frg_serial_edit_ll_product_properties"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:layout_marginLeft="5dp"
                            android:orientation="vertical"
                            android:visibility="visible">

                            <LinearLayout
                                android:id="@+id/frg_serial_edit_ll_require_serial"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="2dp">

                                <TextView
                                    android:id="@+id/frg_serial_edit_tv_require_serial_lbl"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:text="Require Serial" />

                                <TextView
                                    android:id="@+id/frg_serial_edit_tv_require_serial_val"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="5dp"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical|right"
                                    android:text="Sim"
                                    android:textColor="@color/namoa_color_orange" />

                            </LinearLayout>

                            <View
                                android:layout_width="2dp"
                                android:layout_height="match_parent" />

                            <LinearLayout
                                android:id="@+id/frg_serial_edit_ll_allow_new"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="2dp">

                                <TextView
                                    android:id="@+id/frg_serial_edit_tv_allow_lbl"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:text="Allow Creation" />

                                <TextView
                                    android:id="@+id/frg_serial_edit_tv_allow_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="5dp"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical|right"
                                    android:text="Não"
                                    android:textColor="@color/namoa_color_orange" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/frg_serial_edit_ll_serial_add_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:background="@color/namoa_color_gray"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_serial_add_info_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Additional Info"
                            android:textSize="@dimen/font_size_item_md"
                            android:textStyle="bold"/>


                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_et_info1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint=""
                            android:inputType="text"
                            android:minHeight="30dp"
                            android:padding="10dp"
                            app:mBARCODE="false"
                            app:mNFC="false"
                            app:mOCR="false" />

                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_et_info2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:clickable="true"
                            android:gravity="center_vertical"
                            android:hint=""
                            android:inputType="text"
                            android:minHeight="30dp"
                            android:padding="10dp"
                            app:mBARCODE="false"
                            app:mNFC="false"
                            app:mOCR="false" />

                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_et_info3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint=""
                            android:inputType="text"
                            android:minHeight="30dp"
                            android:padding="10dp"
                            app:mBARCODE="false"
                            app:mNFC="false"
                            app:mOCR="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/frg_serial_edit_ll_io_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:background="@color/namoa_color_gray"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_io_info_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="IO Info - Trad"
                            android:textSize="@dimen/font_size_item_md"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_inbound_lbl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Inbound - Trad"
                            android:textSize="@dimen/font_size_item" />


                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_mket_inbound_id"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint=""
                            android:inputType="text"
                            android:minHeight="30dp"
                            android:padding="10dp"
                            app:mBARCODE="false"
                            app:mNFC="false"
                            app:mOCR="false" />

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_inbound_date_conf_lbl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Inbound Date Conf - Trad"
                            android:textSize="@dimen/font_size_item" />


                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_mket_inbound_date_conf_val"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint=""
                            android:inputType="text"
                            android:minHeight="30dp"
                            android:padding="10dp"
                            app:mBARCODE="false"
                            app:mNFC="false"
                            app:mOCR="false" />

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_move_code_lbl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Move - Trad"
                            android:textSize="@dimen/font_size_item" />


                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_mket_move_code_val"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint=""
                            android:inputType="text"
                            android:minHeight="30dp"
                            android:padding="10dp"
                            app:mBARCODE="false"
                            app:mNFC="false"
                            app:mOCR="false" />

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_move_group_lbl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Move Group - Trad"
                            android:textSize="@dimen/font_size_item" />


                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/frg_serial_edit_mket_move_group_val"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="5dp"
                            android:gravity="center_vertical"
                            android:hint=""
                            android:inputType="text"
                            android:minHeight="30dp"
                            android:padding="10dp"
                            app:mBARCODE="false"
                            app:mNFC="false"
                            app:mOCR="false" />

                        <TextView
                            android:id="@+id/frg_serial_edit_tv_outbound_lbl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
