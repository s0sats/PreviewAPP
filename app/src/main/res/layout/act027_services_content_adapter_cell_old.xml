<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="5dp">

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_plc_pc_ps_sc_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLC_PC_PS_SC"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_title" />

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_plc_pc_ps_sc_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1.1.1 / 1"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_item" />

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_price_list_id_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Price List ID"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_title" />

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_price_list_id_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TB_TST_01"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_item" />

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_price_list_desc_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Price Description"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_title" />


        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_price_list_desc_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TABELA TESTE 01"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_item" />

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_pack_id_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Pack ID"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_title" />


        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_pack_id_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIMPEZA_FULL"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_item" />

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_pack_desc_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Pack Desc"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_title" />


        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_pack_desc_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIMPEZA FULL DESC"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_item" />

        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_service_desc_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Service Desc"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_title" />


        <TextView
            android:id="@+id/act027_services_content_cell_old_tv_service_desc_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LAVAGEM DESC"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_item" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_services_content_cell_old_tv_status_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Status"
                    android:textColor="@color/lib_custom_cell_font_color"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_services_content_cell_old_tv_qty_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Quantidade"
                    android:textColor="@color/lib_custom_cell_font_color"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_services_content_cell_old_tv_status_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="PENDING"
                    android:textColor="@color/lib_custom_cell_font_color"
                    android:textSize="@dimen/font_size_item" />

                <TextView
                    android:id="@+id/act027_services_content_cell_old_tv_qty_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/lib_custom_cell_font_color"
                    android:textSize="@dimen/font_size_item" />

            </LinearLayout>


        </LinearLayout>


    </LinearLayout>

</LinearLayout>