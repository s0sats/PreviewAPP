<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">

    <android.support.constraint.ConstraintLayout
        android:id="@+id/act055_main_cl_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/namoa_cell_8">

        <TextView
            android:id="@+id/act055_tv_io_product_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="Product - trad"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_move_order_list_position"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act055_tv_io_product_ext_code_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:text="TextView"
            app:layout_constraintStart_toStartOf="@+id/act055_tv_io_product_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_product_lbl" />

        <TextView
            android:id="@+id/act055_tv_io_product_desc_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TextView"
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_product_ext_code_val"
            app:layout_constraintStart_toEndOf="@+id/textView"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_product_ext_code_val" />


        <TextView
            android:id="@+id/act055_tv_io_serial_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="Serial - trad"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_move_order_list_position"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_product_ext_code_val" />

        <TextView
            android:id="@+id/act055_tv_io_serial_ext_code_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:text="Ext Code: - trad"
            app:layout_constraintStart_toStartOf="@+id/act055_tv_io_serial_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_serial_lbl" />

        <TextView
            android:id="@+id/act055_tv_io_serial_ext_code_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="TextView"
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_serial_ext_code_lbl"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_serial_ext_code_lbl"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_serial_ext_code_lbl" />

        <TextView
            android:id="@+id/act055_tv_io_serial_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="31dp"
            android:text="Marca | Modelo | Cor"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_serial_ext_code_lbl" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" - "
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_product_desc_val"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_product_ext_code_val"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_product_desc_val" />

        <TextView
            android:id="@+id/act055_tv_io_move_order_list_position"
            android:layout_width="25dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="100"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act055_tv_io_move_order_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ordem de Movimentação - trad"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/act055_tv_io_move_order_val"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@+id/act055_tv_io_serial_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_serial_desc" />

        <TextView
            android:id="@+id/act055_tv_io_move_order_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="2019.149"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_move_order_lbl"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_move_order_lbl"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_move_order_lbl" />

        <TextView
            android:id="@+id/act055_tv_io_inbound_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Inbound - trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act055_tv_io_move_order_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_move_order_lbl" />

        <TextView
            android:id="@+id/act055_tv_io_inbound_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="99"
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_inbound_lbl"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_inbound_lbl"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_inbound_lbl" />

        <TextView
            android:id="@+id/act055_tv_io_current_position_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Posição Atual - trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act055_tv_io_inbound_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_inbound_lbl" />

        <TextView
            android:id="@+id/act055_tv_io_current_position_zone_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Zona"
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_current_position_lbl"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_current_position_lbl"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_current_position_lbl" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="|"
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_current_position_zone_val"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_current_position_zone_val"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_current_position_zone_val" />

        <TextView
            android:id="@+id/act055_tv_io_current_position_local_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Local"
            app:layout_constraintBottom_toBottomOf="@+id/textView6"
            app:layout_constraintStart_toEndOf="@+id/textView6"
            app:layout_constraintTop_toTopOf="@+id/textView6" />

        <TextView
            android:id="@+id/act055_tv_io_suggested_position_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:text="Posição Sugerida - trad"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/act055_tv_io_current_position_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act055_tv_io_current_position_lbl" />

        <TextView
            android:id="@+id/textView9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Zona"
            app:layout_constraintBottom_toBottomOf="@+id/act055_tv_io_suggested_position_lbl"
            app:layout_constraintStart_toEndOf="@+id/act055_tv_io_suggested_position_lbl"
            app:layout_constraintTop_toTopOf="@+id/act055_tv_io_suggested_position_lbl" />

        <TextView
            android:id="@+id/textView10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="|"
            app:layout_constraintBottom_toBottomOf="@+id/textView9"
            app:layout_constraintStart_toEndOf="@+id/textView9"
            app:layout_constraintTop_toTopOf="@+id/textView9" />

        <TextView
            android:id="@+id/textView11"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Local"
            app:layout_constraintBottom_toBottomOf="@+id/textView10"
            app:layout_constraintStart_toEndOf="@+id/textView10"
            app:layout_constraintTop_toTopOf="@+id/textView10" />

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>
