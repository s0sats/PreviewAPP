<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/step_process_btn_v_line"
        android:layout_width="@dimen/pipeline_step_vertical_line_width"
        android:layout_height="0dp"
        android:background="@color/namoa_color_dark_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/gl_start"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap" />

    <android.support.constraint.Guideline
        android:id="@+id/gl_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.15" />

    <android.support.constraint.ConstraintLayout
        android:id="@+id/step_process_btn_cl_background"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/gl_start"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/pipeline_step_states"
        >

        <TextView
            android:id="@+id/step_process_btn_tv_ttl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text=" Iniciar etapa"
            android:textAllCaps="true"
            android:textColor="@color/namoa_status_process"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/step_process_btn_gd_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/step_process_btn_iv_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.Guideline
            android:id="@+id/step_process_btn_gd_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="8dp" />

        <View
            android:id="@+id/step_process_btn_v_divider"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_marginTop="@dimen/pipeline_step_info_margin_top"
            android:background="@drawable/step_line_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/step_process_btn_tv_ttl" />

        <ImageView
            android:id="@+id/step_process_btn_iv_icon"
            android:layout_width="@dimen/pipeline_step_icon_width"
            android:layout_height="@dimen/pipeline_step_icon_height"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/step_process_btn_tv_ttl"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/step_process_btn_tv_ttl"
            app:srcCompat="@drawable/ic_skip_next_yellow_24px" />

    </android.support.constraint.ConstraintLayout>


</android.support.constraint.ConstraintLayout>