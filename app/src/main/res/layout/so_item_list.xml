<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    android:background="@color/padrao_TRANSPARENT"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/act047_cell_tv_prefix_code"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:gravity="end"
            android:paddingVertical="2dp"
            android:paddingEnd="5dp"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/act047_cell_tv_status_val"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="2022.1234" />


        <TextView
            android:id="@+id/act047_cell_tv_status_val"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:paddingVertical="2dp"
            android:paddingEnd="10dp"
            android:textAlignment="textEnd"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="In Editing" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/os_card"
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        android:minHeight="80dp"
        app:cardBackgroundColor="@color/m3_namoa_neutral95"
        app:cardCornerRadius="12dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="16dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp">

                <ImageView
                    android:id="@+id/so_left_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="null"
                    android:src="@drawable/baseline_schedule_24"
                    app:layout_constraintBottom_toBottomOf="@+id/so_deadline_val"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/so_deadline_val"
                    app:tint="@color/m3_namoa_onSurfaceVariant" />


                <TextView
                    android:id="@+id/so_deadline_val"
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:paddingStart="8dp"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    app:layout_constraintStart_toEndOf="@+id/so_left_icon"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="01/11/2022 22:00" />


                <TextView
                    android:id="@+id/so_site_val"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/so_left_icon"
                    tools:text="Site" />

                <ImageView
                    android:id="@+id/so_right_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="null"
                    android:src="@drawable/ic_baseline_cloud_done_24"
                    android:visibility="visible"
                    app:layout_constraintBottom_toTopOf="@+id/so_priority_val"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <TextView
                    android:id="@+id/so_priority_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="Aguardando peça" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/mid_card_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:id="@+id/ll_serial_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">


                    <TextView
                        android:id="@+id/so_serial_id_val"
                        style="@style/TextAppearance.Material3.TitleLarge"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left|center"
                        android:layout_weight="1"
                        android:text="SERIAL NAME"
                        android:textAllCaps="true"
                        android:textColor="@color/m3_namoa_onSurface" />

                    <ImageView
                        android:id="@+id/so_block"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="right|center"
                        android:src="@drawable/ic_block_helper_black_18dp"
                        android:visibility="gone" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/so_brand_val"
                            style="@style/TextAppearance.Material3.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxEms="5"
                            android:maxLines="1"
                            android:textColor="@color/m3_namoa_onSurfaceVariant"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/so_model_val"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="Marca" />

                        <TextView
                            android:id="@+id/so_model_val"
                            style="@style/TextAppearance.Material3.BodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:ellipsize="end"
                            android:maxEms="5"
                            android:maxLines="1"
                            android:textColor="@color/m3_namoa_onSurfaceVariant"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/so_color_val"
                            app:layout_constraintHorizontal_bias="0.5"
                            app:layout_constraintStart_toEndOf="@+id/so_brand_val"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="Modelo" />

                        <TextView
                            android:id="@+id/so_color_val"
                            style="@style/TextAppearance.Material3.BodySmall"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/m3_namoa_onSurfaceVariant"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/so_model_val"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="Cor" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/so_tracking_val"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                        android:visibility="gone"
                        tools:text="LISTA | TRACKINGS " />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />
                </LinearLayout>
            </LinearLayout>


            <TextView
                android:id="@+id/so_so_id_val"
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                android:visibility="gone"
                tools:text="MY-OS.XXX" />

            <TextView
                android:id="@+id/so_segment_category_val"
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                android:visibility="gone"
                tools:text="Usados | Carro pequeno" />

            <TextView
                android:id="@+id/so_pipeline_val"
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                android:visibility="gone"
                tools:text="JGA" />


            <LinearLayout
                android:id="@+id/so_express_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/m3_namoa_outlineVariant" />

                <TextView
                    android:id="@+id/so_express_pack_service_list"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="5dp"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    tools:text="teste" />
                
            </LinearLayout>

            <LinearLayout
                android:id="@+id/so_service_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />

                <TextView
                    android:id="@+id/so_service_first"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    tools:text="Um Texto" />

            </LinearLayout>
            
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/so_create_date_val"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="textEnd"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="00:00" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>