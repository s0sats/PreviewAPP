<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_margin="20dp"
    android:orientation="vertical">

    <CheckBox
        android:id="@+id/schedule_filter_chk_site_logged"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        tools:text="Apenas Site Logado - trad" />

    <CheckBox
        android:id="@+id/schedule_filter_chk_n_form"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:checked="true"
        tools:text="N-Form - trad" />

    <CheckBox
        android:id="@+id/schedule_filter_chk_n_form_ap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:checked="true"
        tools:text="N-Form AP - trad" />

    <CheckBox
        android:id="@+id/schedule_filter_chk_n_ticket"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:checked="true"
        tools:text="N - Ticket" />

</LinearLayout>