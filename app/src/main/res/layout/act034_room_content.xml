<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="5dp">

    <LinearLayout
        android:id="@+id/act034_room_ll_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="visible">

        <TextView
            android:id="@+id/act034_room_tv_others_customers_msg_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="10dp"
            android:text="Mensagens de outros Customers - traduzir"
            android:textSize="@dimen/font_size_item" />

        <TextView
            android:id="@+id/act034_room_tv_others_customers_msg_qty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:background="@drawable/badge_chat"
            android:gravity="center"
            android:paddingBottom="3dp"
            android:paddingLeft="5dp"
            android:paddingRight="6dp"
            android:paddingTop="3dp"
            android:text=" 5 "
            android:textColor="@color/padrao_WHITE"
            android:textSize="@dimen/font_size_item" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ListView
            android:id="@+id/act034_room_lv_msg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@color/padrao_TRANSPARENT"
            android:dividerHeight="5dp" />

        <TextView
            android:id="@+id/act034_room_tv_no_result"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="@dimen/font_size_title_md" />

    </FrameLayout>

</LinearLayout>
