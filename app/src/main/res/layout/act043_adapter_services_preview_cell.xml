<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/act043_adapter_services_preview_cell_ll_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="10dp"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:paddingTop="10dp">
        <!--android:background="@drawable/namoa_cell_9_states"-->

        <ImageView
            android:id="@+id/act043_adapter_services_preview_cell_iv_type"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_archive_black_24dp"
            android:tint="@color/namoa_color_dark_blue"
            android:layout_gravity="center_vertical"
            />

        <View
            android:layout_width="5dp"
            android:layout_height="match_parent"/>

        <TextView
            android:id="@+id/act043_adapter_services_preview_cell_tv_service_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="1dp"
            android:text="Status"
            android:textColor="@color/lib_custom_cell_font_color"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/act043_adapter_services_preview_cell_tv_service_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="1dp"
            android:text="66.666"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold" />
        <View
            android:layout_width="5dp"
            android:layout_height="match_parent"/>

        <ImageView
            android:id="@+id/act043_adapter_services_preview_cell_iv_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:tint="@color/namoa_color_dark_blue"
            android:src="@drawable/ic_edit_black_24dp"
            android:layout_gravity="center_vertical"
            />

    </LinearLayout>
</LinearLayout>