<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act036.Act036_Main"
    tools:showIn="@layout/act036_main">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/act036_btn_load"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:background="@drawable/namoa_cell_2_states"
            android:gravity="left"
            android:padding="20dp"
            android:text="Carregar o.s"
            android:textColor="@color/padrao_WHITE"
            android:visibility="gone" />

        <Button
            android:id="@+id/act036_btn_pendencies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:background="@drawable/namoa_cell_2_states"
            android:gravity="left"
            android:padding="20dp"
            android:text="Pendentes (14) "
            android:textColor="@color/padrao_WHITE"
            android:visibility="visible" />

        <Button
            android:id="@+id/act036_btn_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:background="@drawable/namoa_cell_2_states"
            android:gravity="left"
            android:padding="20dp"
            android:text="Syncs (14) "
            android:textColor="@color/padrao_WHITE" />

    </LinearLayout>

    <include layout="@layout/footer_base" />

</LinearLayout>
