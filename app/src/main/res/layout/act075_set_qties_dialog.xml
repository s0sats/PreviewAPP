<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/act075_dialog_set_qty_lbl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        tools:text="TextView"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.namoa_digital.namoa_library.ctls.MKEditTextNM
        android:id="@+id/act075_dialog_set_mkedt_qty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:ems="10"
        android:inputType="text"
        app:mInputType="NUMBER"
        app:mDecimal="4"
        app:mOCR="false"
        app:mOCRVin="false"
        app:mBARCODE="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/act075_dialog_set_qty_lbl"
        app:layout_constraintStart_toStartOf="@+id/act075_dialog_set_qty_lbl"
        app:layout_constraintTop_toBottomOf="@+id/act075_dialog_set_qty_lbl" />

</android.support.constraint.ConstraintLayout>