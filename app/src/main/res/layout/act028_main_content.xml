<?xml version="1.0" encoding="utf-8"?>
<android.support.v4.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/act028_drawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act028.Act028_Main"
    tools:openDrawer="start"
    tools:showIn="@layout/act028_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">


        <LinearLayout
            android:id="@+id/act028_main_llist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <fragment
                android:id="@+id/act028_list"
                android:name="com.namoadigital.prj001.ui.act028.Act028_Task_List"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                tools:layout="@layout/act028_opc_content" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/act028_main_ltask"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <fragment
                android:id="@+id/act028_lt"
                android:name="com.namoadigital.prj001.ui.act028.Act028_Task"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                tools:layout="@layout/act028_opc_content" />

        </LinearLayout>


        <include layout="@layout/footer_base" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:clickable="true"
        android:orientation="vertical">

        <fragment
            android:id="@+id/act028_opc"
            android:name="com.namoadigital.prj001.ui.act028.Act028_Opc"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:layout="@layout/act028_opc_content" />

    </LinearLayout>

</android.support.v4.widget.DrawerLayout>