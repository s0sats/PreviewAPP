<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:gravity="center_vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act074.Act074_Main"
    tools:showIn="@layout/act074_main">

    <android.support.constraint.ConstraintLayout
        android:id="@+id/act074_cl_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintTop_toTopOf="parent">

        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
            android:id="@+id/act074_mket_filter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Search Desc - Trad"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            app:mBARCODE="false"
            app:mNFC="false"
            app:mOCR="false" />

        <android.support.design.widget.TabLayout
            android:id="@+id/act074_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act074_mket_filter"
            app:tabIndicatorColor="@color/namoa_amount_pipeline_background_btn"
            app:tabSelectedTextColor="@color/namoa_amount_pipeline_background_btn"
            app:tabTextColor="@color/namoa_pipeline_header_icon">

            <android.support.design.widget.TabItem
                android:id="@+id/act074_tab_my_tickets"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                tools:text="MEUS TICKETS" />

            <android.support.design.widget.TabItem
                android:id="@+id/act074_tab_other_tickets"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                tools:text="OUTROS" />

        </android.support.design.widget.TabLayout>

        <TextView
            android:id="@+id/act074_tv_no_result"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/act074_mket_filter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="NENHUM ITEM ENCONTRADO"
            android:gravity="center"
            android:visibility="gone"
            />

        <android.support.v7.widget.RecyclerView
            android:id="@+id/act074_rv_ticket_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="4dp"
            app:layoutManager="LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act074_tabs"
            app:layout_constraintVertical_bias="1.0"
            tools:listitem="@layout/act074_ticket_cell" />

    </android.support.constraint.ConstraintLayout>

    <include
        android:id="@+id/include"
        layout="@layout/footer_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/act074_cl_result" />
</android.support.constraint.ConstraintLayout>