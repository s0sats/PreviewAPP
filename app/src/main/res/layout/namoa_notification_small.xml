<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/hdr_notification"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    xmlns:tools="http://schemas.android.com/tools"
    android:weightSum="7"
    android:orientation="horizontal">


    <ImageView
        android:id="@+id/iv_location_placeholder"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:tint="@color/namoa_color_green_chat"
        android:layout_gravity="center"
        app:srcCompat="@drawable/ic_pin_drop_black_24dp" />

    <TextView
        android:id="@+id/tv_location_val"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:textSize="20sp"
        android:gravity="center"
        style="@style/TextAppearance.Compat.Notification.Info"
        tools:text="0" />

    <ImageView
        android:id="@+id/iv_file_upload_placeholder"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:tint="@color/namoa_color_green_chat"
        app:srcCompat="@drawable/ic_photo_size_select_actual_black_24dp" />

    <TextView
        android:id="@+id/tv_file_upload_val"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:textSize="20sp"
        android:gravity="center"
        style="@style/TextAppearance.Compat.Notification.Info"
        tools:text="0" />

    <ImageView
        android:id="@+id/iv_update_required_placeholder"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:tint="@color/namoa_color_green_chat"
        app:srcCompat="@drawable/ic_mail_black_24dp" />

    <TextView
        android:id="@+id/tv_update_required_val"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:textSize="20sp"
        android:gravity="center"
        style="@style/TextAppearance.Compat.Notification.Info"
        tools:text="0" />
</LinearLayout>