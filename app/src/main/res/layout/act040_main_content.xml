<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act040.Act040_Main"
    tools:showIn="@layout/act040_main">

    <ScrollView
        android:id="@+id/sv_main"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_last_order"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:visibility="gone"
                >
                <TextView
                    android:id="@+id/tv_log_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="28/10/2021 10:58"
                    android:textAlignment="center"
                    android:textColor="@color/namoa_color_gray_9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_serial_id" />

                <TextView
                    android:id="@+id/tv_last_order_ttl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    tools:text="Ultima expressa neste site e operacao"
                    android:textAlignment="center"
                    android:textColor="@color/my_action_gray_font"
                    android:textSize="@dimen/font_size_font_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_pack_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    tools:text="VFW/DW - Wasche"
                    android:textAlignment="center"
                    android:textColor="@color/namoa_color_gray_9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_last_order_ttl" />

                <TextView
                    android:id="@+id/tv_serial_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    tools:text="WABCEFGH20211126001"
                    android:textAlignment="center"
                    android:textColor="@color/namoa_color_gray_9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_pack_desc" />
            </androidx.constraintlayout.widget.ConstraintLayout>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/cl_last_order"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingBottom="24dp">

                <com.namoa_digital.namoa_library.ctls.SearchableSpinner
                    android:id="@+id/ss_partner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_pack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/ss_partner"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="16dp"
                    app:hintEnabled="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    app:helperTextTextAppearance="@style/TextInputLayoutHelperTextColorMainBlue"
                    android:background="@drawable/shape_error"
                    >

                    <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                        android:id="@+id/mket_pack"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:hint="Pacote"
                        android:inputType="text"
                        app:mBARCODE="true"
                        app:mNFC="false"
                        app:mOCR="false"
                        />

                </com.google.android.material.textfield.TextInputLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_serial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_pack"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/shape_error"
                    >
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_serial"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constrainedWidth="true"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/cl_serial_search"
                        app:hintEnabled="true"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        >
                        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                            android:id="@+id/mket_serial"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:inputType="text"
                            app:mBARCODE="true"
                            app:mNFC="false"
                            app:mOCR="false"
                            tools:text="ronaldo"
                            />

                    </com.google.android.material.textfield.TextInputLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_serial_search"
                        android:layout_width="42dp"
                        android:layout_height="48dp"
                        app:layout_constraintTop_toTopOf="@id/til_serial"
                        app:layout_constraintBottom_toBottomOf="@id/til_serial"
                        app:layout_constraintStart_toEndOf="@id/til_serial"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone"
                        app:layout_constraintVertical_bias="0.42"
                        >
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/cl_serial_search_btn"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:background="@drawable/my_action_toogle_default"
                            >

                            <ImageView
                                android:id="@+id/iv_serial_search_icon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_baseline_search_24"
                                app:tint="@color/namoa_outlined_button_font_states"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_add_info_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/cl_serial"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:hintEnabled="true"
                    android:layout_marginTop="16dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    tools:helperText="Billing info 1"
                    android:visibility="gone"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    >
                    <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                        android:id="@+id/mket_add_info_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        app:mBARCODE="true"
                        app:mNFC="false"
                        app:mOCR="false"
                        />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_add_info_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/til_add_info_1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:hintEnabled="true"
                    android:layout_marginTop="16dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    tools:helperText="Billing info 2"
                    android:visibility="gone"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    >
                    <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                        android:id="@+id/mket_add_info_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        app:mBARCODE="true"
                        app:mNFC="false"
                        app:mOCR="false"
                        />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_add_info_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/til_add_info_2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:hintEnabled="true"
                    android:layout_marginTop="16dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    tools:helperText="Billing info 3"
                    android:visibility="gone"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    >
                    <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                        android:id="@+id/mket_add_info_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        app:mBARCODE="true"
                        app:mNFC="false"
                        app:mOCR="false"
                        />
                </com.google.android.material.textfield.TextInputLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_add_pack_services"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_add_info_3">

                    <TextView
                        android:id="@+id/tv_service_list_lbl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:textColor="@color/namoa_color_dark_blue"
                        android:textSize="16sp"
                        app:layout_constraintBottom_toBottomOf="@+id/iv_add_pack_services"
                        app:layout_constraintEnd_toStartOf="@+id/iv_add_pack_services"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/iv_add_pack_services"
                        tools:text="Serviços/Pacotes Incluidos" />

                    <ImageView
                        android:id="@+id/iv_add_pack_services"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/my_action_toogle_default"
                        android:padding="8dp"
                        android:src="@drawable/ic_add_plus"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.0"
                        app:tint="@color/namoa_color_black" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_add_pack_services"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/iv_add_pack_services"
                        app:layout_constraintStart_toStartOf="@+id/tv_service_list_lbl"
                        app:layout_constraintTop_toBottomOf="@+id/iv_add_pack_services"
                        tools:listitem="@layout/cell_add_pack_services_item"
                        tools:itemCount="5"/>

                    <TextView
                        android:id="@+id/tv_add_pack_services_placeholder"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:textColor="@color/text_black"
                        android:visibility="invisible"
                        app:layout_constraintEnd_toEndOf="@+id/iv_add_pack_services"
                        app:layout_constraintStart_toStartOf="@+id/tv_service_list_lbl"
                        app:layout_constraintTop_toBottomOf="@+id/iv_add_pack_services"
                        tools:text="Lista sen itens" />

                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_hist"
                android:layout_width="42dp"
                android:layout_height="48dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_fields"
                >
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_hist_btn"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:background="@drawable/my_action_toogle_default"
                    >

                    <ImageView
                        android:id="@+id/iv_hist_icon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_schedule_black_24dp"
                        app:tint="@color/namoa_outlined_button_font_states"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_finalize"
                android:layout_width="0dp"
                android:layout_height="48dp"
                app:layout_constraintStart_toEndOf="@id/cl_hist"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_fields"
                android:layout_marginStart="8dp"
                >

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_finalize_btn"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:background="@drawable/namoa_button_light_green_states"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    >

                    <ImageView
                        android:id="@+id/iv_finalize_icon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_finalizar"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tv_finalize"
                        app:layout_constraintHorizontal_chainStyle="packed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/padrao_WHITE"
                        android:layout_marginEnd="8dp"
                        />

                    <TextView
                        android:id="@+id/tv_finalize"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintWidth_default="wrap"
                        android:textAllCaps="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iv_finalize_icon"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Finalizar"
                        android:textColor="@color/padrao_WHITE"
                        android:textStyle="bold"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <include
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/include"
        layout="@layout/footer_base"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
