<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/license_site_dialog_cl_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    >

    <android.support.design.widget.TextInputLayout
        android:id="@+id/license_site_dialog_til_filter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textColorHint="@color/namoa_dark_blue"
        app:boxStrokeColor="@color/namoa_dark_blue"
        >
        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
            android:id="@+id/license_site_dialog_et_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="hint"
            app:mOCRVin="false"
            app:mOCR="false"
            app:mBARCODE="false"
            app:mNFC="false"
            />
    </android.support.design.widget.TextInputLayout>

    <android.support.v7.widget.RecyclerView
        android:id="@+id/license_site_dialog_rv_sites"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintHeight_default="wrap"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@id/license_site_dialog_tv_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/license_site_dialog_til_filter"
        tools:itemCount="50"
        tools:listitem="@layout/license_site_dialog_row"
        />

    <TextView
        android:id="@+id/license_site_dialog_tv_close"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/border_gray"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="10dp"
        android:text="Fechar"
        android:textAllCaps="true"
        android:textColor="@color/namoa_status_pending"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</android.support.constraint.ConstraintLayout>