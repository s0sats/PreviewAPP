<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        >
        <ImageView
            android:id="@+id/schedule_notification_big_iv_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="5dp"
            android:src="@drawable/ic_warning_white_24dp"
            android:tint="@color/namoa_color_orange"
            android:layout_gravity="top|center_horizontal"

            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/schedule_notification_big_date_start"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="25/03/2020"
                style="@style/TextAppearance.Compat.Notification.Title"
                android:padding="2dp"
                />

            <TextView
                android:id="@+id/schedule_notification_big_desc"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="1dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textStyle="bold"
                tools:text="1000 horas"
                style="@style/TextAppearance.Compat.Notification.Title"
                android:padding="2dp"
                />

            <TextView
                android:id="@+id/schedule_notification_big_cur_status_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                tools:text="Current Status:"
                style="@style/TextAppearance.Compat.Notification.Title"
                />

            <TextView
                android:id="@+id/schedule_notification_big_cur_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:padding="2dp"
                tools:text="PENDING"
                style="@style/TextAppearance.Compat.Notification.Info"
                />

            <TextView
                android:id="@+id/schedule_notification_big_new_status_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                tools:text="New Status"
                style="@style/TextAppearance.Compat.Notification.Title"/>

            <TextView
                android:id="@+id/schedule_notification_s_new_status_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:padding="2dp"
                tools:text="Cancelled"
                style="@style/TextAppearance.Compat.Notification.Info"/>

            <TextView
                android:id="@+id/schedule_notification_big_user_nick_lbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                tools:text="User:"
                style="@style/TextAppearance.Compat.Notification.Title"
                />

            <TextView
                android:id="@+id/schedule_notification_big_user_nick_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:padding="2dp"
                tools:text="Luche(52)"
                style="@style/TextAppearance.Compat.Notification.Info"/>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>