<?xml version="1.0" encoding="utf-8"?>


<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">

    <android.support.constraint.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/namoa_cell_8">

        <ImageView
            android:id="@+id/act052_main_iv_offline_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/act052_tv_io_status_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/act052_tv_io_status_desc"
            app:srcCompat="@drawable/ic_signal_wifi_off_black_24dp" />

        <TextView
            android:id="@+id/act052_tv_io_status_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:text="TextView"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/act052_tv_io_status_icon"
            app:layout_constraintStart_toEndOf="@+id/act052_main_iv_offline_mode"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/act052_tv_io_status_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/act052_tv_io_status_desc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/act052_tv_io_status_desc" />

        <TextView
            android:id="@+id/act052_tv_io_product_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="Product - trad"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/act052_tv_serial_list_position"
            app:layout_constraintTop_toBottomOf="@+id/act052_tv_io_status_desc" />

        <TextView
            android:id="@+id/act052_tv_io_product_ext_code_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            android:text="TextView"
            app:layout_constraintStart_toStartOf="@+id/act052_tv_io_product_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act052_tv_io_product_lbl" />

        <TextView
            android:id="@+id/act052_tv_io_product_desc_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TextView"
            app:layout_constraintBottom_toBottomOf="@+id/act052_tv_io_product_ext_code_val"
            app:layout_constraintStart_toEndOf="@+id/textView"
            app:layout_constraintTop_toTopOf="@+id/act052_tv_io_product_ext_code_val" />


        <TextView
            android:id="@+id/act052_tv_io_serial_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="Serial - trad"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/act052_tv_serial_list_position"
            app:layout_constraintTop_toBottomOf="@+id/act052_tv_io_product_ext_code_val" />

        <TextView
            android:id="@+id/act052_tv_io_serial_ext_code_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:text="Ext Code: - trad"
            app:layout_constraintStart_toStartOf="@+id/act052_tv_io_serial_lbl"
            app:layout_constraintTop_toBottomOf="@+id/act052_tv_io_serial_lbl" />

        <TextView
            android:id="@+id/act052_tv_io_serial_ext_code_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="TextView"
            app:layout_constraintBottom_toBottomOf="@+id/act052_tv_io_serial_ext_code_lbl"
            app:layout_constraintStart_toEndOf="@+id/act052_tv_io_serial_ext_code_lbl"
            app:layout_constraintTop_toTopOf="@+id/act052_tv_io_serial_ext_code_lbl" />

        <TextView
            android:id="@+id/act052_tv_io_serial_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="31dp"
            android:text="Marca | Modelo | Cor"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act052_tv_io_serial_ext_code_lbl" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" - "
            app:layout_constraintBottom_toBottomOf="@+id/act052_tv_io_product_desc_val"
            app:layout_constraintStart_toEndOf="@+id/act052_tv_io_product_ext_code_val"
            app:layout_constraintTop_toTopOf="@+id/act052_tv_io_product_desc_val" />

        <TextView
            android:id="@+id/act052_tv_serial_list_position"
            android:layout_width="25dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="100"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act052_tv_io_serial_zone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:text="Zona - trad"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act052_tv_io_serial_desc" />

        <TextView
            android:id="@+id/act052_tv_io_serial_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:text="Posição - trad "
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/act052_tv_io_serial_desc" />

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>
