<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Material3.CardView.Filled"
    android:elevation="0dp"
    android:id="@+id/serial_site_item_card"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    android:minHeight="80dp"
    app:cardBackgroundColor="@color/m3_namoa_neutral95"
    app:cardCornerRadius="12dp"
    android:layout_marginVertical="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingStart="20dp">

        <ImageView
            android:id="@+id/iconSerialColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="null"
            android:src="@drawable/ic_baseline_arrow_right_24"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@+id/serial_site_item_tv_serial_id"
            app:layout_constraintEnd_toStartOf="@+id/serial_site_item_tv_serial_id"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/serial_site_item_tv_serial_id"
            app:tint="@color/text_black" />

        <TextView
            android:id="@+id/serial_site_item_tv_serial_id"
            style="@style/TextAppearance.Material3.TitleLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/m3_namoa_onSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/iconSerialColor"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="SERIAL NAME" />

        <TextView
            android:id="@+id/product_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_serial_id"
            tools:text="TextView" />

        <TextView
            android:id="@+id/serial_site_item_tv_brand_model_color"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/product_desc"
            tools:text="TextView" />

        <TextView
            android:id="@+id/serial_site_item_tv_trackings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/m3_namoa_onSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_brand_model_color"
            tools:text="TextView" />

        <TextView
            android:id="@+id/serial_site_item_tv_last_measure_lbl"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/m3_namoa_onSurface"
            app:layout_constraintEnd_toEndOf="@+id/serial_site_item_tv_last_measure_val"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_trackings"
            tools:text="TextView" />

        <TextView
            android:id="@+id/serial_site_item_tv_last_measure_val"
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/m3_namoa_onSurface"
            app:layout_constraintEnd_toStartOf="@+id/guideline8"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_last_measure_lbl"
            tools:text="TextView" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline8"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintGuide_percent="0.5"
            app:layout_constraintStart_toStartOf="parent" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/serial_site_item_ll_items_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
            app:layout_constraintEnd_toStartOf="@+id/guideline8"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_last_measure_val"
            app:layout_constraintVertical_bias="0.0">

            <ImageView
                android:id="@+id/iv_tag"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_tag_black_24dp"
                app:layout_constraintEnd_toStartOf="@+id/tv_tag_val"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/m3_namoa_onSurfaceVariant" />

            <TextView
                android:id="@+id/tv_tag_val"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                app:layout_constraintEnd_toStartOf="@+id/iv_item_alert"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/iv_tag"
                app:layout_constraintTop_toTopOf="@id/iv_tag"
                app:layout_constraintWidth_default="wrap"
                tools:text="99" />

            <ImageView
                android:id="@+id/iv_item_alert"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/circle_item"
                app:layout_constraintEnd_toStartOf="@+id/tv_item_alert_val"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/tv_tag_val"
                app:layout_constraintTop_toTopOf="@id/iv_tag"
                app:tint="@color/namoa_os_form_problem_red" />

            <TextView
                android:id="@+id/tv_item_alert_val"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                app:layout_constraintEnd_toStartOf="@+id/iv_item_critical"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/iv_item_alert"
                app:layout_constraintTop_toTopOf="@id/iv_item_alert"
                app:layout_constraintWidth_default="wrap"
                tools:text="99" />


            <ImageView
                android:id="@+id/iv_item_critical"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/circle_item"
                app:layout_constraintEnd_toStartOf="@+id/tv_item_critical_val"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/tv_item_alert_val"
                app:layout_constraintTop_toTopOf="@id/iv_item_alert"
                app:tint="@color/namoa_os_form_critical_forecast_yellow" />

            <TextView
                android:id="@+id/tv_item_critical_val"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="4dp"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/iv_item_critical"
                app:layout_constraintTop_toTopOf="@id/iv_item_critical"
                app:layout_constraintWidth_default="wrap"
                tools:text="99" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/serial_site_item_tv_last_cycle_lbl"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/m3_namoa_onSurface"
            app:layout_constraintEnd_toEndOf="@+id/serial_site_item_tv_last_cycle_val"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/guideline8"
            app:layout_constraintTop_toTopOf="@+id/serial_site_item_tv_last_measure_lbl"
            tools:text="TextView" />

        <TextView
            android:id="@+id/serial_site_item_tv_last_cycle_val"
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/m3_namoa_onSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/guideline8"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_last_cycle_lbl"
            tools:text="TextView" />

        <TextView
            android:id="@+id/serial_site_item_tv_next_cycle_lbl"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/m3_namoa_onSurface"
            app:layout_constraintEnd_toEndOf="@+id/serial_site_item_tv_next_cycle_val"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/guideline8"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_last_cycle_val"
            tools:text="TextView" />

        <TextView
            android:id="@+id/serial_site_item_tv_next_cycle_val"
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/m3_namoa_onSurface"
            app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/guideline8"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_next_cycle_lbl"
            app:layout_constraintVertical_bias="1.0"
            tools:text="TextView" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_buttons_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:gravity="end"
            android:paddingTop="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/serial_site_item_tv_next_cycle_val">


            <com.google.android.material.button.MaterialButton
                android:id="@+id/act083_serial_info"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="12dp"
                android:textColor="@color/m3_namoa_primary"
                app:icon="@drawable/ic_outline_info_24"
                app:layout_constrainedWidth="true"
                app:layout_constraintEnd_toStartOf="@+id/my_action_select_serial"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_default="wrap"
                app:strokeColor="@color/m3_namoa_outline"
                tools:text="Status" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/my_action_select_serial"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/m3_namoa_primary"
                app:icon="@drawable/ic_tag_black_24dp"
                app:layout_constrainedWidth="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/act083_serial_info"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_default="wrap"
                app:strokeColor="@color/m3_namoa_outline"
                tools:text="Ver Ações" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>