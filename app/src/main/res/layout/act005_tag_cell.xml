<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tv_tag_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:textSize="16sp"
        android:singleLine="true"
        tools:text="TextVieasdasddddddddddddddddddddddddddddddddddddddddddddddddddddddddw"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@+id/iv_tag_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/ll_tag_qty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/iv_tag_status"
        app:layout_constraintStart_toStartOf="@+id/tv_tag_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_tag_name">

        <TextView
            android:id="@+id/tv_tag_qty"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:text="TextView"
            android:textColor="@color/gray_colors_menu"
             />
        <ImageView
            android:id="@+id/iv_tag_qty_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_person_black_24dp"
            />
        <TextView
            android:id="@+id/tv_tag_qty_user"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:text="TextView"
            android:textColor="@color/gray_colors_menu"
            />

        <ImageView
            android:id="@+id/iv_tag_qty_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_baseline_group_24_black"
            />
        <TextView
            android:id="@+id/tv_tag_qty_group"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:text="TextView"
            android:textColor="@color/gray_colors_menu"
            />
        <ImageView
            android:id="@+id/iv_tag_qty_other"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_person_off"
            />
        <TextView
            android:id="@+id/tv_tag_qty_other"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:text="TextView"
            android:textColor="@color/gray_colors_menu"
            />

    </LinearLayout>


    <ImageView
        android:id="@+id/iv_tag_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/ll_tag_qty"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_tag_name" />

</androidx.constraintlayout.widget.ConstraintLayout>