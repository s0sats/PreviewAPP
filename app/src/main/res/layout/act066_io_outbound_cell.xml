<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp">

    <android.support.constraint.ConstraintLayout
        android:id="@+id/act066_main_cl_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/namoa_cell_8_states"
        android:paddingBottom="8dp"
        >

        <android.support.constraint.Guideline
            android:id="@+id/act066_io_outbound_cell_guide_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_begin="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.Guideline
            android:id="@+id/act066_io_outbound_cell_guide_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="8dp"
            app:layout_constraintTop_toTopOf="parent" />

        <CheckBox
            android:id="@+id/act066_io_outbound_cell_chk_download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_pv_done"
            app:layout_constraintEnd_toStartOf="@id/act066_io_outbound_cell_iv_offline"
            app:layout_constraintStart_toStartOf="@id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/act066_io_outbound_cell_iv_offline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:padding="5dp"
            android:src="@drawable/ic_signal_wifi_off_black_24dp"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_pv_done"
            app:layout_constraintStart_toEndOf="@id/act066_io_outbound_cell_chk_download"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:text="STATUS - trad"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_pv_done"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_pv_done"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_iv_offline"
            app:layout_constraintTop_toTopOf="parent"
            android:gravity="center"
            />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID - Trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_pv_done" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_id_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="2019.Trad"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_id"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_id"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_id" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Desc - Trad"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="@+id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_tv_id_val" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_desc_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="Desc"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_desc"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_desc"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_desc" />

        <az.plainpie.PieView
            android:id="@+id/act066_io_outbound_cell_pv_done"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="@id/act066_io_outbound_cell_guide_end"
            app:layout_constraintTop_toTopOf="parent"
            app:percentage="50"
            app:percentage_size="12"
            />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_create_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Data: - Trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_tv_desc_val" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_create_date_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="99/99/9999"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_create_date"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_create_date"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_create_date"
            app:layout_constraintVertical_bias="0.0" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_eta_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="ETA: - Trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_tv_create_date_val" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_eta_date_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="99/99/9999"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_eta_date"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_eta_date"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_eta_date" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_invoice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Invoice: -Trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_tv_eta_date_val" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_invoice_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="666 - trad"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_invoice"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_invoice"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_invoice" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_to"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="From: -Trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_tv_invoice_val" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_to_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="FromH - trad"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_to"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_to"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_to" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_modal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Modal - Trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_tv_to_val" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_modal_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="Aereo - Trad"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_modal"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_modal"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_modal" />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_comment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Commets: - trad"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/act066_io_outbound_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act066_io_outbound_cell_tv_modal_val"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="8dp"
            />

        <TextView
            android:id="@+id/act066_io_outbound_cell_tv_comment_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="Comments - trad"
            app:layout_constraintBottom_toBottomOf="@+id/act066_io_outbound_cell_tv_comment"
            app:layout_constraintEnd_toStartOf="@+id/act066_io_outbound_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/act066_io_outbound_cell_tv_comment"
            app:layout_constraintTop_toTopOf="@+id/act066_io_outbound_cell_tv_comment"
            />

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>
