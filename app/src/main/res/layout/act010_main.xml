<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.act010.Act010_Main">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:outlineProvider="none"
        android:theme="@style/AppTheme.AppBarOverlay"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:elevation="0dp"
            app:popupTheme="@style/AppTheme.PopupOverlay"
            app:titleTextColor="@color/m3_namoa_onSurface"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:navigationIconTint="@color/m3_namoa_onSurface"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/m3_namoa_surface1" />

    </com.google.android.material.appbar.AppBarLayout>

    <include
        android:id="@+id/act010_main_content"
        layout="@layout/act010_main_content" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
