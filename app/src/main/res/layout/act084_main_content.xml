<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.act084.Act084Main"
    tools:showIn="@layout/act084_main"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    >
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/act084_cl_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/act084_cv_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            app:cardElevation="10dp"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/act084_cg_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:paddingTop="2dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="8dp"
                    >

<!--                    <TextView-->
<!--                        android:id="@+id/act084_tv_filter1"-->
<!--                        style="@style/TextViewChips"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="200.SHOPPING" />-->


                </com.google.android.material.chip.ChipGroup>

                <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                    android:id="@+id/act084_mket_filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:hint="Search Desc - Trad"
                    android:inputType="text"
                    app:layout_constraintEnd_toStartOf="@id/act084_chk_nc_filter"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act084_cg_filter"
                    app:mBARCODE="false"
                    app:mNFC="false"
                    app:mOCR="false" />

                <CheckBox
                    android:id="@+id/act084_chk_nc_filter"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@drawable/namoa_ic_nc_states"
                    app:layout_constraintTop_toTopOf="@id/act084_mket_filter"
                    app:layout_constraintBottom_toBottomOf="@id/act084_mket_filter"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="8dp"
                    />

                <RadioGroup
                    android:id="@+id/act084_tabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act084_mket_filter">

                    <RadioButton
                        android:id="@+id/act084_tab_my_actions"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/act074_radio_states"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:textColor="@color/my_tickets_radio"
                        tools:text="concluidos"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="match_parent" />

                    <RadioButton
                        android:id="@+id/act084_tab_other_actions"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/act074_radio_states"
                        android:button="@null"
                        android:gravity="center"
                        android:textColor="@color/my_tickets_radio"
                        tools:text="descartados"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        />

                </RadioGroup>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/act084_tv_no_result"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act084_cv_header"
            tools:text="NENHUM ITEM ENCONTRADO" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/act084_rv_actions_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            app:layoutManager="LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act084_cv_header"
            app:layout_constraintVertical_bias="1.0"
            tools:itemCount="4"
            tools:listitem="@layout/my_actions_item" />

        <ProgressBar
            android:id="@+id/act084_pb_load"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:indeterminateTint="@color/namoa_amount_pipeline_background_btn"
            android:indeterminateTintMode="src_in"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@+id/act084_rv_actions_list"
            app:layout_constraintEnd_toEndOf="@+id/act084_rv_actions_list"
            app:layout_constraintStart_toStartOf="@+id/act084_rv_actions_list"
            app:layout_constraintTop_toBottomOf="@+id/act084_cv_header"
            app:layout_constraintVertical_bias="0.2"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/include"
        layout="@layout/footer_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>