<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp">

    <TextView
        android:id="@+id/my_actions_item_tv_code"
        style="@style/TextAppearance.Material3.BodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2022.1234"
        android:paddingEnd="10dp"
        android:textColor="@color/m3_namoa_onSurfaceVariant"
        android:gravity="end"
        android:paddingVertical="2dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/m3_namoa_surfaceVariant"
        android:id="@+id/my_actions_item_cl_infos"
        android:minHeight="80dp"
        android:elevation="0dp"
        style="@style/Widget.Material3.CardView.Filled">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/my_actions_item_iv_icon_left"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/my_actions_item_tv_planned_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:paddingBottom="2dp"
                        android:text="01/11/2022 22:00 - 02/11/2022 06:00"
                        style="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/m3_namoa_onSurfaceVariant" />

                    <TextView
                        android:id="@+id/my_actions_item_tv_done_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:paddingBottom="2dp"
                        android:text="01/11/2022 22:00 - 02/11/2022 06:00"
                        style="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/namoa_color_done_action_pressed" />

                    <TextView
                        android:id="@+id/my_actions_item_tv_site"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:text="Klabin Itajaí | Galpão 1"
                        style="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/m3_namoa_onSurfaceVariant" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/my_actions_item_iv_icon_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_baseline_cloud_done_24"
                    app:layout_constraintEnd_toStartOf="@+id/my_actions_item_iv_icon_mid"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="null" />


                <ImageView
                    android:id="@+id/my_actions_item_iv_icon_mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="null"
                    android:src="@drawable/ic_person_black_24dp"
                    app:layout_constraintEnd_toStartOf="@+id/my_actions_item_iv_icon_main_user"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/m3_namoa_secondary" />

                <ImageView
                    android:id="@+id/my_actions_item_iv_icon_main_user"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_person_black_24dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/m3_namoa_secondary"
                    android:contentDescription="null" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/serial_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:id="@+id/my_actions_item_iv_serial_class"
                        android:layout_width="24dp"
                        android:layout_height="match_parent"
                        android:padding="0dp"
                        android:visibility="visible"
                        android:src="@drawable/ic_baseline_arrow_right_24"
                        app:tint="#000000"
                        android:contentDescription="null" />

                    <TextView
                        android:id="@+id/my_actions_item_tv_serial_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SERIAL NAME"
                        style="@style/TextAppearance.Material3.TitleLarge"
                        android:textColor="@color/m3_namoa_onSurface" />

                </LinearLayout>

                <TextView
                    android:id="@+id/my_actions_item_tv_prod_desc"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Abertura de Chamado de Avaria"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    android:paddingVertical="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/m3_namoa_outline_variant" />

            </LinearLayout>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:id="@+id/my_actions_item_tv_tag_desc"
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="175dp"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="SERIAL NAME"
                    android:textColor="@color/m3_namoa_onSurface"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0" />

                <TextView
                    android:id="@+id/my_actions_item_tv_class_status"
                    style="@style/TextAppearance.Material3.LabelLarge"
                    android:layout_width="175dp"
                    android:layout_height="wrap_content"
                    android:text="Urgente"
                    android:textAlignment="textEnd"
                    android:textColor="@color/m3_namoa_error"
                    app:layout_constraintBottom_toBottomOf="@+id/my_actions_item_tv_tag_desc"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/my_actions_item_tv_tag_desc" />



            </androidx.constraintlayout.widget.ConstraintLayout>


            <TextView
                android:id="@+id/my_actions_item_tv_origin"
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Abertura de Chamado de Avaria"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/my_actions_item_tv_contract"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IN Avaliação de Avaria"
                android:textColor="@color/m3_namoa_onSurface"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/my_actions_item_tv_focus_step_desc"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Etapa: 2. Pedido de insumos"
                android:textColor="@color/m3_namoa_onSurface"
                android:paddingVertical="2dp" />


            <TextView
                android:id="@+id/my_actions_item_tv_internal_comments"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Etapa: 2. Pedido de insumos"
                android:textColor="@color/m3_namoa_onSurfaceVariant"
                android:paddingVertical="32dp" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end">


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/act083_serial_info"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="OK"
                    android:textColor="@color/m3_namoa_primary"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/my_action_select_serial"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0"
                    app:strokeColor="@color/m3_namoa_outline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/my_action_select_serial"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/m3_namoa_primary"
                    android:text="OK"
                    android:textColor="@color/m3_namoa_onPrimary"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/m3_namoa_outline" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>