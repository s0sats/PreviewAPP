<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_actions_item_cl_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginRight="5dp"
    android:layout_marginLeft="5dp"
    >

    <TextView
        android:id="@+id/my_actions_item_tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dp"
        tools:text="(Status)"
        android:textColor="@color/my_action_gray_font"
        android:textSize="8sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/my_actions_item_cl_infos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/namoa_cell_default_gray_states"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_status"
        android:paddingBottom="5dp"
        >

        <TextView
            android:id="@+id/my_actions_item_tv_contract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Contract Desc"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_client"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_client"
            android:visibility="gone"
            />

        <TextView
            android:id="@+id/my_actions_item_tv_os_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="O.S Code"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_contract"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_contract"
            android:visibility="gone"
            />

        <TextView
            android:id="@+id/my_actions_item_tv_site"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Site"
            android:textColor="@color/namoa_color_danger_red"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_focus_step_desc"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_focus_step_desc"
            android:visibility="gone"
            />

        <TextView
            android:id="@+id/my_actions_item_tv_focus_step_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Focus Step Desc"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_process_desc"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_process_desc" />

        <TextView
            android:id="@+id/my_actions_item_tv_client"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Client Desc"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_site"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_site"
            android:visibility="gone"
            />

        <ImageView
            android:id="@+id/my_actions_item_iv_icon_right"
            android:layout_width="@dimen/namoa_icon_cell_so_width"
            android:layout_height="@dimen/namoa_icon_cell_so_height"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_baseline_cloud_download_24_gray"
            />

        <TextView
            android:id="@+id/my_actions_item_tv_planned_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            tools:text="22/01/2020 14:50 - 23/01/2021 15:00"
            app:layout_constraintWidth_default="wrap"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/my_actions_item_iv_icon_right"
            app:layout_constraintEnd_toStartOf="@id/my_actions_item_iv_icon_left"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/my_actions_item_iv_icon_left"
            android:layout_width="@dimen/namoa_icon_cell_so_width"
            android:layout_height="@dimen/namoa_icon_cell_so_height"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/my_actions_item_iv_icon_right"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_twotone_warning_24" />

        <TextView
            android:id="@+id/my_actions_item_tv_tag_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Desc Tag"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/namoa_status_pending"
            android:layout_marginEnd="8dp"
            android:textAllCaps="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_planned_date"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_planned_date"
            
            />

        <TextView
            android:id="@+id/my_actions_item_tv_prod_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Desc Prod"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_planned_date"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_tag_desc" />

        <TextView
            android:id="@+id/my_actions_item_tv_serial_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="ID Serial"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_prod_desc"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_prod_desc" />

        <TextView
            android:id="@+id/my_actions_item_tv_origin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Origin Desc"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_prod_desc"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_serial_id"
            />

        <TextView
            android:id="@+id/my_actions_item_tv_process_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Process Desc"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_origin"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_origin" />

        <TextView
            android:id="@+id/my_actions_item_tv_error_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Site"
            android:textColor="@color/text_red"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_os_code"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_os_code"
            android:visibility="gone"
            />

        <TextView
            android:id="@+id/my_actions_item_tv_done_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/my_action_info_margin_top"
            tools:text="Done Date"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/my_actions_item_tv_error_msg"
            app:layout_constraintTop_toBottomOf="@id/my_actions_item_tv_error_msg"
            android:visibility="gone"
            android:textColor="@color/namoa_status_done"
            android:textStyle="bold"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/my_actions_item_tv_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dp"
        tools:text="2021.1.1"
        android:textColor="@color/my_action_gray_font"
        android:textSize="8sp"
        app:layout_constraintBottom_toBottomOf="@id/my_actions_item_tv_status"
        app:layout_constraintEnd_toStartOf="@id/my_actions_item_tv_status"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>