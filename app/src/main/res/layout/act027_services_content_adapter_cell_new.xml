<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/act027_services_content_cell_ll_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/namoa_cell_8"
    android:clickable="false"
    android:focusable="false"
    android:orientation="vertical"
    android:paddingBottom="15dp"
    android:paddingLeft="15dp"
    android:paddingRight="15dp"
    android:paddingTop="0dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="5dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/act027_services_content_cell_tv_exec_seq_oper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="5dp"
                android:layout_weight="1"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:text="1"
                android:textColor="@color/namoa_color_gray_4"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/act027_services_content_cell_iv_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_weight="1"
                android:src="@drawable/icon_engrenagens_ns"
                android:tint="@color/namoa_dark_blue"
                android:visibility="visible" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/act027_services_content_cell_tv_status"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Status"
                android:textSize="@dimen/font_size_item_md"
                android:textStyle="bold"
                android:visibility="visible" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:gravity="right"
            android:orientation="horizontal"
            android:paddingBottom="5dp">

            <ImageView
                android:id="@+id/act027_services_content_cell_btn_normal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:paddingBottom="4dp"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:paddingTop="4dp"
                android:src="@drawable/ic_pontos_ns" />
        </LinearLayout>


    </LinearLayout>


    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_service"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_service_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_service_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="17 - Lavagem"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_comment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_comment_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comment"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_comment_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Ronaldo"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_qty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_qty_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qty"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_qty_val"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="20/30 "
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:orientation="vertical"
            android:layout_gravity="center_vertical"
            >

            <LinearLayout
                android:id="@+id/act027_services_content_cell_ll_pack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_services_content_cell_tv_pack_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pack"
                    android:textSize="@dimen/font_size_item_md"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:id="@+id/act027_services_content_cell_tv_pack_val"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:gravity="left"
                    android:text="Pack id - Pack Desc" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/act027_services_content_cell_ll_zone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_services_content_cell_tv_zone_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Zone"
                    android:textSize="@dimen/font_size_item_md"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/act027_services_content_cell_tv_zone_val"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:gravity="left"
                    android:text="Zone id - Zone Desc" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/act027_services_content_cell_ll_partner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_services_content_cell_tv_partner_lbl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Partner"
                    android:textSize="@dimen/font_size_item_md"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:id="@+id/act027_services_content_cell_tv_partner_val"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:gravity="left"
                    android:text="Partner id - Partner Desc " />

            </LinearLayout>

        </LinearLayout>
        <View
            android:layout_width="5dp"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:id="@+id/act027_services_content_cell_ll_express"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:padding="2dp">

            <ImageView
                android:id="@+id/act027_services_content_cell_iv_express"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:focusable="false"
                android:src="@drawable/ic_escolher_ns"
                android:layout_gravity="center"
                />
        </LinearLayout>


    </LinearLayout>

</LinearLayout>