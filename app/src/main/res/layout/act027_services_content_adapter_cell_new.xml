<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/act027_services_content_cell_ll_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/namoa_cell_8_states"
    android:orientation="vertical"
    android:paddingBottom="15dp"
    android:paddingLeft="15dp"
    android:paddingRight="15dp"
    android:paddingTop="0dp"
    android:clickable="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView
                android:id="@+id/act027_services_content_cell_tv_exec_seq_oper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="10dp"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:text="1"
                android:textSize="@dimen/font_size_title_md"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/act027_services_content_cell_iv_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:src="@drawable/ic_flag_black_24dp"
                android:tint="@color/namoa_dark_blue"
                android:visibility="invisible" />


        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/act027_services_content_cell_btn_express"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_check_circle"
                android:tint="@color/namoa_dark_blue"
                android:background="@drawable/stroke_blue2_states"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingRight="15dp"
                android:paddingLeft="15dp"
                android:text="Ex" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:orientation="horizontal"
            android:gravity="right">
            <ImageView
                android:id="@+id/act027_services_content_cell_btn_normal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NO"
                android:src="@drawable/ic_transfer_24px_black"
                android:tint="@color/namoa_dark_blue"
                android:background="@drawable/stroke_blue2_states"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingRight="15dp"
                android:paddingLeft="15dp"/>
        </LinearLayout>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_pack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_pack_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pack"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_pack_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="right"
            android:text="Pack id - Pack Desc" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_zone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_zone_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zone"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_zone_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="right"
            android:text="Zone id - Zone Desc" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_comment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_comment_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comment"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_comment_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="right"
            android:text="Ronaldo" />

    </LinearLayout>
    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_partner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_partner_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Partner"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_partner_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="right"
            android:text="Partner id - Partner Desc " />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/act027_services_content_cell_ll_qty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/act027_services_content_cell_tv_qty_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qty"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/act027_services_content_cell_tv_qty_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="right"
            android:text="Done/Total " />

    </LinearLayout>

</LinearLayout>