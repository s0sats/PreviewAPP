<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/act027_approval_content_ll_main"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/act027_approval_content_tv_approval_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Approval"
            android:textSize="20sp"
            android:textStyle="bold" />


        <com.namoa_digital.namoa_library.ctls.ButtonNFC
            android:id="@+id/act027_approval_content_btn_nfc"
            style="@style/ButtonNFC_Style"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Approval NFC" />


        <Button
            android:id="@+id/act027_approval_content_btn_user_password"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/namoa_cell_2_states"
            android:padding="20dp"
            android:text="User / PassWord"
            android:textColor="@color/padrao_WHITE" />

    </LinearLayout>


</LinearLayout>