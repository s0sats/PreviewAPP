<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
    >

        <LinearLayout
            android:id="@+id/act027_approval_content_ll_so_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_approval_content_tv_so_id_lbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    android:text="SO ID"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="10dp"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_approval_content_tv_so_id_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:text="2017.1" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
                android:id="@+id/act027_approval_content_ll_serial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/act027_approval_content_tv_serial_lbl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:text="Serial - Trad"
                        android:textStyle="bold" />

            </LinearLayout>

            <View
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/act027_approval_content_tv_serial_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="ABCD - Trad" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/act027_approval_content_tv_so_approval_quality_type_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_weight="1"
            android:gravity="left"
            android:text="Aprovação Qualidade"
            android:textSize="@dimen/font_size_title_md"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/act027_approval_content_ll_quality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        </LinearLayout>

        <LinearLayout
            android:id="@+id/act027_approval_content_ll_quality_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/act027_approval_content_tv_client_approval_quality_user_nick_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="2dp"
                android:text="Client Approval User Nick"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act027_approval_content_tv_client_approval_quality_user_nick_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:enabled="false"
                android:padding="2dp"
                android:text="Nick"
                android:textColor="@color/lib_custom_cell_font_color" />

            <TextView
                android:id="@+id/act027_approval_content_tv_client_approval_quality_date_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="2dp"
                android:text="Client Approval Date"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act027_approval_content_tv_client_approval_quality_date_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:enabled="false"
                android:padding="2dp"
                android:text="Date"
                android:textColor="@color/lib_custom_cell_font_color" />

        </LinearLayout>


        <TextView
            android:id="@+id/act027_approval_content_tv_so_approval_type_lbl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_weight="1"
            android:gravity="left"
            android:text="Aprovação Final"
            android:textSize="@dimen/font_size_title_md"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/act027_approval_content_ll_final"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/act027_approval_content_tv_name_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Approval Name"
                android:textStyle="bold" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act027_approval_content_mk_name_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N.Hugo Android"
                android:textSize="@dimen/font_size_item_md"
                app:mBARCODE="false" />

            <TextView
                android:id="@+id/act027_approval_content_tv_name_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:enabled="false"
                android:padding="2dp"
                android:text="N.Hugo Android"
                android:textColor="@color/lib_custom_cell_font_color" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/act027_approval_content_ll_final_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/act027_approval_content_tv_client_approval_user_nick_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="2dp"
                android:text="Client Approval User Nick"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/act027_approval_content_tv_client_approval_user_nick_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:enabled="false"
                android:padding="2dp"
                android:text="Nick"
                android:textColor="@color/lib_custom_cell_font_color" />

        </LinearLayout>

        <LinearLayout
                android:id="@+id/act027_approval_content_ll_external_approval_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                    android:id="@+id/act027_approval_content_tv_client_external_approval_email_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="2dp"
                    android:text="Client Approval Email - Trad"
                    android:textStyle="bold" />

            <TextView
                    android:id="@+id/act027_approval_content_tv_client_external_approval_email_val"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:enabled="false"
                    android:padding="2dp"
                    android:text="Email@client.trad.com  - Trad"
                    android:textColor="@color/lib_custom_cell_font_color" />

        </LinearLayout>

        <LinearLayout
                android:id="@+id/act027_approval_content_ll_cliente_approval_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            <TextView
                    android:id="@+id/act027_approval_content_tv_client_approval_date_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="2dp"
                    android:text="Client Approval Date"
                    android:textStyle="bold" />

            <TextView
                    android:id="@+id/act027_approval_content_tv_client_approval_date_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:enabled="false"
                    android:padding="2dp"
                    android:text="Date"
                    android:textColor="@color/lib_custom_cell_font_color" />



        </LinearLayout>

        <LinearLayout
            android:id="@+id/act027_approval_content_ll_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <RadioGroup
                android:id="@+id/act027_approval_content_rg_opc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">


                <RadioButton
                    android:id="@+id/act027_approval_content_rb_user"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Eu" />


                <RadioButton
                    android:id="@+id/act027_approval_content_rb_other"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Outro" />

            </RadioGroup>

            <Button
                android:id="@+id/act027_approval_content_btn_approval_user"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/namoa_cell_2_states"
                android:padding="20dp"
                android:text="Approval"
                android:textColor="@color/padrao_WHITE" />

            <com.namoa_digital.namoa_library.ctls.ButtonNFC
                android:id="@+id/act027_approval_content_btn_nfc"
                style="@style/ButtonNFC_Style"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Approval NFC" />

            <Button
                android:id="@+id/act027_approval_content_btn_user_password"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/namoa_cell_2_states"
                android:padding="20dp"
                android:text="User / PassWord"
                android:textColor="@color/padrao_WHITE" />

            <Button
                android:id="@+id/act027_approval_content_btn_approval"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/namoa_cell_2_states"
                android:padding="20dp"
                android:text="Approval"
                android:textColor="@color/padrao_WHITE" />

        </LinearLayout>

        <ImageView
            android:id="@+id/act027_approval_content_iv_signature"
            android:layout_width="300dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>


</ScrollView>