<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/act027_approval_content_ll_so_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_approval_content_tv_so_id_lbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    android:text="SO ID"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="10dp"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_approval_content_tv_so_id_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:text="2017.1" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/act027_approval_content_tv_name_lbl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Approval Name"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/act027_approval_content_tv_name_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="N.Hugo Android" />


        <RadioGroup
            android:id="@+id/act027_approval_content_rg_opc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">


            <RadioButton
                android:id="@+id/act027_approval_content_rb_user"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Eu" />


            <RadioButton
                android:id="@+id/act027_approval_content_rb_other"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Outro" />

        </RadioGroup>

    </LinearLayout>


    <LinearLayout
        android:id="@+id/act027_approval_content_ll_main"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <com.namoa_digital.namoa_library.ctls.ButtonNFC
            android:id="@+id/act027_approval_content_btn_nfc"
            style="@style/ButtonNFC_Style"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Approval NFC" />


        <Button
            android:id="@+id/act027_approval_content_btn_user_password"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/namoa_cell_2_states"
            android:padding="20dp"
            android:text="User / PassWord"
            android:textColor="@color/padrao_WHITE" />


        <Button
            android:id="@+id/act027_approval_content_btn_approval"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/namoa_cell_2_states"
            android:padding="20dp"
            android:text="Approval"
            android:textColor="@color/padrao_WHITE" />


    </LinearLayout>


</LinearLayout>