                <TextView
                    android:id="@+id/act027_opc_tv_serial_add_info_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    tools:text="Serial  Add Info"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/act027_opc_tv_serial_add_info_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:textColor="@color/m3_namoa_onSurfaceVariant"
