                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:textColor="@color/m3_namoa_onSurfaceVariant"
                        tools:text="marca|modelo|cor" />

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/act027_opc_ll_tracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_tv_tracking_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:text="Tracking:"
