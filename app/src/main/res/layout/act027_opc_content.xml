<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:background="@drawable/btn_namoa_main_states"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:clickable="false"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">


    <LinearLayout
        android:id="@+id/act027_opc_ll_info"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="@drawable/btn_namoa_main_states"
        android:clickable="false"
        android:gravity="top"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/act027_opc_ll_info_prefix_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_namoa_main_states"
            android:clickable="false"
            android:paddingLeft="20dp"
            android:layout_marginTop="5dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/act027_opc_iv_info_prefix_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE"
                android:visibility="invisible" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_tv_prefix_code_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Prefix / Code"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_opc_tv_prefix_code_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2017 / 30"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:paddingLeft="20dp"
            android:layout_marginTop="5dp"

            android:id="@+id/act027_opc_ll_info_product_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_namoa_main_states"
            android:clickable="false"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/act027_opc_iv_info_product_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE"
                android:visibility="invisible" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_tv_product_id_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Product ID"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_opc_tv_product_id_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="300"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:paddingLeft="20dp"
            android:layout_marginTop="5dp"

            android:id="@+id/act027_opc_ll_info_product_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_namoa_main_states"
            android:clickable="false"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/act027_opc_iv_info_product_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE"
                android:visibility="invisible" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_desc_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Product Description"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_opc_tv_desc_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ful Productive Descripiton."
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:paddingLeft="20dp"
            android:layout_marginTop="5dp"
            android:id="@+id/act027_opc_ll_info_product_serial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_namoa_main_states"
            android:clickable="false"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/act027_opc_iv_info_product_serial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE"
                android:visibility="invisible" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_serial_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Product Serial"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_opc_tv_serial_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Serial"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:paddingLeft="20dp"
            android:layout_marginTop="5dp"

            android:id="@+id/act027_opc_ll_info_product_deadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_namoa_main_states"
            android:clickable="false"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/act027_opc_iv_info_product_deadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE"
                android:visibility="invisible" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_deadline_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dead Line"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_opc_tv_deadline_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="01/01/2017"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:paddingLeft="20dp"
            android:layout_marginTop="5dp"

            android:id="@+id/act027_opc_ll_info_product_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_namoa_main_states"
            android:clickable="false"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/act027_opc_iv_info_product_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE"
                android:visibility="invisible" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_status_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_opc_tv_status_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DONE"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:paddingLeft="20dp"
            android:layout_marginTop="5dp"

            android:id="@+id/act027_opc_ll_info_product_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_namoa_main_states"
            android:clickable="false"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/act027_opc_iv_info_product_priority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:maxHeight="24dp"
                android:maxWidth="24dp"
                android:src="@drawable/ic_power_settings_new_black_24dp"
                android:tint="@color/padrao_WHITE"
                android:visibility="invisible" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act027_opc_priority_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Priority"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

                <TextView
                    android:id="@+id/act027_opc_tv_priority_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TOP"
                    android:textColor="@color/padrao_WHITE"
                    android:textSize="@dimen/font_size_title" />

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:clickable="false"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="10dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/padrao_WHITE" />

            <LinearLayout
                android:id="@+id/act027_opc_ll_services"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_namoa_main_states"
                android:clickable="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/act027_opc_iv_services"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:maxHeight="24dp"
                    android:maxWidth="24dp"
                    android:src="@drawable/ic_power_settings_new_black_24dp"
                    android:tint="@color/padrao_WHITE" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/act027_opc_tv_services_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:text="Services"
                        android:textColor="@color/padrao_WHITE"
                        android:textSize="@dimen/font_size_title" />

                    <TextView
                        android:id="@+id/act027_opc_tv_services_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:text="Services"
                        android:textColor="@color/padrao_WHITE"
                        android:textSize="@dimen/font_size_title"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/padrao_WHITE" />


            <LinearLayout
                android:id="@+id/act027_opc_ll_serial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_namoa_main_states"
                android:clickable="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/act027_opc_iv_serial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:maxHeight="24dp"
                    android:maxWidth="24dp"
                    android:src="@drawable/ic_power_settings_new_black_24dp"
                    android:tint="@color/padrao_WHITE" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/act027_opc_tv_serial_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:text="Serial"
                        android:textColor="@color/padrao_WHITE"
                        android:textSize="@dimen/font_size_title" />

                    <TextView
                        android:id="@+id/act027_opc_tv_serial_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:text="Serial"
                        android:textColor="@color/padrao_WHITE"
                        android:textSize="@dimen/font_size_title"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/padrao_WHITE" />


            <LinearLayout
                android:id="@+id/act027_opc_ll_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_namoa_main_states"
                android:clickable="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/act027_opc_iv_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:maxHeight="24dp"
                    android:maxWidth="24dp"
                    android:src="@drawable/ic_power_settings_new_black_24dp"
                    android:tint="@color/padrao_WHITE" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/act027_opc_tv_header_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:text="Header"
                        android:textColor="@color/padrao_WHITE"
                        android:textSize="@dimen/font_size_title" />

                    <TextView
                        android:id="@+id/act027_opc_tv_header_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:text="Header"
                        android:textColor="@color/padrao_WHITE"
                        android:textSize="@dimen/font_size_title"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </LinearLayout>

</LinearLayout>

