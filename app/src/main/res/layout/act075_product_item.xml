<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/padrao_WHITE"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tv_product_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="8dp"
        tools:text="TextView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_planned"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_product_info"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gdl_planned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <TextView
            android:id="@+id/product_cell_tv_planned"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/gdl_planned"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="TextView" />

        <TextView
            android:id="@+id/product_cell_tv_planned_qty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="32dp"
            android:layout_marginRight="48dp"
            android:background="@color/padrao_WHITE"
            android:padding="4dp"
            android:textAlignment="center"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_tv_planned"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@+id/gdl_planned"
            app:layout_constraintTop_toTopOf="@+id/product_cell_tv_planned"
            tools:text="1 un" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_withdrawn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_planned"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gdl_withdrawn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <TextView
            android:id="@+id/product_cell_tv_withdrawn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_withdrawn_add"
            app:layout_constraintEnd_toStartOf="@+id/gdl_withdrawn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_withdrawn_add"
            tools:text="TextView" />

        <ImageView
            android:id="@+id/product_cell_iv_withdrawn_substract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/tk_product_amount_controllers"
            app:tint="@color/colorFooterWhite"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/gdl_withdrawn"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_remove_black_24dp" />

        <ImageView
            android:id="@+id/product_cell_iv_withdrawn_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/tk_product_amount_controllers"
            app:tint="@color/colorFooterWhite"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_withdrawn_substract"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_withdrawn_substract"
            app:srcCompat="@drawable/ic_add_black_24px" />

        <TextView
            android:id="@+id/product_cell_tv_withdrawn_qty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/padrao_WHITE"
            android:padding="4dp"
            android:textAlignment="center"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_withdrawn_add"
            app:layout_constraintEnd_toStartOf="@+id/product_cell_iv_withdrawn_add"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@+id/product_cell_iv_withdrawn_substract"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_withdrawn_add"
            tools:text="1 un" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_applied"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_withdrawn"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gdl_applied"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <TextView
            android:id="@+id/product_cell_tv_applied"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_applied_add"
            app:layout_constraintEnd_toStartOf="@+id/gdl_applied"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_applied_add"
            tools:text="TextView" />

        <ImageView
            android:id="@+id/product_cell_iv_applied_substract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/tk_product_amount_controllers"
            app:tint="@color/colorFooterWhite"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/gdl_applied"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_remove_black_24dp" />

        <ImageView
            android:id="@+id/product_cell_iv_applied_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/tk_product_amount_controllers"
            app:tint="@color/colorFooterWhite"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_applied_substract"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_applied_substract"
            app:srcCompat="@drawable/ic_add_black_24px" />

        <TextView
            android:id="@+id/product_cell_tv_applied_qty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/padrao_WHITE"
            android:padding="4dp"
            android:textAlignment="center"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_applied_add"
            app:layout_constraintEnd_toStartOf="@+id/product_cell_iv_applied_add"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@+id/product_cell_iv_applied_substract"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_applied_add"
            tools:text="1 un" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_returned"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_applied"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gdl_returned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <TextView
            android:id="@+id/product_cell_tv_returned"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_returned_add"
            app:layout_constraintEnd_toStartOf="@+id/gdl_returned"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_returned_add"
            tools:text="TextView" />


        <ImageView
            android:id="@+id/product_cell_iv_returned_substract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#FB9C0E"
            app:tint="@color/colorFooterWhite"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/gdl_returned"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_remove_black_24dp"
            tools:visibility="invisible" />


        <ImageView
            android:id="@+id/product_cell_iv_returned_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_check_white_24dp"
            app:tint="@color/namoa_product_extract_check"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_returned_substract"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_returned_substract" />

        <TextView
            android:id="@+id/product_cell_tv_returned_qty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/padrao_WHITE"
            android:padding="4dp"
            android:textAlignment="center"
            android:textColor="@color/namoa_pipeline_product_lbl"
            app:layout_constraintBottom_toBottomOf="@+id/product_cell_iv_returned_add"
            app:layout_constraintEnd_toStartOf="@+id/product_cell_iv_returned_add"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@+id/product_cell_iv_returned_substract"
            app:layout_constraintTop_toTopOf="@+id/product_cell_iv_returned_add"
            tools:text="1 un" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/product_cell_tv_extract"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        tools:text="TextView"
        android:textColor="@color/namoa_pipeline_extract"
        android:textAlignment="textEnd"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_returned" />
</androidx.constraintlayout.widget.ConstraintLayout>