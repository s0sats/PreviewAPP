<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act010.Act010_Main"
    tools:showIn="@layout/act010_main">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">
        <TextView
            android:id="@+id/act010_tv_form_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Form Type:"
            android:textSize="18sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/act010_tv_form_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="22 - huehue br"
            android:textSize="16sp"
            android:paddingLeft="10dp"
            />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="5dp">

        <ListView
            android:id="@+id/act010_lv_form"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:padding="5dp"
            android:divider="@color/padrao_TRANSPARENT"
            />

        <com.beardedhen.androidbootstrap.BootstrapButton
            android:id="@+id/act010_btn_back"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:bootstrapBrand="primary"
            app:bootstrapSize="lg"
            app:bootstrapText="Back"
            app:roundedCorners="true" />


    </LinearLayout>


    <include layout="@layout/footer_base" />

</LinearLayout>
