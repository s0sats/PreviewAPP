<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#a2636363"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act022.Act022_Main"
    tools:showIn="@layout/act022_main">


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_warning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        app:cardBackgroundColor="@color/m3_namoa_errorContainer"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/padrao_WHITE"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_qrcode_reader_ttl"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="LEIA NOVAMENTE O QRCODE PARA FINALIZAR" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_qrcode_reader"
                style="@style/NamoaTheme3.Button.Icon.Center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_qrcode_reader_ttl"
                android:paddingHorizontal="4dp"
                tools:text="LER QR CODE" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/NamoaTheme3.Button.Outlined.Center.Icon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_qrcode_reader"
                tools:text="Cancelar" />


            <com.namoa_digital.namoa_library.ctls.ButtonNFC
                android:id="@+id/btn_nfc_reader"
                style="@style/NamoaTheme3.Button.Outlined.Center.Icon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_nfc"
                app:layout_constraintBottom_toBottomOf="@+id/btn_cancel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@+id/btn_cancel"
                app:layout_constraintTop_toTopOf="@+id/btn_cancel"
                app:layout_constraintWidth_default="wrap"
                tools:text="Ler NFC" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include layout="@layout/footer_base" />
    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
