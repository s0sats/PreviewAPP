<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:background="@color/padrao_WHITE"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.namoa_digital.namoa_library.ctls.ButtonNFC
                android:id="@+id/frg_serial_search_btn_nfc_reader"
                style="@style/ButtonNFC_Style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NFC" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <TextView
                android:id="@+id/frg_serial_search_tv_product_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Prod Id"
                android:textSize="@dimen/font_size_title_md" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/frg_serial_search_mket_product_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:paddingLeft="10dp"
                app:mBARCODE="true"
                app:mNFC="false"
                app:mOCR="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <TextView
                android:id="@+id/frg_serial_search_tv_serial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Serial id"
                android:textSize="@dimen/font_size_title_md" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/frg_serial_search_mket_serial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:paddingLeft="10dp"
                app:mBARCODE="true"
                app:mNFC="false"
                app:mOCR="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <TextView
                android:id="@+id/frg_serial_search_tv_tracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Tracking N"
                android:textSize="@dimen/font_size_title_md" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/frg_serial_search_mket_tracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:paddingLeft="10dp"
                app:mBARCODE="true"
                app:mNFC="false"
                app:mOCR="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <Button
                android:id="@+id/frg_serial_search_btn_option_01"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:background="@drawable/namoa_cell_2_states"
                android:gravity="left"
                android:padding="20dp"
                android:text="Option 01"
                android:textColor="@color/padrao_WHITE" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <Button
                android:id="@+id/frg_serial_search_btn_option_02"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:background="@drawable/namoa_cell_2_states"
                android:gravity="left"
                android:padding="20dp"
                android:text="Option 02"
                android:textColor="@color/padrao_WHITE" />

            <View
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <Button
                android:id="@+id/frg_serial_search_btn_option_03"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:background="@drawable/namoa_cell_2_states"
                android:gravity="left"
                android:padding="20dp"
                android:text="Option 03"
                android:textColor="@color/padrao_WHITE" />




        </LinearLayout>

    </ScrollView>


</LinearLayout>

