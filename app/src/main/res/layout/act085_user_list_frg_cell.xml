<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginBottom="5dp"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:paddingBottom="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/namoa_cell_8_states">

        <ImageView
            android:id="@+id/act085_user_list_frg_cell_iv_photo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:maxWidth="200dp"
            android:maxHeight="200dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/act085_user_list_frg_cell_gd_start"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_baseline_account_box_24" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/act085_user_list_frg_cell_gd_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="8dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/act085_user_list_frg_cell_gd_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="8dp" />

        <TextView
            android:id="@+id/act085_user_list_frg_cell_tv_nick"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            tools:text="Zezin (666) - trad"
            app:layout_constraintEnd_toStartOf="@+id/act085_user_list_frg_cell_gd_end"
            app:layout_constraintStart_toEndOf="@id/act085_user_list_frg_cell_iv_photo"
            app:layout_constraintTop_toTopOf="parent"
            />

        <TextView
            android:id="@+id/act085_user_list_frg_cell_tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="5dp"
            tools:text="Jose Gousefi Jr - Trad"
            app:layout_constraintEnd_toStartOf="@+id/act085_user_list_frg_cell_gd_end"
            app:layout_constraintStart_toEndOf="@+id/act085_user_list_frg_cell_iv_photo"
            app:layout_constraintTop_toBottomOf="@+id/act085_user_list_frg_cell_tv_nick" />

        <TextView
            android:id="@+id/act085_user_list_frg_cell_tv_email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="5dp"
            tools:text="jjr@corp.com"
            app:layout_constraintEnd_toStartOf="@+id/act085_user_list_frg_cell_gd_end"
            app:layout_constraintStart_toEndOf="@+id/act085_user_list_frg_cell_iv_photo"
            app:layout_constraintTop_toBottomOf="@+id/act085_user_list_frg_cell_tv_name" />

        <TextView
            android:id="@+id/act085_user_list_frg_cell_tv_erp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="5dp"
            tools:text="V9965"
            app:layout_constraintEnd_toStartOf="@+id/act085_user_list_frg_cell_gd_end"
            app:layout_constraintStart_toEndOf="@+id/act085_user_list_frg_cell_iv_photo"
            app:layout_constraintTop_toBottomOf="@+id/act085_user_list_frg_cell_tv_email" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>