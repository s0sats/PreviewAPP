<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp">

    <android.support.constraint.ConstraintLayout
        android:id="@+id/act069_ticket_cell_cl_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/namoa_cell_8_states"
        android:paddingBottom="8dp">

        <android.support.constraint.Guideline
            android:id="@+id/act069_ticket_cell_guide_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_begin="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.Guideline
            android:id="@+id/act069_ticket_cell_guide_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="8dp"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.ConstraintLayout
            android:id="@+id/act069_ticket_cell_cl_ticket_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_tv_status"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/act069_ticket_cell_tv_ticket_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/font_size_item_md"
                android:textStyle="bold"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="2019.999" />
        </android.support.constraint.ConstraintLayout>

        <TextView
            android:id="@+id/act069_ticket_cell_tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Pending" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_type_path"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="@dimen/font_size_item"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_cl_ticket_id"
            tools:text="2019.Trad" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_type_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_tv_type_path"
            tools:text="Desc" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_open_comment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/namoa_color_light_blue"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_tv_type_desc"
            tools:text="Comentario aqui Comentario aqui Comentario aqui Comentario aqui" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_open_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_tv_open_comment"
            tools:text="Open Date:" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_open_date_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="@id/act069_ticket_cell_tv_open_date"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/act069_ticket_cell_tv_open_date"
            app:layout_constraintTop_toTopOf="@id/act069_ticket_cell_tv_open_date"
            app:layout_constraintVertical_bias="0.0"
            tools:text="99/99/9999" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_forecast_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_tv_open_date_val"
            tools:text="Forecast:" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_forecast_date_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="@id/act069_ticket_cell_tv_forecast_date"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/act069_ticket_cell_tv_forecast_date"
            app:layout_constraintTop_toTopOf="@id/act069_ticket_cell_tv_forecast_date"
            tools:text="99/99/9999" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_site"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_tv_forecast_date_val"
            tools:text="Site: " />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_site_dec"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/namoa_color_danger_red"
            app:layout_constraintBottom_toBottomOf="@id/act069_ticket_cell_tv_site"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/act069_ticket_cell_tv_site"
            app:layout_constraintTop_toTopOf="@id/act069_ticket_cell_tv_site"
            tools:text="666 - trad" />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_product"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="8dp"
            android:textSize="@dimen/font_size_font_12"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_tv_site_dec"
            tools:text="Btt4 " />

        <TextView
            android:id="@+id/act069_ticket_cell_tv_serial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act069_ticket_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act069_ticket_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act069_ticket_cell_tv_product"
            tools:text="Btt00123" />


    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>
