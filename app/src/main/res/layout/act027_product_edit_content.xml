<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/namoa_color_gray2"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_product_edit_content_tv_seq_tmp_ttl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:text="Ref"
                    android:textStyle="bold" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/act027_product_edit_content_tv_seq_tmp_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="201" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_product_edit_content_tv_prod_ttl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:text="Product"
                    android:textSize="@dimen/font_size_title_md"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/act027_product_edit_content_tv_prod_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Prod - Desc"
                    android:textSize="@dimen/font_size_title_dialog"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:gravity="center"
                android:orientation="horizontal">

                <android.support.constraint.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/act027_product_edit_content_iv_gallery"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_camera"
                        android:tint="@color/namoa_icon_petrol_blue"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/act027_product_edit_content_tv_photo_amount"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/badge"
                        android:gravity="center"
                        app:layout_constraintBottom_toBottomOf="@+id/act027_product_edit_content_iv_gallery"
                        app:layout_constraintEnd_toEndOf="@+id/act027_product_edit_content_iv_gallery"
                        app:layout_constraintHorizontal_bias="1.25"
                        app:layout_constraintStart_toStartOf="@+id/act027_product_edit_content_iv_gallery"
                        app:layout_constraintTop_toTopOf="@+id/act027_product_edit_content_iv_gallery"
                        app:layout_constraintVertical_bias="0.0"
                        tools:text="10" />

                </android.support.constraint.ConstraintLayout>

                <LinearLayout
                    android:id="@+id/act027_product_edit_content_ll_save"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="8dp"
                    android:gravity="center"
                    android:visibility="visible"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/act027_product_edit_content_iv_save"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_ok_ns_states" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="-10dp"
            android:layout_marginRight="-10dp"
            android:orientation="vertical">

            <com.namoa_digital.namoa_library.ctls.ApplyRepairImageFF
                android:id="@+id/act027_product_edit_content_arff_applyrepair"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:mValue="00" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/act027_product_edit_content_ll_qty_apply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="-30dp"
            android:orientation="horizontal"
            android:paddingLeft="15dp"
            android:visibility="gone">

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act027_product_edit_content_mk_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:inputType="text"
                android:minWidth="50dp"
                android:selectAllOnFocus="true"
                app:mBARCODE="false"
                app:mDecimal="3"
                app:mInputType="NUMBER" />

            <TextView
                android:id="@+id/act027_product_edit_content_tv_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="unit" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="15dp">

            <CheckBox
                android:id="@+id/act027_product_edit_content_cb_inspection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@null"
                android:drawableLeft="@drawable/fundo_ic_assignment_turned"
                android:text="Inspection" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingEnd="10dp"
            android:paddingStart="10dp">

            <TextView
                android:id="@+id/act027_product_edit_content_tv_comments_lbl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comments"
                android:textSize="@dimen/font_size_item_md" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act027_product_edit_content_mk_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Comentario aqui"
                android:inputType="textMultiLine"
                android:maxLength="500"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="-10dp"
            android:layout_marginRight="-10dp"
            android:orientation="vertical">

            <com.namoa_digital.namoa_library.ctls.PictureFF
                android:id="@+id/act027_product_edit_content_pff_sketch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="right"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/act027_product_edit_content_ll_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="10dp"
                android:background="@color/namoa_color_light_blue3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/act027_product_edit_content_tv_nick"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nick"
                    android:textColor="@color/lib_custom_cell_font_color"
                    android:textSize="@dimen/font_size_item_md" />

                <TextView
                    android:id="@+id/act027_product_edit_content_tv_date"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:text="01/01/2018"
                    android:textColor="@color/lib_custom_cell_font_color"
                    android:textSize="@dimen/font_size_item_md" />
            </LinearLayout>

        </LinearLayout>


    </LinearLayout>

</ScrollView>