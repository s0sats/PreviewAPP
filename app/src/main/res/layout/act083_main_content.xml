<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.act083.Act083_Main">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/act083_cl_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/act083_cv_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                    android:id="@+id/act083_mket_filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:hint="Search Desc - Trad"
                    android:inputType="text"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:mBARCODE="false"
                    app:mNFC="false"
                    app:mOCR="false" />

                <RadioGroup
                    android:id="@+id/act083_tabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act083_mket_filter">

                    <RadioButton
                        android:id="@+id/act083_tab_my_tickets"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:textColor="@color/my_tickets_radio"
                        android:layout_weight="1"
                        android:background="@drawable/act074_radio_states"
                        tools:text="ACOES"
                        android:checked="true"
                        android:gravity="center"
                        android:button="@null" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="match_parent" />

                    <RadioButton
                        android:id="@+id/act083_tab_other_tickets"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:textColor="@color/my_tickets_radio"
                        android:layout_weight="1"
                        tools:text="OUTROS"
                        android:background="@drawable/act074_radio_states"
                        android:gravity="center"
                        android:button="@null" />

                </RadioGroup>



            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/act083_tv_no_result"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act083_cv_header"
            tools:text="NENHUM ITEM ENCONTRADO" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/act083_rv_actions_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            app:layoutManager="LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act083_cv_header"
            app:layout_constraintVertical_bias="1.0"
            tools:listitem="@layout/my_actions_item"
            tools:itemCount="4"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:visibility="gone"
            android:indeterminateTintMode="src_in"
            android:indeterminateTint="@color/namoa_amount_pipeline_background_btn"
            app:layout_constraintBottom_toBottomOf="@+id/act083_rv_actions_list"
            app:layout_constraintEnd_toEndOf="@+id/act083_rv_actions_list"
            app:layout_constraintStart_toStartOf="@+id/act083_rv_actions_list"
            app:layout_constraintTop_toBottomOf="@+id/act083_cv_header" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/include"
        layout="@layout/footer_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>