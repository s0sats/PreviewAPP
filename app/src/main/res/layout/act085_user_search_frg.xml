<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act085.Act085Main">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/act085_user_search_frg_gd_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="8dp" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/act085_user_search_frg_gd_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="8dp" />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act085_user_search_frg_mket_user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@+id/act085_user_search_frg_gd_end"
                app:layout_constraintStart_toStartOf="@+id/act085_user_search_frg_gd_start"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="8dp"
                app:mBARCODE="true"
                app:mOCR="false"
                app:mNFC="false"
                app:mOCRVin="false"
                android:inputType="text"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:hint="Name / Nick - Trad"
                app:mInputType="text"
                android:imeOptions="actionDone"
                />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act085_user_search_frg_mket_user_email"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@+id/act085_user_search_frg_gd_end"
                app:layout_constraintStart_toStartOf="@+id/act085_user_search_frg_gd_start"
                app:layout_constraintTop_toBottomOf="@id/act085_user_search_frg_mket_user_name"
                android:layout_marginTop="8dp"
                app:mBARCODE="true"
                app:mOCR="false"
                app:mNFC="false"
                app:mOCRVin="false"
                android:inputType="text|textEmailAddress"
                app:mInputType="text"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:hint="Email - trad"
                android:imeOptions="actionDone"
                />


            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act085_user_search_frg_mket_user_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/act085_user_search_frg_gd_end"
                app:layout_constraintStart_toStartOf="@id/act085_user_search_frg_gd_start"
                app:layout_constraintTop_toBottomOf="@id/act085_user_search_frg_mket_user_email"
                android:layout_marginTop="8dp"
                app:mBARCODE="true"
                app:mOCR="false"
                app:mNFC="false"
                app:mOCRVin="false"
                android:inputType="number"
                app:mInputType="NUMBER"
                android:hint="User Code - Trad"
                android:imeOptions="actionDone"
                />

            <com.namoa_digital.namoa_library.ctls.MKEditTextNM
                android:id="@+id/act085_user_search_frg_mket_user_erp_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/act085_user_search_frg_gd_end"
                app:layout_constraintStart_toStartOf="@id/act085_user_search_frg_gd_start"
                app:layout_constraintTop_toBottomOf="@id/act085_user_search_frg_mket_user_code"
                android:layout_marginTop="8dp"
                app:mBARCODE="true"
                app:mOCR="false"
                app:mNFC="false"
                app:mOCRVin="false"
                android:inputType="text"
                android:hint="ERP User Code - Trad"
                android:imeOptions="actionDone"
                />

            <Button
                android:id="@+id/act085_user_search_frg_btn_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/namoa_cell_3_states"
                android:padding="15dp"
                android:text="Buscar User - trad"
                android:textColor="@color/padrao_WHITE"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/act085_user_search_frg_gd_end"
                app:layout_constraintStart_toStartOf="@id/act085_user_search_frg_gd_start"
                app:layout_constraintTop_toBottomOf="@id/act085_user_search_frg_mket_user_erp_code"
                app:layout_constraintVertical_bias="0.0" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>