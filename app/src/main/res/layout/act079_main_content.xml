<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:gravity="center_vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act079.Act079_Main"
    tools:showIn="@layout/act079_main">

    <FrameLayout
        android:id="@+id/act079_frg_pipeline_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_default="wrap"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.namoa_digital.namoa_library.ctls.FabMenu
        android:id="@+id/act079_fabMenu_anchor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:elevation="5dp"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintEnd_toEndOf="parent"
        app:mButton_Back_Color="@color/namoa_sync_pipeline_background_btn"
        app:mButton_Resource="@drawable/ic_menu_hamburger"
        app:mButton_Resource_Color="@color/colorPrimary" />

    <include
        android:id="@+id/include"
        layout="@layout/footer_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/act079_gdl_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="8dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/act079_gdl_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="8dp" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/act079_nsv_main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/include"
        app:layout_constraintEnd_toStartOf="@id/act079_gdl_end"
        app:layout_constraintStart_toStartOf="@id/act079_gdl_start"
        app:layout_constraintTop_toBottomOf="@id/act079_frg_pipeline_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="60dp">

            <LinearLayout
                android:id="@+id/act079_ll_open_photo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act079_tv_open_photo_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textStyle="bold"
                    tools:text="Photo" />

                <!-- A cor do icone é definida via code-->
                <ImageView
                    android:id="@+id/act079_iv_open_photo"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    app:srcCompat="@drawable/ic_foto_ns_black" />

                <View
                    android:id="@+id/act079_divider_1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/text_black" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/act079_ll_open_comment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/act079_tv_open_comment_lbl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"
                    tools:text="Comentario da Abertura - trad" />

                <TextView
                    android:id="@+id/act079_tv_open_comment_val"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:layout_constraintEnd_toStartOf="@id/act079_gdl_end"
                    app:layout_constraintStart_toStartOf="@id/act079_gdl_start"
                    app:layout_constraintTop_toBottomOf="@id/act079_tv_open_comment_lbl"
                    tools:text="Comentario da Abertura - trad\nComentario da Abertura - trad" />

                <View
                    android:id="@+id/act079_divider_2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/text_black" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/act079_ll_privacy_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toStartOf="@id/act079_gdl_end"
                app:layout_constraintStart_toStartOf="@id/act079_gdl_start"
                app:layout_constraintTop_toBottomOf="@id/act079_divider_2">

                <LinearLayout
                    android:id="@+id/act079_ll_open_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/act079_tv_open_username_lbl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Nome da Pessoa da Abertura - trad" />

                    <TextView
                        android:id="@+id/act079_tv_open_username_val"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/act079_tv_open_username_lbl"
                        tools:text="Nome da Pessoa da Abertura - trad" />

                    <View
                        android:id="@+id/act079_divider_3"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/text_black" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/act079_ll_open_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/act079_tv_open_email_lbl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="E-Mail da Pessoa da Abertura - trad" />

                    <TextView
                        android:id="@+id/act079_tv_open_email_val"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/act079_tv_open_email_lbl"
                        tools:text="E-Mail da Pessoa da Abertura - trad" />

                    <View
                        android:id="@+id/act079_divider_4"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/text_black" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/act079_ll_open_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/act079_tv_open_phone_lbl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Telefone da Pessoa da Abertura - trad" />

                    <TextView
                        android:id="@+id/act079_tv_open_phone_val"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/act079_tv_open_phone_lbl"
                        tools:text="(11) 99999 8765" />

                    <View
                        android:id="@+id/act079_divider_5"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/text_black" />
                </LinearLayout>

            </LinearLayout>
            
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/act079_iv_form_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/act079_tv_form_score"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/act079_tv_form_score"
                    app:srcCompat="@drawable/ic_baseline_star_24"
                    app:tint="@color/namoa_color_gray_4" />

                <ImageView
                    android:id="@+id/act079_iv_form_nc_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act079_tv_form_score"
                    app:srcCompat="@drawable/ic_non_compliance_on" />

                <TextView
                    android:id="@+id/act079_tv_form_score"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintWidth_default="wrap"
                    app:layout_constraintHorizontal_bias="0"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/act079_iv_form_score"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="TextView" />

                <TextView
                    android:id="@+id/act079_tv_form_nc_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintWidth_default="wrap"
                    app:layout_constraintHorizontal_bias="0"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/namoa_color_danger_red_lib"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/act079_iv_form_nc_count"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/act079_iv_form_nc_count"
                    app:layout_constraintTop_toTopOf="@id/act079_iv_form_nc_count"
                    tools:text="TextView" />


                <ImageView
                    android:id="@+id/act079_iv_form_download_pdf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/act079_tv_form_nc_count"
                    app:srcCompat="@drawable/ic_baseline_get_app_24"
                    app:tint="@color/namoa_pipeline_product_lbl" />

                <TextView
                    android:id="@+id/act079_tv_form_download_pdf"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintWidth_default="wrap"
                    app:layout_constraintHorizontal_bias="0"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/namoa_pipeline_product_lbl"
                    app:layout_constraintBottom_toBottomOf="@id/act079_iv_form_download_pdf"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/act079_iv_form_download_pdf"
                    app:layout_constraintTop_toTopOf="@id/act079_iv_form_download_pdf"
                    tools:text="TextView" />
                
            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:id="@+id/act079_ll_nc_views"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>