<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/act070_measure_cell_cv_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    >

    <android.support.constraint.ConstraintLayout
        android:id="@+id/act070_measure_cell_cl_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/namoa_cell_8_states"
        android:paddingBottom="8dp">

        <android.support.constraint.Guideline
            android:id="@+id/act070_measure_cell_guide_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_begin="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <android.support.constraint.Guideline
            android:id="@+id/act070_measure_cell_guide_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="8dp"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_ctrl_type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toEndOf="@+id/act070_measure_cell_tv_seq"
            app:layout_constraintStart_toStartOf="@+id/act070_measure_cell_tv_status"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="MEDIÇÃO" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_seq"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act070_measure_cell_guide_start"
            app:layout_constraintTop_toTopOf="@+id/act070_measure_cell_tv_status"
            tools:text="1" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toEndOf="@id/act070_measure_cell_tv_seq"
            app:layout_constraintTop_toBottomOf="@+id/act070_measure_cell_tv_ctrl_type"
            tools:text="Pending" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_measure_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/namoa_color_light_blue"
            app:layout_constraintEnd_toStartOf="@id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act070_measure_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act070_measure_cell_tv_status"
            tools:text="Comentario aqui" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_measure_value_lbl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act070_measure_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_measure_cell_tv_measure_desc"
            tools:text="Valor medido :" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_measure_value_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@id/act070_measure_cell_tv_measure_value_lbl"
            app:layout_constraintEnd_toStartOf="@id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toEndOf="@id/act070_measure_cell_tv_measure_value_lbl"
            app:layout_constraintTop_toTopOf="@id/act070_measure_cell_tv_measure_value_lbl"
            app:layout_constraintVertical_bias="0.0"
            tools:text="68 " />

        <TextView
            android:id="@+id/act070_measure_cell_tv_measure_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toStartOf="@id/act070_measure_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_measure_cell_tv_measure_info"
            tools:text="5 -ABERTURA DE PORTA" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_measure_dt_lbl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act070_measure_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_measure_cell_tv_measure_value_val"
            tools:text="Data Medição :" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_measure_dt_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/act070_measure_cell_tv_measure_dt_lbl"
            app:layout_constraintEnd_toStartOf="@id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toEndOf="@id/act070_measure_cell_tv_measure_value_lbl"
            app:layout_constraintTop_toTopOf="@+id/act070_measure_cell_tv_measure_dt_lbl"
            tools:text="22/01/1988" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_serial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toStartOf="@+id/act070_measure_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_measure_cell_tv_product"
            tools:text="Btt00123" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_product"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textSize="@dimen/font_size_font_12"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/act070_measure_cell_guide_end"
            app:layout_constraintStart_toStartOf="@+id/act070_measure_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_measure_cell_tv_measure_dt_val"
            tools:text="Btt4 " />

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>
