<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/act070_action_cell_cv_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/act070_action_cell_cl_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/namoa_cell_8_states"
        android:paddingBottom="8dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/act070_action_cell_guide_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_begin="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/act070_action_cell_guide_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="8dp"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act070_measure_cell_tv_ctrl_type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/act070_action_cell_tv_status"
            app:layout_constraintStart_toStartOf="@+id/act070_action_cell_tv_status"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="MEDIÇÃO" />

        <TextView
            android:id="@+id/act070_action_cell_tv_seq"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/font_size_item_md"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/act070_action_cell_tv_status"
            app:layout_constraintStart_toStartOf="@id/act070_action_cell_guide_start"
            app:layout_constraintTop_toTopOf="@+id/act070_action_cell_tv_status"
            tools:text="1" />

        <TextView
            android:id="@+id/act070_action_cell_tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:textSize="@dimen/font_size_title"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/act070_action_cell_guide_end"
            app:layout_constraintStart_toEndOf="@id/act070_action_cell_tv_seq"
            app:layout_constraintTop_toBottomOf="@+id/act070_measure_cell_tv_ctrl_type"
            tools:text="Pending" />

        <TextView
            android:id="@+id/act070_action_cell_tv_comment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/namoa_color_light_blue"
            app:layout_constraintBottom_toBottomOf="@+id/act070_action_cell_iv_photo"
            app:layout_constraintEnd_toStartOf="@id/act070_action_cell_guide_end"
            app:layout_constraintStart_toEndOf="@+id/act070_action_cell_iv_photo"
            app:layout_constraintTop_toTopOf="@+id/act070_action_cell_iv_photo"
            tools:text="Comentario aqui" />

        <TextView
            android:id="@+id/act070_action_cell_tv_partner_lbl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/act070_action_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_action_cell_iv_photo"
            tools:text="Parceiro :" />

        <TextView
            android:id="@+id/act070_action_cell_tv_partner_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintBottom_toBottomOf="@id/act070_action_cell_tv_partner_lbl"
            app:layout_constraintEnd_toStartOf="@id/act070_action_cell_iv_action"
            app:layout_constraintStart_toEndOf="@id/act070_action_cell_tv_partner_lbl"
            app:layout_constraintTop_toTopOf="@id/act070_action_cell_tv_partner_lbl"
            app:layout_constraintVertical_bias="0.0"
            tools:text="Namoa " />

        <TextView
            android:id="@+id/act070_action_cell_tv_product"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="4dp"
            android:textSize="@dimen/font_size_font_12"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_action_cell_iv_action"
            app:layout_constraintStart_toStartOf="@id/act070_action_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act070_action_cell_tv_partner_val"
            tools:text="Btt4 " />

        <TextView
            android:id="@+id/act070_action_cell_tv_serial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/act070_action_cell_iv_action"
            app:layout_constraintStart_toStartOf="@id/act070_action_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@id/act070_action_cell_tv_product"
            tools:text="Btt00123" />

        <ImageView
            android:id="@+id/act070_action_cell_iv_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@+id/act070_action_cell_guide_start"
            app:layout_constraintTop_toBottomOf="@+id/act070_action_cell_tv_seq"
            app:srcCompat="@drawable/ic_camera_off" />

        <ImageView
            android:id="@+id/act070_action_cell_iv_action"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/act070_action_cell_guide_end"
            app:layout_constraintTop_toBottomOf="@id/act070_action_cell_tv_comment"
            app:srcCompat="@drawable/ic_ok_azul_ns_states" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
