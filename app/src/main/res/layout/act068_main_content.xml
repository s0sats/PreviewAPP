<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act068.Act068_Main"
    tools:showIn="@layout/act068_main">

    <!--<ScrollView-->
    <!--android:layout_width="match_parent"-->
    <!--android:layout_height="0dp"-->
    <!--android:layout_weight="1"-->
    <!--android:padding="10dp">-->


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <android.support.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp">

            <RadioGroup
                android:id="@+id/act068_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/act068_tab_serial_search"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/act074_radio_states"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:textColor="@color/my_tickets_radio"
                    tools:text="SERIAL" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="match_parent" />

                <RadioButton
                    android:id="@+id/act068_tab_ticket_search"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/act074_radio_states"
                    android:button="@null"
                    android:gravity="center"
                    android:textColor="@color/my_tickets_radio"
                    tools:text="TICKET" />
            </RadioGroup>
        </android.support.v7.widget.CardView>

        <FrameLayout
            android:id="@+id/act068_frg_placeholder"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />


    </LinearLayout>


    <!--</ScrollView>-->

    <include layout="@layout/footer_base" />

</LinearLayout>
