<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.act020.Act020_Main"
    tools:showIn="@layout/act020_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <com.namoa_digital.namoa_library.ctls.MKEditTextNM
            android:id="@+id/act020_mket_search"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/namoa_bg_1"
            android:inputType="text"
            android:padding="10dp"
            android:textSize="@dimen/font_size_title"
            app:mBARCODE="true"
            app:mNFC="true"
            app:mOCR="false" />


        <Button
            android:id="@+id/act020_btn_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:background="@drawable/btn_namoa_main_states"
            android:text="NEW"
            android:textColor="@color/padrao_WHITE" />
    </LinearLayout>

    <ListView
        android:id="@+id/act020_lv_prod_serial"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        />

    <include layout="@layout/footer_base" />

</LinearLayout>
