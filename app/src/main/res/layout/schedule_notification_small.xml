<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="5dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/schedule_notification_small_iv_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_warning_white_24dp"
        android:tint="@color/namoa_color_orange"
        android:layout_marginRight="5dp"

        />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/schedule_notification_small_date_start"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="25/03/2020"
            style="@style/TextAppearance.Compat.Notification.Title"
            />

        <TextView
            android:id="@+id/schedule_notification_small_desc"
            android:layout_marginTop="1dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="1000 horas"
            android:textStyle="bold"
            style="@style/TextAppearance.Compat.Notification.Title"
            />

    </LinearLayout>


</LinearLayout>