<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="3dp"
    android:background="@drawable/item_menu_states"
    android:focusable="false"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/menu_llChecklist">

    <ImageView
        android:id="@+id/menu_ivChecklist"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:gravity="center_horizontal"
        android:tint="@color/item_menu_title_color" />

    <TextView
        android:id="@+id/menu_tvChecklist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/item_menu_title_normal"         />

</LinearLayout>
