<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingTop="15dp"
    android:paddingHorizontal="20dp"
    android:orientation="vertical"
    android:id="@+id/act091_list_item">

    <TextView
        android:id="@+id/act091_list_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Martelinho de Ouro"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:textStyle="bold"
        android:ellipsize="end"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <View
            android:id="@+id/view"
            android:layout_width="240dp"
            android:layout_height="1dp"
            android:layout_marginBottom="0.5dp"
            android:background="@android:color/darker_gray"
            app:layout_constraintBottom_toBottomOf="@id/act091_list_progress"
            app:layout_constraintStart_toStartOf="@id/act091_list_progress"
            app:layout_constraintTop_toTopOf="@id/act091_list_progress" />


        <ProgressBar
            android:id="@+id/act091_list_progress"
            style="@android:style/Widget.Material.ProgressBar.Horizontal"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:progress="100"
            android:progressTint="@color/namoa_light_blue"
            android:background="@android:color/transparent"
            android:layout_marginTop="5dp"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/act091_list_price"
            style="@style/TextAppearance.MaterialComponents.Subtitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:ellipsize="end"
            android:text="(Especificar preço)"
            app:layout_constraintBottom_toBottomOf="@id/act091_list_progress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/act091_list_progress" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="15dp"
        android:background="@android:color/darker_gray"
        />

</LinearLayout>