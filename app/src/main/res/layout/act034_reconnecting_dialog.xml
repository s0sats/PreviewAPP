<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_gravity="center"
    android:background="@color/padrao_TRANSPARENT"
    android:id="@+id/act034_reconnecting_ll_main"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center">

        <ImageView
            android:id="@+id/act034_reconnecting_iv_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:scaleType="fitCenter"
            android:background="@drawable/badge_chat"
            android:src="@drawable/ic_sync_black_24dp"
            android:rotationX="180"
            android:tint="@color/padrao_WHITE"
            />
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"/>
        <TextView
            android:id="@+id/act034_reconnecting_tv_msg_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try connection -"
            android:layout_gravity="center_vertical"
            />
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"/>
        <TextView
            android:id="@+id/act034_reconnecting_tv_msg_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(66)"
            android:layout_gravity="center_vertical"
            />

    </LinearLayout>


</LinearLayout>

