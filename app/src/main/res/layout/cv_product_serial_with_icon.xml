<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <android.support.v7.widget.CardView
        android:id="@+id/cv_product_serial_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:elevation="5dp">

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="10dp"
            android:paddingTop="10dp">

            <ImageView
                android:id="@+id/iv_product_serial_id"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:scaleType="fitXY"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_product_serial_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:maxLines="2"
                android:textSize="@dimen/font_size_item_md"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/tv_product_serial_infos"
                app:layout_constraintEnd_toStartOf="@+id/iv_editable_serial"
                app:layout_constraintStart_toEndOf="@+id/iv_product_serial_id"
                app:layout_constraintTop_toTopOf="@+id/iv_product_serial_id"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/tv_product_serial_infos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:maxLines="2"
                app:layout_constraintBottom_toBottomOf="@+id/iv_product_serial_id"
                app:layout_constraintEnd_toStartOf="@+id/iv_editable_serial"
                app:layout_constraintStart_toEndOf="@+id/iv_product_serial_id"
                app:layout_constraintTop_toBottomOf="@+id/tv_product_serial_id"
                app:layout_constraintVertical_bias="1.0" />

            <ImageView
                android:id="@+id/iv_editable_serial"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="16dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_edit_black_24dp"
                android:tint="@color/namoa_color_light_blue"
                app:layout_constraintBottom_toBottomOf="@+id/iv_product_serial_id"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/iv_product_serial_id" />

        </android.support.constraint.ConstraintLayout>
    </android.support.v7.widget.CardView>
</FrameLayout>