<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <Button
            android:id="@+id/act043_frag_package_detail_list_btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_namoa_main_states"
            android:text="Cancel - trad"
            android:textColor="@color/padrao_WHITE"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/act043_frag_package_detail_list_btn_save"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act043_frag_package_detail_list_rv_pack_service_detail" />

    <Button
            android:id="@+id/act043_frag_package_detail_list_btn_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_namoa_main_states"
            android:text="Save - trad"
            android:textColor="@color/padrao_WHITE"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/act043_frag_package_detail_list_btn_cancel"
            app:layout_constraintTop_toTopOf="@+id/act043_frag_package_detail_list_btn_cancel" />

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/act043_frag_package_detail_list_rv_pack_service_detail"
            android:name="com.namoadigital.prj001.ui.act043.Act043_Frag_Package_Detail_List"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            app:layoutManager="LinearLayoutManager"
            app:layout_constraintBottom_toTopOf="@+id/act043_frag_package_detail_list_btn_cancel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act043_frag_package_detail_list_v_divider"
            tools:context="com.namoadigital.prj001.ui.act043.Act043_Frag_Package_Detail_List"
            tools:listitem="@layout/act043_frag_package_detail_list_item" />

    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/act043_frag_package_detail_list_cl_pack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/namoa_color_gray_5"
            android:padding="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        <ImageView
                android:id="@+id/act043_frag_package_detail_list_iv_pack_icon"
                android:layout_width="30dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:tint="@color/namoa_color_dark_blue"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_archive_material_black_24dp" />

        <ImageView
                android:id="@+id/act043_frag_package_detail_list_iv_remove_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/namoa_danger_bg_states"
                android:padding="2dp"
                android:tint="@color/padrao_WHITE"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_trash" />

        <TextView
                android:id="@+id/act043_frag_package_detail_list_tv_pack_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:padding="10dp"
                android:text="Pack Desc - trad "
                android:textSize="@dimen/font_size_title_dialog"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/act043_frag_package_detail_list_iv_remove_icon"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@+id/act043_frag_package_detail_list_iv_pack_icon"
                app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
            android:id="@+id/act043_frag_package_detail_list_v_divider"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="@color/namoa_color_gray"
            app:layout_constraintBottom_toTopOf="@id/act043_frag_package_detail_list_rv_pack_service_detail"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/act043_frag_package_detail_list_cl_pack" />


</androidx.constraintlayout.widget.ConstraintLayout>